    .case-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 36px 32px;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      transition:
        box-shadow var(--tr),
        transform var(--tr);
    }

    .case-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      border-radius: var(--radius) var(--radius) 0 0;
    }

    .cc-teal::before {
      background: linear-gradient(90deg, #2bbfa8, #6dd4a0);
    }
    .cc-blue::before {
      background: linear-gradient(90deg, var(--blue), var(--green));
    }

    .case-card:hover {
      box-shadow: 0 16px 56px rgba(0, 0, 0, 0.12);
      transform: translateY(-3px);
    }

    .case-img {
      margin: -36px -32px 28px -32px;
