      display: block;
      transition: transform 0.5s ease;
    }

    .case-card:hover .case-img img {
      transform: scale(1.04);
    }

    .case-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gray-light);
      margin-bottom: 18px;
    }

    .case-tag::before {
      content: "";
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--border);
      flex-shrink: 0;
    }

    .cc-teal .case-tag::before {
      background: var(--teal);
    }
    .cc-blue .case-tag::before {
      background: var(--blue);
    }

    .case-card h3 {
      font-size: 22px;
      font-weight: 300;
      letter-spacing: -0.02em;
      color: var(--black);
      margin-bottom: 14px;
      line-height: 1.25;
    }

    .case-card p {
      font-size: 14px;
      color: var(--gray-mid);
      line-height: 1.75;
      margin-bottom: 26px;
