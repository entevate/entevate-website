      .offerings-grid {
        grid-template-columns: 1fr;
      }

      .proof-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .momentify-stats {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 600px) {
      .cta-band-actions {
        flex-direction: column;
