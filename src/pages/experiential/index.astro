---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.jsx";
import Footer from "../../components/Footer.jsx";
import "../../global.css";

// Page metadata
const title = "Experiential Branding & Marketing — ENTEVATE";
const description =
  "We help you spark connection and drive action through intentional, emotionally engaging brand moments. With tools like Momentify, every interaction becomes measurable, memorable, and built to scale.";

const jsonLd = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Experiential Branding & Marketing",
    "provider": { "@type": "Organization", "name": "ENTEVATE" },
    "description": description,
    "url": "https://www.entevate.com/experiential",
    "serviceType": "Experiential Marketing",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Experiential Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Trade Show Activations & Exhibit Design" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Momentify Platform — In-Person Engagement & ROX™ Scoring" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AR/VR/Spatial Computing Experiences" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Brand Strategy & Experiential Marketing" } }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is experiential branding?",
        "acceptedAnswer": { "@type": "Answer", "text": "Experiential branding creates intentional, emotionally engaging brand moments that spark connection and drive measurable action — from trade show activations and immersive AR/VR experiences to branded environments and live events." }
      },
      {
        "@type": "Question",
        "name": "What is Momentify?",
        "acceptedAnswer": { "@type": "Answer", "text": "Momentify is ENTEVATE's proprietary engagement platform that captures real-time interaction data at live events and experiences, providing ROX (Return on Experience) scoring and actionable insights to measure the impact of brand activations." }
      },
      {
        "@type": "Question",
        "name": "How does ENTEVATE use AR and VR for brand experiences?",
        "acceptedAnswer": { "@type": "Answer", "text": "ENTEVATE designs and deploys AR, VR, and spatial computing experiences that transform how audiences interact with products and brands — from interactive trade show exhibits to remote product demonstrations and immersive training environments." }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.entevate.com" },
      { "@type": "ListItem", "position": 2, "name": "Experiential Branding & Marketing", "item": "https://www.entevate.com/experiential" }
    ]
  }
]);
---

<BaseLayout title={title} description={description} ogImage="/images/og/ebm-og.png" jsonLd={jsonLd}>
  <Header client:load />

  <!-- ═══════════════════════════ HERO ═══════════════════════════ -->
  <section class="hero" id="top">
    <div class="hero-inner">
      <div class="fade-up">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>
          Experiential Branding & Marketing
        </div>
        <h1>
          Crafting Immersive Brand Experiences <span class="accent"
            >That Resonate.</span
          >
        </h1>
        <p class="hero-sub">
          We help you spark connection and drive action through intentional,
          emotionally engaging brand moments. With tools like Momentify, every
          interaction becomes measurable, memorable, and built to scale.
        </p>
        <div class="hero-actions">
          <a href="/contact?service=experiential" class="btn-teal"
            >Start a Conversation →</a
          >
          <a href="#offerings" class="btn-ghost-dark">Explore Our Services ↓</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ OFFERINGS ═══════════════════════════ -->
  <section class="offerings-section" id="offerings">
    <div class="container">
      <div class="fade-up">
        <div class="section-label">What We Create</div>
        <h2 class="section-title">Experiences that move people.</h2>
        <p class="section-subtitle">
          From live events to immersive AR/VR activations, we design brand
          moments that are human-first, strategically sound, and built to
          perform.
        </p>
      </div>

      <div class="offerings-grid">
        <div class="offering-card oc-teal fade-up">
          <div class="offering-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path
                d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <circle
                cx="9"
                cy="7"
                r="4"
                stroke="currentColor"
                stroke-width="1.6"></circle>
              <path
                d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <h3>Live Events &amp; Brand Activations Strategy</h3>
          <em>Where your brand becomes an experience.</em>
          <p>
            From trade show booths to full-scale corporate events, we design and
            produce immersive, on-brand experiences that create lasting
            impressions and meaningful connections. Every activation is rooted
            in strategy, executed with precision, and measured for real impact.
          </p>
          <a href="/contact?service=experiential" class="offering-cta"
            >Activate Your Brand →</a
          >
        </div>

        <div class="offering-card oc-teal-mid fade-up">
          <div class="offering-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path
                d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <circle
                cx="12"
                cy="12"
                r="3"
                stroke="currentColor"
                stroke-width="1.6"></circle>
            </svg>
          </div>
          <h3>AR, VR &amp; Spatial Computing Experiences</h3>
          <em>Redefining what brand engagement can be.</em>
          <p>
            We design and build augmented reality, virtual reality, and
            spatial computing experiences that place your audience inside
            your story, powered by cutting-edge technology and grounded
            in measurable outcomes.
          </p>
          <a href="/contact?service=experiential" class="offering-cta"
            >Explore Immersive Tech →</a
          >
        </div>

        <div class="offering-card oc-blue fade-up">
          <div class="offering-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <rect
                x="3"
                y="3"
                width="18"
                height="18"
                rx="2"
                stroke="currentColor"
                stroke-width="1.6"></rect>
              <path
                d="M3 9h18M9 21V9"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"></path>
            </svg>
          </div>
          <h3>Content Production &amp; Brand Storytelling</h3>
          <em>Stories that earn attention and drive action.</em>
          <p>
            From concept to final cut, we produce video, photography, and
            multimedia content that brings your brand narrative to life. Our
            storytelling framework ensures every piece of content serves a
            strategic purpose across every channel.
          </p>
          <a href="/contact?service=experiential" class="offering-cta"
            >Tell Your Story →</a
          >
        </div>

        <div class="offering-card oc-green fade-up">
          <div class="offering-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path
                d="M12 2L2 7l10 5 10-5-10-5z"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linejoin="round"></path>
              <path
                d="M2 17l10 5 10-5M2 12l10 5 10-5"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <h3>Trade Show &amp; Exhibition Experience Design</h3>
          <em>Stand out on the floor that matters most.</em>
          <p>
            We design trade show exhibits and exhibition environments that
            attract, engage, and convert. From concept and floorplan to
            fabrication management and on-site execution, we deliver
            complete booth experiences that drive results.
          </p>
          <a href="/contact?service=experiential" class="offering-cta"
            >Design Your Exhibit →</a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ MOMENTIFY SPOTLIGHT ═══════════════════════════ -->
  <section class="momentify-section" id="momentify">
    <div class="momentify-inner">
      <div class="momentify-left fade-up">
        <span class="momentify-eyebrow">Featured Platform</span>
        <img src="/logos/momentify-logo.svg" alt="Momentify" class="momentify-logo" />
        <h2>The Operating System for In-Person Engagement</h2>
        <p>
          Momentify captures, scores, and converts interactions at events and
          venues using proprietary ROX (Return on Experience) scoring. From
          trade shows to facility tours, it transforms attendee engagement into
          real-time lead capture, intent scoring, and conversion tracking —
          so you can finally tie experiential investments to measurable outcomes.
        </p>
        <a
          href="https://momentify-website.vercel.app/"
          target="_blank"
          class="btn-teal-solid">Explore Momentify ↗</a
        >
      </div>

      <div class="momentify-stats fade-up">
        <div class="m-stat">
          <div class="m-stat-val">ROX™</div>
          <div class="m-stat-label">Return on Experience scoring across every interaction</div>
        </div>
        <div class="m-stat">
          <div class="m-stat-val">92%</div>
          <div class="m-stat-label">
            Lead increase reported year-over-year by customers
          </div>
        </div>
        <div class="m-stat">
          <div class="m-stat-val">Real-Time</div>
          <div class="m-stat-label">
            Analytics, dashboards, and automated follow-up workflows
          </div>
        </div>
        <div class="m-stat">
          <div class="m-stat-val">Multi-Platform</div>
          <div class="m-stat-label">
            Available on web, iOS, and Android — with offline capture
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ WHY ENTEVATE ═══════════════════════════ -->
  <section class="why-section" id="why">
    <div class="container">
      <div class="why-header fade-up">
        <div class="section-label">Why ENTEVATE</div>
        <h2 class="section-title">Built for the Brave.</h2>
      </div>

      <div class="proof-grid">
        <div class="proof-point fade-up">
          <div class="proof-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none">
              <path
                d="M12 2L3 7v8l9 5 9-5V7L12 2z"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <div class="proof-stat">Fortune 500 Proven</div>
          <div class="proof-desc">
            Deep experience delivering enterprise-grade brand activations for
            Mustang CAT, Boeing, Oracle, and more.
          </div>
        </div>

        <div class="proof-point fade-up">
          <div class="proof-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none">
              <path
                d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"
                stroke="currentColor"
                stroke-width="1.6"></path>
              <circle
                cx="12"
                cy="12"
                r="3"
                stroke="currentColor"
                stroke-width="1.6"></circle>
            </svg>
          </div>
          <div class="proof-stat">Immersive by Design</div>
          <div class="proof-desc">
            We don't just execute events — we engineer experiences that shift
            perception, deepen loyalty, and drive action.
          </div>
        </div>

        <div class="proof-point fade-up">
          <div class="proof-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none">
              <path
                d="M18 20V10M12 20V4M6 20v-6"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <div class="proof-stat">Measurable Impact</div>
          <div class="proof-desc">
            Momentify gives you real data on every touchpoint — so your brand
            investment becomes a strategic decision, not a gut feel.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ CASE STUDIES ═══════════════════════════ -->
  <section class="cases-section" id="case-studies">
    <div class="container">
      <div class="fade-up">
        <div class="section-label">In the Field</div>
        <h2 class="section-title">Experience at work.</h2>
        <p class="section-subtitle">
          Real engagements where immersive brand strategy moved audiences and
          delivered measurable outcomes.
        </p>
      </div>

      <div class="cases-grid">
        <div class="case-card cc-teal fade-up">
          <div class="case-img">
            <img src="/images/bt1.png" alt="Brand Activation Case Study" />
          </div>
          <div class="case-tag">Enterprise · Brand Activation</div>
          <h3>Fortune 500<br />Trade Show Transformation</h3>
          <p>
            A leading industrial enterprise partnered with ENTEVATE to reimagine
            their annual trade show presence. We designed an immersive,
            multi-zone exhibit integrating AR product demos, live storytelling
            stations, and real-time audience engagement tracking via Momentify —
            transforming a static booth into a destination experience.
          </p>
          <div class="case-outcomes">
            <div class="case-outcome">AR Product Demos Deployed</div>
            <div class="case-outcome">Momentify Engagement Tracking</div>
            <div class="case-outcome">3× Dwell Time Increase</div>
            <div class="case-outcome">Multi-Zone Exhibit Design</div>
          </div>
          <a href="/experiential/fortune-500-trade-show" class="case-cta"
            >Learn More →</a
          >
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ CTA BAND ═══════════════════════════ -->
  <section class="cta-band" id="contact">
    <div class="container">
      <div class="fade-up">
        <h2>Ready to Create Something Unforgettable?</h2>
        <p>
          Let's design a brand experience that connects, converts, and lasts.
          Tell us about your next activation.
        </p>
        <div class="cta-band-actions">
          <a href="/contact?service=experiential" class="btn-white-solid"
            >Schedule a Discovery Call</a
          >
          <a
            href="https://www.momentifyapp.com/"
            target="_blank"
            class="btn-white-ghost">Explore Momentify ↗</a
          >
        </div>
      </div>
    </div>
  </section>

  <Footer client:load buttonStyle={{ background: "var(--teal)" }} />

  <script src="../../global.js"></script>
  <script>
    document;
    window.onload = () => {
      staggerFadeIn(
        ".offerings-grid .fade-up, .proof-grid .fade-up, .momentify-stats .m-stat",
      );
    };
  </script>

  <style>
    /* ── Nav color tweaks for Experiential page ── */
    nav .nav-center a:hover {
      color: var(--teal);
    }

    nav .dropdown a:hover {
      background: var(--light-blue);
      color: var(--teal);
    }

    nav .dropdown a.active {
      background: var(--light-blue);
      color: var(--teal);
      font-weight: 600;
    }

    /* ── Hero (Experiential) ── */
    .hero {
      background:
        linear-gradient(
          135deg,
          rgba(5, 35, 28, 0.55) 0%,
          rgba(12, 62, 48, 0.45) 50%,
          rgba(22, 82, 65, 0.38) 100%
        ),
        url("/images/bt1.png") center/cover no-repeat;
      position: relative;
      overflow: hidden;
      padding: 96px 48px 120px;
      min-height: 82vh;
      display: flex;
      align-items: center;
    }

    .hero-inner {
      position: relative;
      z-index: 2;
      max-width: 1160px;
      margin: 0 auto;
      width: 100%;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: rgba(43, 191, 168, 0.14);
      border: 1px solid rgba(43, 191, 168, 0.38);
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 28px;
      color: rgba(255, 255, 255, 0.9);
    }

    .hero-eyebrow-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: linear-gradient(135deg, #adfff2, #ddfff8);
      flex-shrink: 0;
    }

    .hero h1 {
      font-size: clamp(40px, 7vw, 82px);
      font-weight: 100;
      line-height: 1.04;
      color: var(--white);
      margin-bottom: 24px;
      letter-spacing: -0.03em;
      text-wrap: balance;
      max-width: 880px;
    }

    .hero h1 .accent {
      background: linear-gradient(90deg, #adfff2 0%, #ddfff8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: 17px;
      color: rgba(255, 255, 255, 0.68);
      line-height: 1.75;
      max-width: 680px;
      margin-bottom: 42px;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .btn-teal {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 30px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: linear-gradient(135deg, #2bbfa8 0%, #6dd4a0 100%);
      color: var(--white);
      transition: all var(--tr);
      display: inline-block;
    }

    .btn-teal:hover {
      opacity: 0.88;
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(43, 191, 168, 0.45);
    }

    .btn-ghost-dark {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 500;
      background: none;
      border: 1.5px solid rgba(255, 255, 255, 0.35);
      padding: 12px 26px;
      border-radius: var(--radius);
      cursor: pointer;
      color: rgba(255, 255, 255, 0.85);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all var(--tr);
    }

    .btn-ghost-dark:hover {
      border-color: rgba(255, 255, 255, 0.8);
      color: var(--white);
      background: rgba(255, 255, 255, 0.08);
    }

    /* ── Offerings ── */
    .offerings-section {
      background: var(--light-blue);
      padding: 80px 48px;
    }

    .offerings-section .section-label,
    .why-section .section-label,
    .cases-section .section-label {
      color: var(--teal);
      background: none;
      -webkit-background-clip: initial;
      -webkit-text-fill-color: inherit;
      background-clip: initial;
    }

    .offerings-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
      margin-top: 52px;
    }

    .offering-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px 28px;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      transition:
        box-shadow var(--tr),
        transform var(--tr);
    }

    .offering-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      border-radius: var(--radius) var(--radius) 0 0;
    }

    .oc-teal::before {
      background: linear-gradient(90deg, #2bbfa8, #6dd4a0);
    }
    .oc-teal-mid::before {
      background: linear-gradient(90deg, #3d978a, #2bbfa8);
    }
    .oc-blue::before {
      background: linear-gradient(90deg, #247b96, #3fafc8);
    }
    .oc-green::before {
      background: linear-gradient(90deg, #3d978a, #6dd4a0);
    }

    .offering-card:hover {
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
      transform: translateY(-3px);
    }

    .offering-icon {
      width: 48px;
      height: 48px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
    }

    .oc-teal .offering-icon {
      background: rgba(43, 191, 168, 0.1);
      color: var(--teal);
    }
    .oc-teal-mid .offering-icon {
      background: rgba(61, 151, 138, 0.1);
      color: var(--green);
    }
    .oc-blue .offering-icon {
      background: rgba(36, 123, 150, 0.1);
      color: var(--blue);
    }
    .oc-green .offering-icon {
      background: rgba(43, 191, 168, 0.1);
      color: var(--teal);
    }

    .offering-card h3 {
      font-size: 17px;
      font-weight: 300;
      color: var(--black);
      margin-bottom: 6px;
      letter-spacing: -0.01em;
      line-height: 1.3;
      max-width: 240px;
    }

    .offering-card em {
      display: block;
      font-style: italic;
      font-size: 13px;
      color: var(--gray-light);
      margin-bottom: 14px;
    }

    .offering-card p {
      font-size: 13.5px;
      color: var(--gray-mid);
      line-height: 1.7;
      flex: 1;
      margin-bottom: 22px;
    }

    .offering-cta {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: auto;
      transition: gap var(--tr);
      color: var(--teal);
    }

    .offering-cta:hover {
      gap: 10px;
    }

    /* ── Momentify Spotlight ── */
    .momentify-section {
      background:
        linear-gradient(
          135deg,
          rgba(5, 35, 28, 0.55) 0%,
          rgba(12, 62, 48, 0.45) 50%,
          rgba(22, 82, 65, 0.38) 100%
        ),
        url("/images/bt1.png") center/cover no-repeat;
      color: var(--white);
      padding: 80px 48px;
    }

    .momentify-inner {
      max-width: 1160px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }

    .momentify-eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--teal-light);
      margin-bottom: 14px;
      display: block;
    }

    .momentify-logo {
      height: 32px;
      width: auto;
      margin-bottom: 18px;
      display: block;
      filter: brightness(0) invert(1);
    }

    .momentify-left h2 {
      font-size: clamp(26px, 3.5vw, 40px);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.15;
      margin-bottom: 18px;
    }

    .momentify-left p {
      font-size: 15px;
      color: rgba(255, 255, 255, 0.6);
      line-height: 1.8;
      margin-bottom: 32px;
      max-width: 460px;
