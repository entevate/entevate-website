      .offerings-section,
      .momentify-section,
      .why-section,
      .cases-section,
      .cta-band {
        padding: 64px 24px;
      }

      .momentify-inner {
        grid-template-columns: 1fr;
        gap: 48px;
      }

      .cases-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
