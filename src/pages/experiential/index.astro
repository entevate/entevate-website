    }

    .proof-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
      max-width: 1160px;
      margin: 0 auto;
    }

    .proof-point {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 40px 28px 36px;
      background: var(--white);
