---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.jsx";
import Footer from "../../components/Footer.jsx";
import "../../global.css";

const title = "Operational Intelligence Assessment — ENTEVATE";
const description =
  "The Operational Intelligence Assessment evaluates your organization across People, Platform, and Process, scoring AI readiness, automation maturity, content systems, and cross-functional alignment. Get your score and a prioritized action plan.";

const jsonLd = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Operational Intelligence Assessment",
    "provider": { "@type": "Organization", "name": "ENTEVATE" },
    "description": description,
    "url": "https://www.entevate.com/operational-intelligence/assessment",
    "serviceType": "Operational Readiness Diagnostic",
    "audience": {
      "@type": "Audience",
      "audienceType": "Enterprise leaders, operations teams, and organizations evaluating AI, automation, and digital transformation readiness"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.entevate.com" },
      { "@type": "ListItem", "position": 2, "name": "Operational Intelligence", "item": "https://www.entevate.com/operational-intelligence" },
      { "@type": "ListItem", "position": 3, "name": "Assessment", "item": "https://www.entevate.com/operational-intelligence/assessment" }
    ]
  }
]);
---

<BaseLayout title={title} description={description} ogImage="/images/og/oi-og.png" jsonLd={jsonLd}>
  <style>
    /* Shared */
    .section {
      padding: 80px 48px;
    }
    .container {
      max-width: 1160px;
      margin: 0 auto;
    }
    .section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 14px;
      display: inline-block;
      color: var(--orange);
    }
    h2.section-title {
      font-size: clamp(30px, 4vw, 48px);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin-bottom: 16px;
    }
    .section-subtitle {
      font-size: 15px;
      color: var(--gray-mid);
      max-width: 580px;
      line-height: 1.75;
    }

    /* Hero */
    .hero {
      background:
        linear-gradient(
          135deg,
          rgba(50, 22, 5, 0.55) 0%,
          rgba(85, 42, 12, 0.45) 50%,
          rgba(115, 65, 25, 0.38) 100%
        ),
        url("/images/bt2.png") center/cover no-repeat;
      position: relative;
      overflow: hidden;
      padding: 96px 48px 120px;
      min-height: 72vh;
      display: flex;
      align-items: center;
    }
    .hero-inner {
      position: relative;
      z-index: 2;
      max-width: 1160px;
      margin: 0 auto;
      width: 100%;
    }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: rgba(232, 120, 42, 0.14);
      border: 1px solid rgba(232, 120, 42, 0.38);
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 28px;
      color: rgba(255, 255, 255, 0.9);
    }
    .hero-eyebrow-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ffe5c0, #fff5e0);
      flex-shrink: 0;
    }
    .hero h1 {
      font-size: clamp(38px, 6.5vw, 78px);
      font-weight: 100;
      line-height: 1.04;
      color: var(--white);
      margin-bottom: 24px;
      letter-spacing: -0.03em;
      text-wrap: balance;
      max-width: 860px;
    }
    .hero h1 .accent {
      background: linear-gradient(90deg, #ffe5c0 0%, #fff5e0 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      font-size: 17px;
      color: rgba(255, 255, 255, 0.68);
      line-height: 1.75;
      max-width: 640px;
      margin-bottom: 42px;
    }
    .hero-actions {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    .btn-orange {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 30px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: linear-gradient(135deg, #e8782a 0%, #f5b731 100%);
      color: var(--white);
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-orange:hover {
      opacity: 0.88;
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(232, 120, 42, 0.45);
    }
    .btn-ghost-dark {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 500;
      background: none;
      border: 1.5px solid rgba(255, 255, 255, 0.35);
      padding: 12px 26px;
      border-radius: var(--radius);
      cursor: pointer;
      color: rgba(255, 255, 255, 0.85);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all var(--tr);
    }
    .btn-ghost-dark:hover {
      border-color: rgba(255, 255, 255, 0.8);
      color: var(--white);
      background: rgba(255, 255, 255, 0.08);
    }

    /* Overview Split */
    .overview-section {
      background: var(--white);
      padding: 80px 48px;
    }
    .overview-split {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      max-width: 1160px;
      margin: 0 auto;
    }
    .overview-left h2 {
      font-size: clamp(28px, 3.5vw, 42px);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.2;
      margin-bottom: 18px;
    }
    .overview-left p {
      font-size: 15px;
      color: var(--gray-mid);
      line-height: 1.8;
      margin-bottom: 20px;
    }
    .overview-quote {
      background: var(--light-blue);
      border-left: 3px solid var(--orange);
      border-radius: 0 var(--radius) var(--radius) 0;
      padding: 24px 28px;
      font-size: 15px;
      font-style: italic;
      line-height: 1.75;
      color: var(--black);
      margin-bottom: 28px;
    }
    .platform-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .platform-chip {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.04em;
      padding: 6px 14px;
      border-radius: 100px;
      background: rgba(232, 120, 42, 0.08);
      border: 1px solid rgba(232, 120, 42, 0.22);
      color: var(--orange);
    }
    .overview-right {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .overview-stat {
      background: var(--light-blue);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px 26px;
    }
    .overview-stat-num {
      font-size: 40px;
      font-weight: 100;
      letter-spacing: -0.03em;
      color: var(--black);
      line-height: 1;
    }
    .overview-stat-label {
      font-size: 13px;
      color: var(--gray-mid);
      margin-top: 6px;
      line-height: 1.5;
    }
    .overview-stat-accent {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 8px;
    }

    /* Pillars */
    .pillars-section {
      background: var(--light-blue);
      padding: 80px 48px;
    }
    .pillars-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 52px;
    }
    .pillar-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 36px 30px;
      position: relative;
      overflow: hidden;
      transition:
        box-shadow var(--tr),
        transform var(--tr);
    }
    .pillar-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .pc-people::before {
      background: linear-gradient(90deg, #e8782a, #f5b731);
    }
    .pc-platform::before {
      background: linear-gradient(90deg, #ea9709, #f5c842);
    }
    .pc-process::before {
      background: linear-gradient(90deg, #cb632f, #e8782a);
    }
    .pillar-card:hover {
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
      transform: translateY(-3px);
    }
    .pillar-card-icon {
      width: 52px;
      height: 52px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 22px;
    }
    .pc-people .pillar-card-icon {
      background: rgba(232, 120, 42, 0.1);
      color: var(--orange);
    }
    .pc-platform .pillar-card-icon {
      background: rgba(234, 151, 9, 0.1);
      color: var(--orange-light);
    }
    .pc-process .pillar-card-icon {
      background: rgba(203, 99, 47, 0.1);
      color: var(--orange-dark);
    }
    .pillar-card h3 {
      font-size: 20px;
      font-weight: 300;
      letter-spacing: -0.01em;
      margin-bottom: 10px;
    }
    .pillar-card p {
      font-size: 14px;
      color: var(--gray-mid);
      line-height: 1.72;
    }
    .pillar-card ul {
      margin-top: 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 0;
      list-style: none;
    }
    .pillar-card ul li {
      font-size: 13px;
      color: var(--gray-mid);
      display: flex;
      align-items: flex-start;
      gap: 8px;
      line-height: 1.4;
    }
    .pillar-card ul li::before {
      content: "—";
      color: var(--orange);
      flex-shrink: 0;
      font-weight: 700;
    }

    /* Assessment */
    .assessment-section {
      background: var(--white);
      padding: 80px 48px;
    }
    .assessment-intro {
      max-width: 680px;
      margin-bottom: 56px;
    }
    .assessment-intro h2 {
      font-size: clamp(28px, 3.5vw, 42px);
      font-weight: 300;
      letter-spacing: -0.02em;
      margin-bottom: 14px;
    }
    .assessment-intro p {
      font-size: 15px;
      color: var(--gray-mid);
      line-height: 1.75;
    }
    .pillar-group {
      margin-bottom: 52px;
    }
    .pillar-group-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 26px;
      padding-bottom: 16px;
      border-bottom: 2px solid var(--border);
    }
    .pg-icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .pg-people {
      background: rgba(232, 120, 42, 0.1);
      color: var(--orange);
    }
    .pg-platform {
      background: rgba(234, 151, 9, 0.1);
      color: var(--orange-light);
    }
    .pg-process {
      background: rgba(203, 99, 47, 0.1);
      color: var(--orange-dark);
    }
    .pg-title {
      font-size: 19px;
      font-weight: 400;
      letter-spacing: -0.01em;
    }
    .pg-subtitle {
      font-size: 13px;
      color: var(--gray-mid);
    }
    .question-row {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: 20px;
      padding: 14px 0;
      border-bottom: 1px solid rgba(221, 230, 240, 0.7);
    }
    .question-row:last-child {
      border-bottom: none;
    }
    .q-num {
      font-size: 11px;
      font-weight: 700;
      color: var(--gray-light);
      margin-bottom: 3px;
    }
    .q-text {
      font-size: 14px;
      color: var(--black);
      line-height: 1.5;
    }
    .rating-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      flex-shrink: 0;
    }
    .rating-scale-labels {
      display: flex;
      justify-content: space-between;
      width: 100%;
      padding: 0 2px;
    }
    .rating-scale-label {
      font-size: 9px;
      color: var(--gray-light);
      letter-spacing: 0.03em;
      white-space: nowrap;
    }
    .rating-options {
      display: flex;
      gap: 6px;
    }
    .r-opt {
      display: flex;
      flex-direction: column;
      align-items: center;
      cursor: pointer;
    }
    .r-opt input {
      display: none;
    }
    .r-circle {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1.5px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 500;
      color: var(--gray-light);
      transition: all var(--tr);
      cursor: pointer;
      user-select: none;
    }
    .r-opt input:checked ~ .r-circle {
      background: var(--orange);
      border-color: var(--orange);
      color: var(--white);
    }
    .r-opt:hover .r-circle {
      border-color: var(--orange);
      color: var(--orange);
    }
    .assessment-actions {
      margin-top: 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
      padding-top: 32px;
      border-top: 1px solid var(--border);
    }
    .progress-count {
      font-size: 13px;
      color: var(--gray-light);
    }
    .btn-score {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 32px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: linear-gradient(135deg, #e8782a, #f5b731);
      color: var(--white);
      transition: all var(--tr);
      opacity: 0.5;
      pointer-events: none;
    }
    .btn-score.ready {
      opacity: 1;
      pointer-events: auto;
    }
    .btn-score.ready:hover {
      opacity: 0.88;
      transform: translateY(-2px);
    }

    /* Score Display */
    .score-display {
      display: none;
      margin-top: 48px;
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid var(--border);
    }
    .score-display.visible {
      display: block;
    }
    .score-header {
      background: linear-gradient(135deg, #3d1e08, #e8782a);
      color: var(--white);
      padding: 40px 48px;
      text-align: center;
    }
    .score-big {
      font-size: 80px;
      font-weight: 100;
      letter-spacing: -0.04em;
      line-height: 1;
    }
    .score-pct {
      font-size: 32px;
      font-weight: 300;
    }
    .score-stage-badge {
      display: inline-block;
      margin-top: 14px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 7px 22px;
      border-radius: 100px;
      border: 1.5px solid rgba(255, 255, 255, 0.5);
      color: var(--white);
    }
    .score-body {
      background: var(--light-blue);
      padding: 40px 48px;
    }
    .score-body h3 {
      font-size: 18px;
      font-weight: 400;
      margin-bottom: 24px;
      text-align: center;
      color: var(--black);
    }
    .pillar-scores {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-bottom: 32px;
    }
    .pillar-score-item {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 22px 20px;
    }
    .ps-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gray-mid);
      margin-bottom: 10px;
    }
    .ps-bar-track {
      height: 8px;
      background: var(--border);
      border-radius: 100px;
      overflow: hidden;
      margin-bottom: 8px;
    }
    .ps-bar-fill {
      height: 100%;
      border-radius: 100px;
      background: linear-gradient(90deg, #e8782a, #f5b731);
      transition: width 1.2s ease;
    }
    .ps-pct {
      font-size: 20px;
      font-weight: 300;
      color: var(--black);
    }
    .score-interpretation {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px 28px;
      margin-bottom: 32px;
    }
    .si-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 8px;
    }
    .si-text {
      font-size: 14px;
      color: var(--gray-mid);
      line-height: 1.72;
    }

    /* Lead Form */
    .lead-form-wrap {
      display: none;
      padding: 40px 48px;
      background: var(--white);
      border-top: 1px solid var(--border);
    }
    .lead-form-wrap.visible {
      display: block;
    }
    .lead-form-wrap h3 {
      font-size: 20px;
      font-weight: 300;
      letter-spacing: -0.01em;
      margin-bottom: 8px;
    }
    .lead-form-wrap p {
      font-size: 14px;
      color: var(--gray-mid);
      margin-bottom: 28px;
      line-height: 1.65;
    }
    .lead-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 20px;
    }
    .form-field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .form-field label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--gray-mid);
    }
    .form-field input,
    .form-field select {
      font-family: var(--font);
      font-size: 14px;
      padding: 12px 14px;
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      color: var(--black);
      outline: none;
      transition: border-color var(--tr);
      background: var(--white);
    }
    .form-field input:focus,
    .form-field select:focus {
      border-color: var(--orange);
    }
    .form-field.full {
      grid-column: 1/-1;
    }
    .btn-submit {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 14px 36px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: linear-gradient(135deg, #e8782a, #f5b731);
      color: var(--white);
      transition: all var(--tr);
    }
    .btn-submit:hover {
      opacity: 0.88;
      transform: translateY(-2px);
    }
    .form-note {
      font-size: 12px;
      color: var(--gray-light);
      margin-top: 12px;
      line-height: 1.5;
    }

    /* CTA Band */
    .cta-band {
      background: linear-gradient(135deg, #3d1e08 0%, #e8782a 100%);
      color: var(--white);
      padding: 80px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-band::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          circle at 25% 40%,
          rgba(255, 255, 255, 0.07) 0%,
          transparent 50%
        ),
        radial-gradient(
          circle at 80% 70%,
          rgba(255, 255, 255, 0.05) 0%,
          transparent 45%
        );
      pointer-events: none;
    }
    .cta-band .container {
      position: relative;
      z-index: 1;
    }
    .cta-band h2 {
      font-size: clamp(28px, 4.5vw, 52px);
      font-weight: 300;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }
    .cta-band p {
      font-size: 16px;
      color: rgba(255, 255, 255, 0.68);
      max-width: 520px;
      margin: 0 auto 38px;
      line-height: 1.72;
    }
    .cta-band-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .btn-white-solid {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 30px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: var(--white);
      color: var(--orange);
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-white-solid:hover {
      background: var(--light-blue);
      transform: translateY(-1px);
    }
    .btn-white-ghost {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 500;
      padding: 12px 30px;
      border-radius: var(--radius);
      border: 1.5px solid rgba(255, 255, 255, 0.45);
      cursor: pointer;
      color: var(--white);
      background: transparent;
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-white-ghost:hover {
      border-color: rgba(255, 255, 255, 0.9);
      background: rgba(255, 255, 255, 0.1);
    }
  </style>
  <Header client:load />

  <!-- Hero -->
  <section class="hero" id="top">
    <div class="hero-inner">
      <div class="fade-up">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>
          Operational Intelligence
        </div>
        <h1>
          Operational Intelligence Assessment.<br /><span class="accent"
            >The diagnostic before the strategy.</span
          >
        </h1>
        <p class="hero-sub">
          Before you invest in AI, automation, or transformation, you need
          to know where you actually stand. The Operational Intelligence
          Assessment scores your organization across People, Platform, and
          Process so you can see the gaps, prioritize the fixes, and build
          from a real foundation.
        </p>
        <div class="hero-actions">
          <a href="#assessment" class="btn-orange">Take the Assessment →</a>
          <a href="/operational-intelligence" class="btn-ghost-dark"
            >← Back to Operational Intelligence</a
          >
        </div>
      </div>
    </div>
  </section>

