  <!-- CTA Band -->
  <section class="cta-band" id="contact">
    <div class="container">
      <div class="fade-up">
        <h2>Ready to close your Operational Intelligence gap?</h2>
        <p>
          Let ENTEVATE assess your people, platforms, and processes and
          build a plan to get you ready for AI, automation, and what comes
          next.
        </p>
        <div class="cta-band-actions">
          <a href="/contact?service=operational-intelligence" class="btn-white-solid"
            >Start a Conversation</a
          >
          <a href="/operational-intelligence" class="btn-white-ghost"
            >← All Operational Intelligence Services</a
          >
        </div>
      </div>
    </div>
  </section>

  <Footer client:load buttonStyle={{ background: "var(--orange)" }} />

  <script src="../../global.js"></script>
  <script>
    // Assessment logic
    const questions = [
      "p1",
      "p2",
      "p3",
      "p4",
      "p5",
      "pl1",
      "pl2",
      "pl3",
      "pl4",
      "pl5",
      "pr1",
      "pr2",
      "pr3",
      "pr4",
      "pr5",
    ];
    const peopleQs = ["p1", "p2", "p3", "p4", "p5"];
    const platformQs = ["pl1", "pl2", "pl3", "pl4", "pl5"];
    const processQs = ["pr1", "pr2", "pr3", "pr4", "pr5"];
    const progressEl = document.getElementById("progressCount");
    const btnScore = document.getElementById("btnScore");

    function getAnswered() {
      return questions.filter((q) =>
        document.querySelector('input[name="' + q + '"]:checked'),
      );
    }
    function pillarScore(qs) {
      return qs.reduce((sum, q) => {
        const el = document.querySelector('input[name="' + q + '"]:checked');
        return sum + (el ? parseInt(el.value) : 0);
      }, 0);
    }

    document.querySelectorAll(".rating-options input").forEach((input) => {
      input.addEventListener("change", () => {
        const answered = getAnswered().length;
        progressEl.textContent = answered + " of 15 answered";
        if (answered === 15) {
          btnScore.classList.add("ready");
        }
      });
    });

    btnScore.addEventListener("click", () => {
      const pScore = pillarScore(peopleQs);
      const plScore = pillarScore(platformQs);
      const prScore = pillarScore(processQs);
      const total = pScore + plScore + prScore;
      const pct = Math.round((total / 75) * 100);
      const pPct = Math.round((pScore / 25) * 100);
      const plPct = Math.round((plScore / 25) * 100);
      const prPct = Math.round((prScore / 25) * 100);

      let stage, stageLabel, stageText;
      if (pct <= 39) {
        stage = "Stage 1: Not Operationally Ready";
        stageLabel = "Significant Readiness Gaps Identified";
        stageText =
          "Your operational foundation has fundamental gaps across People, Platform, and/or Process. Immediate action is needed to establish a baseline before layering on AI, automation, or transformation initiatives.";
      } else if (pct <= 59) {
        stage = "Stage 2: Emerging";
        stageLabel = "Foundation Being Established";
        stageText =
          "You have the early shape of an intelligent operation, but significant work remains. Close your lowest-scoring pillar first to build a stable base for scaled transformation.";
      } else if (pct <= 79) {
        stage = "Stage 3: Developing";
        stageLabel = "On the Path to Operational Intelligence";
        stageText =
          "You're making real progress. Your organization has meaningful operational capabilities and clear opportunities to optimize. Targeted improvements to your weakest pillar will unlock significant gains in AI, automation, and content leverage.";
      } else {
        stage = "Stage 4: OI Leader";
        stageLabel = "Strong Operational Foundation";
        stageText =
          "Your organization demonstrates strong operational intelligence. You're well-positioned to leverage advanced AI, automation, and emerging capabilities. Focus on sustaining and evolving your capabilities as the landscape keeps shifting.";
      }

      document.getElementById("scoreNumber").textContent = pct + "%";
      document.getElementById("stageBadge").textContent = stage;
      document.getElementById("stageLabel").textContent = stageLabel;
      document.getElementById("stageText").textContent = stageText;
      document.getElementById("pctPeople").textContent = pPct + "%";
      document.getElementById("pctPlatform").textContent = plPct + "%";
      document.getElementById("pctProcess").textContent = prPct + "%";

      // Hidden form fields
      document.getElementById("hiddenScore").value = pct + "%";
      document.getElementById("hiddenStage").value = stage;
      document.getElementById("hiddenPeople").value = pPct + "%";
      document.getElementById("hiddenPlatform").value = plPct + "%";
      document.getElementById("hiddenProcess").value = prPct + "%";

      const scoreEl = document.getElementById("scoreDisplay");
      scoreEl.classList.add("visible");
      setTimeout(() => {
        document.getElementById("barPeople").style.width = pPct + "%";
        document.getElementById("barPlatform").style.width = plPct + "%";
        document.getElementById("barProcess").style.width = prPct + "%";
      }, 100);
      document.getElementById("leadFormWrap").classList.add("visible");
      scoreEl.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    // ─── Operational Intelligence Assessment Lead Form → HubSpot submission ───
    var leadFormLoadTime = Date.now();
    var minSubmitMs = 3 * 1000;
    document
      .getElementById("leadForm")
      .addEventListener("submit", function (e) {
        e.preventDefault();
        var form = document.getElementById("leadForm");
        var btn = form.querySelector(".btn-submit");
        var botCheck = form.querySelector('input[name="website_url"]');
        if (botCheck && botCheck.value) {
          form.innerHTML =
            '<div style="text-align:center;padding:32px 0;"><h3 style="font-size:22px;font-weight:400;margin-bottom:10px;">Action Plan Requested!</h3><p style="font-size:14px;color:#6B6B6B;">Thanks! We\'ll send your personalized Operational Intelligence report shortly.</p></div>';
          return;
        }
        if (Date.now() - leadFormLoadTime < minSubmitMs) {
          form.innerHTML =
            '<div style="text-align:center;padding:32px 0;"><h3 style="font-size:22px;font-weight:400;margin-bottom:10px;">Action Plan Requested!</h3><p style="font-size:14px;color:#6B6B6B;">Thanks! We\'ll send your personalized Operational Intelligence report shortly.</p></div>';
          return;
        }
        var required = form.querySelectorAll("[required]");
        var valid = true;
        required.forEach(function (field) {
          if (!field.value.trim()) {
            field.style.borderColor = "#CB632F";
            valid = false;
          } else {
            field.style.borderColor = "";
          }
        });
        if (!valid) return;
        btn.disabled = true;
        btn.textContent = "Sending…";
        var payload = {
          fields: [
            { name: "firstname", value: form.first_name.value },
            { name: "lastname", value: form.last_name.value },
            { name: "company", value: form.company.value },
            { name: "jobtitle", value: form.role.value },
            { name: "email", value: form.email.value },
            { name: "phone", value: form.phone.value },
            { name: "industry", value: form.industry.value },
            {
              name: "oi_assessment_score",
              value: form.querySelector("#hiddenScore").value,
            },
            {
              name: "oi_assessment_stage",
              value: form.querySelector("#hiddenStage").value,
            },
            {
              name: "people_score",
              value: form.querySelector("#hiddenPeople").value,
            },
            {
              name: "platform_score",
              value: form.querySelector("#hiddenPlatform").value,
            },
            {
              name: "process_score",
              value: form.querySelector("#hiddenProcess").value,
            },
          ],
          context: {
            pageUri: window.location.href,
            pageName: document.title,
          },
        };
        fetch(
          "https://api.hsforms.com/submissions/v3/integration/submit/44191993/ef7b3576-d3f9-4afe-9d2c-80c10fadfd86",
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          },
        )
          .then(function (r) {
            if (r.ok) {
              form.innerHTML =
                '<div style="text-align:center;padding:32px 0;"><h3 style="font-size:22px;font-weight:400;margin-bottom:10px;">Action Plan Requested!</h3><p style="font-size:14px;color:#6B6B6B;">Thanks! We\'ll send your personalized Operational Intelligence report shortly.</p></div>';
            } else {
              btn.disabled = false;
              btn.textContent = "Send Me My Action Plan →";
              alert(
                "Something went wrong. Please try again or email us at hello@entevate.com.",
              );
            }
          })
          .catch(function () {
            btn.disabled = false;
            btn.textContent = "Send Me My Action Plan →";
            alert(
              "Something went wrong. Please try again or email us at hello@entevate.com.",
            );
          });
      });
  </script>
</BaseLayout>
