---
import Footer from "../../components/Footer.jsx";
import Header from "../../components/Header.jsx";
import "../../global.css";
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "AI Foundry™ — Custom AI Systems | ENTEVATE";
const description =
  "We design, build, and operate AI pipelines that power content workflows, brand systems, and full-stack applications — turning concepts into production-grade intelligent systems.";

const jsonLd = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "AI Foundry™",
    "provider": { "@type": "Organization", "name": "ENTEVATE" },
    "description": description,
    "url": "https://www.entevate.com/operational-intelligence/ai-foundry",
    "serviceType": "AI Systems Development & Operations"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.entevate.com" },
      { "@type": "ListItem", "position": 2, "name": "Operational Intelligence", "item": "https://www.entevate.com/operational-intelligence" },
      { "@type": "ListItem", "position": 3, "name": "AI Foundry", "item": "https://www.entevate.com/operational-intelligence/ai-foundry" }
    ]
  }
]);
---

<BaseLayout title={title} description={description} ogImage="/images/og/oi-og.png" jsonLd={jsonLd}>
  <style>
    .section {
      padding: 80px 48px;
    }
    .container {
      max-width: 1160px;
      margin: 0 auto;
    }
    .section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 14px;
      display: inline-block;
      color: var(--orange);
    }
    h2.section-title {
      font-size: clamp(30px, 4vw, 48px);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin-bottom: 16px;
    }
    .section-subtitle {
      font-size: 15px;
      color: var(--gray-mid);
      max-width: 580px;
      line-height: 1.75;
    }

    /* Hero */
    .hero {
      background:
        linear-gradient(
          135deg,
          rgba(50, 22, 5, 0.72) 0%,
          rgba(85, 42, 12, 0.55) 50%,
          rgba(232, 120, 42, 0.38) 100%
        ),
        url("/images/bt2.png") center/cover no-repeat;
      position: relative;
      overflow: hidden;
      padding: 96px 48px 120px;
      min-height: 72vh;
      display: flex;
      align-items: center;
    }
    .hero-inner {
      position: relative;
      z-index: 2;
      max-width: 1160px;
      margin: 0 auto;
      width: 100%;
    }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: rgba(232, 120, 42, 0.14);
      border: 1px solid rgba(232, 120, 42, 0.38);
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 28px;
      color: rgba(255, 255, 255, 0.9);
    }
    .hero-eyebrow-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: linear-gradient(135deg, #f5b731, #fff5e0);
      flex-shrink: 0;
    }
    .hero h1 {
      font-size: clamp(36px, 6vw, 74px);
      font-weight: 100;
      line-height: 1.04;
      color: var(--white);
      margin-bottom: 24px;
      letter-spacing: -0.03em;
      text-wrap: balance;
      max-width: 860px;
    }
    .hero h1 .accent {
      background: linear-gradient(90deg, #f5b731 0%, #fff5e0 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      font-size: 17px;
      color: rgba(255, 255, 255, 0.68);
      line-height: 1.75;
      max-width: 640px;
      margin-bottom: 42px;
    }
    .hero-actions {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    .btn-primary {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 30px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: linear-gradient(135deg, var(--orange) 0%, #f5b731 100%);
      color: var(--white);
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-primary:hover {
      opacity: 0.88;
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(115, 65, 25, 0.45);
    }
    .btn-ghost-dark {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 500;
      background: none;
      border: 1.5px solid rgba(255, 255, 255, 0.35);
      padding: 12px 26px;
      border-radius: var(--radius);
      cursor: pointer;
      color: rgba(255, 255, 255, 0.85);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all var(--tr);
    }
    .btn-ghost-dark:hover {
      border-color: rgba(255, 255, 255, 0.8);
      color: var(--white);
      background: rgba(255, 255, 255, 0.08);
    }

    /* Transformation Model */
    .maturity-section {
      background: var(--white);
      padding: 80px 48px 48px;
    }
    .maturity-viz {
      display: grid;
      grid-template-columns: 1fr 1fr auto 1fr 1fr;
      gap: 20px;
      align-items: end;
      margin-top: 52px;
      margin-bottom: 16px;
      min-height: 320px;
      position: relative;
      padding-bottom: 48px;
    }
    .maturity-gap {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      align-self: stretch;
      gap: 10px;
      padding: 0 4px;
    }
    .maturity-gap-line {
      flex: 1;
      width: 0;
      border-left: 2px dashed rgba(232, 120, 42, 0.35);
    }
    .maturity-gap-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--orange);
      writing-mode: vertical-lr;
      text-orientation: mixed;
      white-space: nowrap;
    }
    .maturity-col {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }
    .maturity-bar {
      width: 100%;
      border-radius: 4px 4px 0 0;
      display: flex;
      flex-direction: row;
      align-items: flex-end;
      justify-content: center;
      padding-bottom: 14px;
      gap: 8px;
    }
    .maturity-bar-icon {
      opacity: 0.5;
    }
    .ml-3 .maturity-bar-icon,
    .ml-4 .maturity-bar-icon {
      opacity: 0.85;
      color: #fff;
    }
    .ml-1 .maturity-bar-icon,
    .ml-2 .maturity-bar-icon {
      color: rgba(232, 120, 42, 0.45);
    }
    .maturity-bar-label {
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-align: center;
      line-height: 1.3;
    }
    .ml-1 .maturity-bar {
      height: 60px;
      background: rgba(232, 120, 42, 0.12);
      border: 1px dashed rgba(232, 120, 42, 0.25);
      border-bottom: none;
    }
    .ml-1 .maturity-bar-label { color: rgba(232, 120, 42, 0.5); }
    .ml-2 .maturity-bar {
      height: 110px;
      background: rgba(232, 120, 42, 0.18);
      border: 1px dashed rgba(232, 120, 42, 0.3);
      border-bottom: none;
    }
    .ml-2 .maturity-bar-label { color: rgba(232, 120, 42, 0.6); }
    .ml-3 .maturity-bar {
      height: 200px;
      background: linear-gradient(180deg, #f5b731 0%, var(--orange) 100%);
    }
    .ml-3 .maturity-bar-label { color: rgba(255, 255, 255, 0.85); }
    .ml-4 .maturity-bar {
      height: 300px;
      background: linear-gradient(180deg, var(--orange) 0%, #cb632f 100%);
    }
    .ml-4 .maturity-bar-label { color: rgba(255, 255, 255, 0.9); }
    .maturity-col-label {
      font-size: 13px;
      font-weight: 500;
      color: var(--black);
      text-align: center;
    }
    .maturity-col-desc {
      font-size: 12px;
      color: var(--gray-mid);
      text-align: center;
      line-height: 1.5;
      max-width: 200px;
    }
    .maturity-brackets {
      display: grid;
      grid-template-columns: 2fr auto 2fr;
      gap: 0;
      margin-bottom: 48px;
    }
    .maturity-brackets .bracket-spacer {
      width: 40px;
    }
    .maturity-bracket {
      text-align: center;
      padding-top: 14px;
      border-top: 2px solid;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .bracket-stuck {
      border-color: var(--gray-light);
      color: var(--gray-mid);
    }
    .bracket-value {
      border-color: var(--orange);
      color: var(--orange);
    }
    .maturity-bridge {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .bridge-item {
      background: var(--light-blue);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 20px;
      text-align: center;
      font-size: 14px;
      font-weight: 500;
      color: var(--black);
    }
    .bridge-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--orange);
      display: block;
      margin-bottom: 4px;
    }
    .bridge-levels {
      font-size: 13px;
      color: var(--gray-mid);
      font-weight: 400;
    }
    .level-tag {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 100px;
      background: rgba(232, 120, 42, 0.1);
      border: 1px solid rgba(232, 120, 42, 0.2);
      color: var(--orange);
      margin-top: 12px;
    }

    /* Framework */
    .framework-section {
      background: var(--white);
      padding: 48px 48px 80px;
    }
    .framework-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      margin-top: 52px;
    }
    .fw-card {
      background: var(--light-blue);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px 26px;
      position: relative;
      overflow: hidden;
      transition:
        box-shadow var(--tr),
        transform var(--tr);
    }
    .fw-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .fw-1::before {
      background: linear-gradient(90deg, var(--orange), #f5b731);
    }
    .fw-2::before {
      background: linear-gradient(90deg, #ea9709, #f5c842);
    }
    .fw-3::before {
      background: linear-gradient(90deg, #cb632f, var(--orange));
    }
    .fw-card:hover {
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
      transform: translateY(-3px);
    }
    .fw-icon {
      width: 48px;
      height: 48px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 18px;
    }
    .fw-1 .fw-icon {
      background: rgba(232, 120, 42, 0.1);
      color: var(--orange);
    }
    .fw-2 .fw-icon {
      background: rgba(234, 151, 9, 0.1);
      color: #ea9709;
    }
    .fw-3 .fw-icon {
      background: rgba(203, 99, 47, 0.1);
      color: #cb632f;
    }
    .fw-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gray-light);
      margin-bottom: 10px;
    }
    .fw-card h3 {
      font-size: 17px;
      font-weight: 400;
      letter-spacing: -0.01em;
      margin-bottom: 10px;
      line-height: 1.3;
    }
    .fw-card p {
      font-size: 13.5px;
      color: var(--gray-mid);
      line-height: 1.7;
    }

    /* What We Build */
    .build-section {
      background: var(--light-blue);
      padding: 80px 48px;
    }
    .build-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      margin-top: 52px;
    }
    .build-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px 26px;
      position: relative;
      overflow: hidden;
      transition:
        box-shadow var(--tr),
        transform var(--tr);
    }
    .build-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      border-radius: var(--radius) var(--radius) 0 0;
      background: linear-gradient(90deg, var(--orange), #f5b731);
    }
    .build-card:hover {
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
      transform: translateY(-3px);
    }
    .build-icon {
      width: 48px;
      height: 48px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 18px;
      background: rgba(232, 120, 42, 0.1);
      color: var(--orange);
    }
    .build-card h3 {
      font-size: 17px;
      font-weight: 400;
      letter-spacing: -0.01em;
      margin-bottom: 10px;
      line-height: 1.3;
    }
    .build-card p {
      font-size: 13.5px;
      color: var(--gray-mid);
      line-height: 1.7;
    }

    /* Stats */
    .stats-section {
      background: var(--white);
      padding: 80px 48px;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
      margin-top: 52px;
    }
    .stat-card {
      background: var(--light-blue);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 36px 28px;
      text-align: center;
      transition:
        box-shadow var(--tr),
        transform var(--tr);
    }
    .stat-card:hover {
      box-shadow: 0 8px 28px rgba(0, 0, 0, 0.07);
      transform: translateY(-3px);
    }
    .stat-number {
      font-size: clamp(36px, 5vw, 56px);
      font-weight: 200;
      letter-spacing: -0.03em;
      color: var(--orange);
      margin-bottom: 8px;
      line-height: 1;
    }
    .stat-desc {
      font-size: 14px;
      color: var(--gray-mid);
      line-height: 1.65;
    }

    /* Who It's For */
    .audience-section {
      background: var(--light-blue);
      padding: 80px 48px;
    }
    .audience-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 22px;
      margin-top: 52px;
    }
    .audience-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px 24px;
      text-align: center;
      transition:
        box-shadow var(--tr),
        transform var(--tr);
    }
    .audience-card:hover {
      box-shadow: 0 8px 28px rgba(0, 0, 0, 0.07);
      transform: translateY(-3px);
    }
    .audience-icon {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: rgba(232, 120, 42, 0.09);
      color: var(--orange);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }
    .audience-card h3 {
      font-size: 15px;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: 8px;
    }
    .audience-card p {
      font-size: 13px;
      color: var(--gray-mid);
      line-height: 1.65;
    }

    /* CTA Band */
    .cta-band {
      background: linear-gradient(135deg, #3d1e08 0%, var(--orange) 100%);
      color: var(--white);
      padding: 80px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-band::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          circle at 25% 40%,
          rgba(255, 255, 255, 0.07) 0%,
          transparent 50%
        ),
        radial-gradient(
          circle at 80% 70%,
          rgba(255, 255, 255, 0.05) 0%,
          transparent 45%
        );
      pointer-events: none;
    }
    .cta-band .container {
      position: relative;
      z-index: 1;
    }
    .cta-band h2 {
      font-size: clamp(28px, 4.5vw, 52px);
      font-weight: 300;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }
    .cta-band p {
      font-size: 16px;
      color: rgba(255, 255, 255, 0.68);
      max-width: 520px;
      margin: 0 auto 38px;
      line-height: 1.72;
    }
    .cta-band-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .btn-white-solid {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 30px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: var(--white);
      color: var(--orange);
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-white-solid:hover {
      background: var(--light-blue);
      transform: translateY(-1px);
    }
    .btn-white-ghost {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 500;
      padding: 12px 30px;
      border-radius: var(--radius);
      border: 1.5px solid rgba(255, 255, 255, 0.45);
      cursor: pointer;
      color: var(--white);
      background: transparent;
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-white-ghost:hover {
      border-color: rgba(255, 255, 255, 0.9);
      background: rgba(255, 255, 255, 0.1);
    }

    /* Responsive */
    @media (max-width: 960px) {
      .framework-grid,
      .build-grid,
      .stats-grid {
        grid-template-columns: 1fr 1fr;
      }
      .audience-grid {
        grid-template-columns: 1fr 1fr;
      }
    }
    @media (max-width: 768px) {
      .hero {
        padding: 80px 24px 80px;
        min-height: 60vh;
      }
      .section,
      .framework-section,
      .build-section,
      .stats-section,
      .audience-section,
      .cta-band {
        padding: 60px 24px;
      }
      .framework-grid,
      .build-grid,
      .stats-grid,
      .audience-grid {
        grid-template-columns: 1fr;
      }
      .maturity-viz {
        grid-template-columns: 1fr 1fr auto 1fr 1fr;
        gap: 10px;
      }
      .ml-1 .maturity-bar { height: 40px; }
      .ml-2 .maturity-bar { height: 70px; }
      .ml-3 .maturity-bar { height: 130px; }
      .ml-4 .maturity-bar { height: 200px; }
      .maturity-bar-icon { display: none; }
      .maturity-gap-label { font-size: 8px; }
      .maturity-brackets {
        grid-template-columns: 1fr auto 1fr;
      }
      .hero-actions {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
  <Header client:load />

  <!-- Hero -->
  <section class="hero" id="top">
    <div class="hero-inner">
      <div class="fade-up">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>AI Foundry&trade;
        </div>
        <h1>
          Custom AI Systems,<br /><span class="accent"
            >Forged for Your Operations.</span
          >
        </h1>
        <p class="hero-sub">
          Most organizations are stuck asking AI questions. The real value
          starts when AI runs your operations. We design, build, and operate
          the production-grade systems that bridge that gap.
        </p>
        <div class="hero-actions">
          <a href="#framework" class="btn-primary"
            >Explore the Foundry &rarr;</a
          >
          <a href="/contact?service=ai-foundry" class="btn-ghost-dark"
            >Schedule a Discovery Call</a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- AI Transformation Model -->
  <section class="maturity-section" id="transformation-model">
    <div class="container">
      <div class="fade-up">
        <div class="section-label">The AI Transformation Model</div>
        <h2 class="section-title">Four levels. One exponential curve.</h2>
        <p class="section-subtitle">
          Most organizations are stuck at Level 1-2, using AI to brainstorm
          and save time on individual tasks. The real operational value lives
          at Level 3-4, where AI becomes your teammate and runs your systems.
        </p>
      </div>

      <div class="maturity-viz">
        <div class="maturity-col ml-1 fade-up">
          <div class="maturity-bar">
            <svg class="maturity-bar-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 017 7c0 2.38-1.19 4.47-3 5.74V17H8v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 017-7z"/><path d="M9 18h6M10 22h4"/></svg>
            <span class="maturity-bar-label">L1</span>
          </div>
          <strong class="maturity-col-label">Thought Partner</strong>
          <span class="maturity-col-desc">Help people explore ideas and improve decisions</span>
        </div>
        <div class="maturity-col ml-2 fade-up">
          <div class="maturity-bar">
            <svg class="maturity-bar-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 7h6M9 12h6M9 17h4"/></svg>
            <span class="maturity-bar-label">L2</span>
          </div>
          <strong class="maturity-col-label">Assistant</strong>
          <span class="maturity-col-desc">Complete individual tasks faster, save employee time</span>
        </div>

        <div class="maturity-gap fade-up">
          <div class="maturity-gap-line"></div>
          <span class="maturity-gap-label">The Gap</span>
