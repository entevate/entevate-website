---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.jsx";
import Footer from "../components/Footer.jsx";
import "../global.css";

const title =
  "ENTEVATE | Experiential Branding, Digital Transformation & Innovation Roadmapping";
const description =
  "Human-centered innovation partner. We partner with organizations ready to evolve—designing immersive brand experiences, aligning digital content, and building actionable roadmaps for lasting impact.";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "ENTEVATE",
  "url": "https://www.entevate.com",
  "description": description,
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://www.entevate.com/contact?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
});
---

<BaseLayout title={title} description={description} ogType="website" jsonLd={jsonLd}>
  <Header client:load />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-svg-bg">
      <svg
        viewBox="0 0 1440 800"
        preserveAspectRatio="xMidYMid slice"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          class="curve-1"
          d="M 180 -80 C 180 -80 60 140 60 300 C 60 460 180 540 180 720 C 180 800 130 860 130 860"
          stroke="white"
          stroke-width="5"
          stroke-linecap="round"
          opacity="0.30"></path>
        <path
          class="curve-2"
          d="M 420 -100 C 420 -100 230 160 230 330 C 230 500 420 600 420 760 C 420 840 360 900 360 900"
          stroke="white"
          stroke-width="5.5"
          stroke-linecap="round"
          opacity="0.40"></path>
        <path
          class="curve-3"
          d="M 790 -120 C 790 -120 490 200 490 400 C 490 600 790 730 790 920"
          stroke="white"
          stroke-width="6"
          stroke-linecap="round"
          opacity="0.50"></path>
        <path
          class="curve-4"
          d="M 1080 -80 C 1080 -80 780 220 780 420 C 780 620 1080 760 1080 940"
          stroke="white"
          stroke-width="5"
          stroke-linecap="round"
          opacity="0.35"></path>
        <path
          class="curve-5"
          d="M 1320 -60 C 1320 -60 1060 240 1060 440 C 1060 640 1320 780 1320 960"
          stroke="white"
          stroke-width="4"
          stroke-linecap="round"
          opacity="0.25"></path>
      </svg>
    </div>
    <div class="hero-left fade-up">
      <div class="hero-eyebrow">
        <svg width="8" height="8" viewBox="0 0 8 8"
          ><circle cx="4" cy="4" r="4" fill="url(#eg)"></circle><defs
            ><linearGradient id="eg" x1="0" y1="0" x2="1" y2="0"
              ><stop offset="0%" stop-color="#2060D8"></stop><stop
                offset="100%"
                stop-color="#38C6F4"></stop></linearGradient
            ></defs
          ></svg
        >
        <span>Human-Centered Innovation Partner</span>
      </div>
      <h1>
        Innovating today for <span class="accent">a better tomorrow.</span>
      </h1>
      <p>
        At ENTEVATE, we believe innovation should be human, purposeful, and
        accessible. We partner with organizations ready to evolve—designing
        immersive brand experiences, aligning digital content, and building
        actionable roadmaps for lasting impact.
      </p>
      <div class="hero-actions">
        <a href="#services" class="btn-gradient">Our Services →</a>
        <a href="/contact" class="btn-ghost">Get In Touch</a>
      </div>
    </div>

    <div class="scroll-hint">
      <svg width="14" height="18" viewBox="0 0 14 18" fill="none"
        ><path
          d="M7 1v12M1 9l6 7 6-7"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path></svg
      >
      Scroll to explore
    </div>
  </section>

  <!-- Clients -->
  <div class="clients">
    <div class="clients-label">Trusted by leading organizations</div>
    <div class="clients-track-wrap">
      <div class="clients-track">
        <img src="/logos/caterpillar.svg" alt="Caterpillar" class="client-logo" />
        <img src="/logos/mustang-cat.svg" alt="Mustang CAT" class="client-logo" />
        <img src="/logos/trinity-college.svg" alt="Trinity College" class="client-logo" />
        <img src="/logos/cisco.svg" alt="Cisco" class="client-logo" />
        <img src="/logos/city-of-hartford.svg" alt="City of Hartford" class="client-logo" />
        <img src="/logos/blanchard-machinery.svg" alt="Blanchard Machinery" class="client-logo" />
        <img src="/logos/thompson-tractor.svg" alt="Thompson Tractor" class="client-logo" />
        <img src="/logos/caterpillar.svg" alt="Caterpillar" class="client-logo" />
        <img src="/logos/mustang-cat.svg" alt="Mustang CAT" class="client-logo" />
        <img src="/logos/trinity-college.svg" alt="Trinity College" class="client-logo" />
        <img src="/logos/cisco.svg" alt="Cisco" class="client-logo" />
        <img src="/logos/city-of-hartford.svg" alt="City of Hartford" class="client-logo" />
        <img src="/logos/blanchard-machinery.svg" alt="Blanchard Machinery" class="client-logo" />
        <img src="/logos/thompson-tractor.svg" alt="Thompson Tractor" class="client-logo" />
      </div>
    </div>
  </div>

  <!-- Services -->
  <section class="section" id="services">
    <div class="container">
      <div class="fade-up">
        <div class="section-label blue-gradient-clip">What We Do</div>
        <h2 class="section-title">Three pillars, one bold vision.</h2>
        <p class="section-subtitle">
          Every engagement is rooted in our three core practice areas — each
          designed to create human-first, measurable impact.
        </p>
      </div>
      <div class="services-grid">
        <div class="service-card s1 fade-up">
          <div class="service-icon">
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><polygon
                points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
              ></polygon></svg
            >
          </div>
          <h3>Experiential Branding &amp; Marketing</h3>
          <em>Crafting immersive brand experiences that resonate, engage audiences, and drive measurable action.</em>
          <p>
            We spark connection through intentional, emotionally engaging brand
            moments — measurable, memorable, and built to scale.
          </p>
          <a href="/experiential" class="learn-more">Learn More →</a>
        </div>
        <div class="service-card s2 fade-up">
          <div class="service-icon">
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
              ></path></svg
            >
          </div>
          <h3>Digital &amp; Content Transformation</h3>
          <em>Content Readiness™ for a more connected, adaptable, and future-ready business.</em>
          <p>
            We align people, platforms, and processes so your content is always
            clear, strategic, and ready to perform.
          </p>
          <a href="/transformation" class="learn-more">Learn More →</a>
        </div>
        <div class="service-card s3 fade-up">
          <div class="service-icon">
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M9 18h6M10 22h4M12 2a7 7 0 017 7c0 2.38-1.19 4.47-3 5.74V17H8v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 017-7z"
              ></path></svg
            >
          </div>
          <h3>Innovation Roadmapping</h3>
          <em>Clarity for bold ideas — and the structured systems to bring them to life at scale.</em>
          <p>
            We turn big ideas into tangible strategies — from concept to
            execution, aligning vision with action and clarity.
          </p>
          <a href="/innovation" class="learn-more">Learn More →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section
    class="section"
    id="about"
    style="background: var(--light-blue); background-image: radial-gradient(circle at 80% 20%, rgba(36,123,150,0.10) 0%, transparent 50%), radial-gradient(circle at 15% 85%, rgba(56,198,244,0.07) 0%, transparent 45%);"
  >
    <div class="container">
      <div class="about-split">
        <div class="about-left fade-up">
          <div class="section-label blue-gradient-clip">About ENTEVATE</div>
          <h2 class="section-title">A purpose-driven innovation collective.</h2>
          <p>
            ENTEVATE is a human-centered innovation partner working at the
            intersection of experiential branding, digital transformation, and
            strategic roadmapping.
          </p>
          <p>
            We partner with bold leaders who believe technology should amplify
            humanity — not replace it. From immersive brand experiences powered
            by Momentify to co-created innovation roadmaps, everything we build
            starts with people.
          </p>
          <a href="/about" class="btn-gradient">Learn About Us →</a>
          <div class="stat-row">
            <div class="stat">
              <h3>6+</h3><p>Fortune 500 clients served</p>
            </div>
            <div class="stat"><h3>3</h3><p>Core innovation pillars driving impact</p></div>
            <div class="stat">
              <h3>100%</h3><p>Human-centered by design</p>
            </div>
          </div>
        </div>

        <div class="about-visual fade-up">
          <div class="value-pill">
            <div class="pill-dot" style="background:var(--blue)"></div>
            <div>
              <h5>Empathy — We lead with heart</h5><span
                >Before we recommend, we listen. Before we solve, we understand.
                We approach every challenge through the lens of people first.</span
              >
            </div>
          </div>
          <div class="value-pill">
            <div class="pill-dot" style="background:var(--green)"></div>
            <div>
              <h5>Authenticity — We keep it real</h5><span
                >We bring our full selves to the table and encourage our clients
                to do the same. Transparency, vulnerability, and mutual respect.</span
              >
            </div>
          </div>
          <div class="value-pill">
            <div class="pill-dot" style="background:var(--purple)"></div>
            <div>
              <h5>Adaptability — We embrace the pivot</h5><span
                >In a world that changes fast, we stay grounded by staying
                flexible — with open minds, curious questions, and a willingness
                to evolve.</span
              >
            </div>
          </div>
          <div class="value-pill">
            <div class="pill-dot" style="background:var(--orange-light)"></div>
            <div>
              <h5>Quality — We don't cut corners</h5><span
                >From strategy to execution, we hold ourselves to a higher
                standard. Excellence is in the details — how we do something
                matters as much as what we do.</span
              >
            </div>
          </div>
          <div class="value-pill">
            <div class="pill-dot" style="background:var(--orange-dark)"></div>
            <div>
              <h5>
                Responsibility — We do what's right, not just what's easy
              </h5><span
                >We're committed to impact that's ethical, sustainable, and
                meaningful — accountable to our partners, our communities, and
                the planet.</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-banner" id="contact">
    <div class="fade-up">
      <h2>Ready to turn ideas into outcomes?</h2>
      <p>Let's build something unforgettable together.</p>
      <a href="/contact" class="btn-orange">Get In Touch →</a>
    </div>
  </section>

  <!-- Our Work -->
  <section class="section" id="work">
    <div class="container">
      <div class="blog-header fade-up">
        <div>
          <div class="section-label blue-gradient-clip">Our Work</div>
          <h2 class="section-title">Insights &amp; perspectives.</h2>
        </div>
        <a href="/our-work" class="btn-ghost">See All →</a>
      </div>
      <div class="blog-grid">
        <a
          href="/transformation/remote-assistance"
          class="blog-card card-dct fade-up"
        >
          <div class="blog-thumb bt2">Digital Transformation</div>
          <div class="blog-body">
            <div class="blog-tag">Digital &amp; Content Transformation</div>
            <h4>
              Transforming Remote Assistance with Spatial Computing: A
              Real-World Use Case
            </h4>
            <p>
              How spatial computing is reshaping the way distributed teams
              collaborate, troubleshoot, and deliver real-time remote assistance
              across complex industrial environments.
            </p>
            <div class="blog-read-more">Read More →</div>
          </div>
        </a>
        <a
          href="/insights/innovation-roadmapping"
          class="blog-card card-irm fade-up"
        >
          <div class="blog-thumb bt3">Innovation</div>
          <div class="blog-body">
            <div class="blog-tag">Innovation | Ventures | Ecosystem</div>
            <h4>
              Innovation Roadmapping: Navigating from Ideation to Amplification
            </h4>
            <p>
              Comprehensive plans to lead your business through rapid digital
              evolution — from early ideation and validation through full-scale
              execution and market growth.
            </p>
            <div class="blog-read-more">Read More →</div>
          </div>
        </a>
        <a
          href="/insights/beyond-the-hype-ar-vr-revenue"
          class="blog-card card-ebm fade-up"
        >
          <div class="blog-thumb bt1">Experiential</div>
          <div class="blog-body">
            <div class="blog-tag">Experiential Branding &amp; Marketing</div>
            <h4>
              Beyond the Hype: How AR/VR/Spatial Computing is Fueling Real
              Revenue Growth
            </h4>
            <p>
              The concrete business outcomes that immersive technologies like
              AR, VR, and spatial computing are delivering for forward-thinking
              brands and enterprises today.
            </p>
            <div class="blog-read-more">Read More →</div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <Footer client:load />

  <script src="../global.js"></script>
  <script>
    // Staggered fade-up delay for grid items on home page
    document.querySelectorAll(".services-grid, .blog-grid").forEach((grid) => {
      grid.querySelectorAll(".fade-up").forEach((el, i) => {
        (el as HTMLElement).style.transitionDelay = `${i * 0.1}s`;
      });
    });
  </script>

  <style>
    /* ── Hero (index-specific) ── */
    .hero {
      background: var(--light-blue);
      position: relative;
      overflow: hidden;
      padding: 96px 48px 140px;
      display: flex;
      align-items: center;
      min-height: 88vh;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          circle at 70% 30%,
          rgba(36, 123, 150, 0.1) 0%,
          transparent 55%
        ),
        radial-gradient(
          circle at 25% 80%,
          rgba(61, 151, 138, 0.07) 0%,
          transparent 50%
        );
      pointer-events: none;
    }
    .hero-svg-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
      pointer-events: none;
      overflow: hidden;
    }
    .hero-svg-bg svg {
      width: 100%;
      height: 100%;
      position: absolute;
      inset: 0;
    }
    .curve-1 {
      animation: drift1 8s ease-in-out infinite alternate;
      transform-origin: 50% 50%;
    }
    .curve-2 {
      animation: drift2 10s ease-in-out infinite alternate;
      transform-origin: 50% 50%;
    }
    .curve-3 {
      animation: drift3 12s ease-in-out infinite alternate;
      transform-origin: 50% 50%;
    }
    .curve-4 {
      animation: drift1 9s ease-in-out infinite alternate-reverse;
      transform-origin: 50% 50%;
    }
    .curve-5 {
      animation: drift2 11s ease-in-out infinite alternate-reverse;
      transform-origin: 50% 50%;
    }
    @keyframes drift1 {
      from {
        transform: translateY(-28px) translateX(0px) scaleY(1);
      }
      to {
        transform: translateY(28px) translateX(8px) scaleY(1.04);
      }
    }
    @keyframes drift2 {
      from {
        transform: translateY(20px) translateX(-6px) scaleY(0.97);
      }
      to {
        transform: translateY(-32px) translateX(10px) scaleY(1.04);
      }
    }
    @keyframes drift3 {
      from {
        transform: translateY(-16px) translateX(4px) scaleY(1.02);
      }
      to {
        transform: translateY(36px) translateX(-8px) scaleY(0.96);
      }
    }
    .hero-left {
      position: relative;
      z-index: 2;
      max-width: 1000px;
    }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: rgba(36, 123, 150, 0.08);
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 28px;
    }
    .hero-eyebrow span {
      background: linear-gradient(90deg, #2060d8 0%, #38c6f4 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero h1 {
      font-size: clamp(51px, 6.8vw, 97px);
      font-weight: 100;
      line-height: 1.04;
      color: var(--black);
      margin-bottom: 24px;
      letter-spacing: -0.03em;
      text-wrap: balance;
    }
    .hero h1 .accent {
      background: linear-gradient(90deg, #2060d8 0%, #38c6f4 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero p {
      font-size: 16px;
      color: var(--gray-mid);
      line-height: 1.75;
      max-width: 720px;
      margin-bottom: 40px;
    }
    .hero-actions {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    .hero-right {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .hero-card {
      background: var(--white);
      border-radius: var(--radius);
      padding: 22px 26px;
      border: 1px solid var(--border);
      display: flex;
      align-items: flex-start;
      gap: 14px;
      transition:
        box-shadow var(--tr),
        transform var(--tr);
    }
    .hero-card:hover {
      box-shadow: 0 6px 24px rgba(0, 0, 0, 0.07);
      transform: translateX(4px);
    }
    .hero-card-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 6px;
    }
    .hero-card h4 {
      font-size: 14px;
      font-weight: 700;
      color: var(--black);
      margin-bottom: 4px;
    }
    .hero-card p {
      font-size: 13px;
      color: var(--gray-mid);
      line-height: 1.55;
    }
    .scroll-hint {
      position: absolute;
      bottom: 36px;
      left: 48px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: var(--gray-light);
      z-index: 2;
    }

    @media (max-width: 600px) {
      .services-grid,
      .blog-grid {
        grid-template-columns: 1fr;
      }
    }

    /* ── About (index-specific) ── */
    .about-split {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .about-left p {
      font-size: 15px;
      color: var(--gray-mid);
      line-height: 1.8;
      margin-bottom: 16px;
    }
    .about-left p:last-of-type {
      margin-bottom: 32px;
    }
    .about-visual {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 36px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    /* ── Responsive (index-specific) ── */
    @media (max-width: 960px) {
      .hero {
        padding: 72px 24px 96px;
        min-height: auto;
      }
      .hero-right {
        display: none;
      }

      .about-split {
        grid-template-columns: 1fr;
        gap: 48px;
      }
    }
    @media (max-width: 600px) {
      .hero {
        padding: 56px 20px 80px;
      }
      .scroll-hint {
        left: 20px;
      }
    }
  </style>
</BaseLayout>
