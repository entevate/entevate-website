                  ><input type="radio" name="pr4" value="3" /><span
                    class="r-circle">3</span
                  ></label
                ><label class="r-opt"
                  ><input type="radio" name="pr4" value="4" /><span
                    class="r-circle">4</span
                  ></label
                ><label class="r-opt"
                  ><input type="radio" name="pr4" value="5" /><span
                    class="r-circle">5</span
                  ></label
                >
              </div>
            </div>
          </div>
          <div class="question-row">
            <div>
              <div class="q-num">PR5</div><div class="q-text">
                Our content can be deployed across multiple channels and
                platforms without significant rework.
              </div>
            </div>
            <div class="rating-wrap">
              <div class="rating-options" data-q="pr5">
                <label class="r-opt"
                  ><input type="radio" name="pr5" value="1" /><span
                    class="r-circle">1</span
                  ></label
                ><label class="r-opt"
                  ><input type="radio" name="pr5" value="2" /><span
                    class="r-circle">2</span
                  ></label
                ><label class="r-opt"
                  ><input type="radio" name="pr5" value="3" /><span
                    class="r-circle">3</span
                  ></label
                ><label class="r-opt"
                  ><input type="radio" name="pr5" value="4" /><span
                    class="r-circle">4</span
                  ></label
                ><label class="r-opt"
                  ><input type="radio" name="pr5" value="5" /><span
                    class="r-circle">5</span
                  ></label
                >
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="assessment-actions fade-up">
        <div class="progress-count" id="progressCount">0 of 15 answered</div>
        <button class="btn-score" id="btnScore"
          >Calculate My Readiness Score →</button
