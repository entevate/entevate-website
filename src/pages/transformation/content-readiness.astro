      </div>

      <!-- Score Display -->
      <div class="score-display" id="scoreDisplay">
        <div class="score-header">
          <div class="score-big" id="scoreNumber">—</div>
          <div
            style="font-size:16px;color:rgba(255,255,255,0.70);margin-top:6px;"
          >
            Overall Readiness Score
          </div>
          <div class="score-stage-badge" id="stageBadge">—</div>
        </div>
        <div class="score-body">
          <h3>Score Breakdown by Pillar</h3>
          <div class="pillar-scores">
            <div class="pillar-score-item">
              <div class="ps-label">People</div>
              <div class="ps-bar-track">
                <div class="ps-bar-fill" id="barPeople" style="width:0%"></div>
              </div>
              <div class="ps-pct" id="pctPeople">—</div>
            </div>
            <div class="pillar-score-item">
              <div class="ps-label">Platform</div>
              <div class="ps-bar-track">
                <div class="ps-bar-fill" id="barPlatform" style="width:0%">
                </div>
              </div>
              <div class="ps-pct" id="pctPlatform">—</div>
            </div>
            <div class="pillar-score-item">
              <div class="ps-label">Process</div>
              <div class="ps-bar-track">
                <div class="ps-bar-fill" id="barProcess" style="width:0%"></div>
              </div>
              <div class="ps-pct" id="pctProcess">—</div>
            </div>
          </div>
          <div class="score-interpretation">
            <div class="si-label" id="stageLabel">—</div>
            <div class="si-text" id="stageText">—</div>
          </div>
        </div>
        <!-- Lead Capture -->
        <div class="lead-form-wrap" id="leadFormWrap">
          <h3>Get Your Personalized Action Plan</h3>
          <p>
            Share your contact details and we'll send you a detailed action plan
            based on your Content Readiness™ score — along with recommendations
            for each pillar.
          </p>
          <form id="leadForm" action="#" method="POST" novalidate>
            <input
              type="hidden"
              name="_subject"
              value="Content Readiness Assessment Submission"
            />
            <input type="hidden" name="score" id="hiddenScore" />
            <input type="hidden" name="stage" id="hiddenStage" />
            <input type="hidden" name="people_score" id="hiddenPeople" />
            <input type="hidden" name="platform_score" id="hiddenPlatform" />
            <input type="hidden" name="process_score" id="hiddenProcess" />
            <div class="lead-grid">
              <div class="form-field">
                <label>First Name *</label><input
                  type="text"
                  name="first_name"
                  required
                  placeholder="Jane"
                />
              </div>
              <div class="form-field">
                <label>Last Name *</label><input
                  type="text"
                  name="last_name"
                  required
                  placeholder="Smith"
                />
              </div>
              <div class="form-field">
                <label>Company *</label><input
                  type="text"
                  name="company"
                  required
                  placeholder="Acme Corp"
                />
              </div>
              <div class="form-field">
                <label>Your Role</label><input
                  type="text"
                  name="role"
                  placeholder="VP of Marketing"
                />
              </div>
              <div class="form-field">
                <label>Business Email *</label><input
                  type="email"
                  name="email"
                  required
                  placeholder="jane@company.com"
                />
              </div>
              <div class="form-field">
                <label>Phone</label><input
                  type="tel"
                  name="phone"
                  placeholder="(555) 000-0000"
                />
              </div>
              <div class="form-field full">
                <label>Industry</label>
                <select name="industry">
                  <option value="">Select your industry</option>
                  <option>Manufacturing</option>
                  <option>Heavy Equipment</option>
                  <option>Automotive</option>
                  <option>Aviation &amp; Defense</option>
                  <option>Construction</option>
                  <option>Healthcare</option>
                  <option>Energy</option>
                  <option>Government</option>
                  <option>Other</option>
                </select>
              </div>
            </div>
            <div style="position:absolute;left:-9999px;" aria-hidden="true">
              <input
                type="text"
                name="website_url"
                tabindex="-1"
                autocomplete="off"
              />
            </div>
            <button type="submit" class="btn-submit"
              >Send Me My Action Plan →</button
            >
            <p class="form-note">
              We respect your privacy. Your information is used only to deliver
              your personalized Content Readiness report.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="cta-band" id="contact">
    <div class="container">
      <div class="fade-up">
        <h2>Ready to Close Your Content Readiness Gap?</h2>
        <p>
          Let ENTEVATE assess your people, platforms, and processes — and build
          a plan to get you ready for what's next.
        </p>
        <div class="cta-band-actions">
          <a href="/contact?service=transformation" class="btn-white-solid"
            >Start a Conversation</a
          >
          <a href="/transformation" class="btn-white-ghost"
            >← All Transformation Services</a
          >
        </div>
      </div>
    </div>
  </section>

  <Footer client:load buttonStyle={{ background: "var(--orange)" }} />

  <script src="../../global.js"></script>
  <script>
    // Assessment logic
    const questions = [
      "p1",
      "p2",
      "p3",
      "p4",
      "p5",
      "pl1",
      "pl2",
      "pl3",
      "pl4",
      "pl5",
      "pr1",
      "pr2",
      "pr3",
      "pr4",
      "pr5",
    ];
    const peopleQs = ["p1", "p2", "p3", "p4", "p5"];
    const platformQs = ["pl1", "pl2", "pl3", "pl4", "pl5"];
    const processQs = ["pr1", "pr2", "pr3", "pr4", "pr5"];
    const progressEl = document.getElementById("progressCount");
    const btnScore = document.getElementById("btnScore");

    function getAnswered() {
      return questions.filter((q) =>
        document.querySelector('input[name="' + q + '"]:checked'),
      );
    }
    function pillarScore(qs) {
      return qs.reduce((sum, q) => {
        const el = document.querySelector('input[name="' + q + '"]:checked');
        return sum + (el ? parseInt(el.value) : 0);
      }, 0);
    }

    document.querySelectorAll(".rating-options input").forEach((input) => {
      input.addEventListener("change", () => {
        const answered = getAnswered().length;
        progressEl.textContent = answered + " of 15 answered";
        if (answered === 15) {
          btnScore.classList.add("ready");
        }
      });
    });

    btnScore.addEventListener("click", () => {
      const pScore = pillarScore(peopleQs);
      const plScore = pillarScore(platformQs);
      const prScore = pillarScore(processQs);
      const total = pScore + plScore + prScore;
      const pct = Math.round((total / 75) * 100);
      const pPct = Math.round((pScore / 25) * 100);
      const plPct = Math.round((plScore / 25) * 100);
      const prPct = Math.round((prScore / 25) * 100);

      let stage, stageLabel, stageText;
      if (pct <= 39) {
        stage = "Stage 1 — Not Content Ready";
        stageLabel = "Significant Readiness Gaps Identified";
        stageText =
          "Your content ecosystem has fundamental gaps across People, Platform, and/or Process. Immediate action is needed to establish a baseline of readiness before scaling any digital or immersive initiatives.";
      } else if (pct <= 59) {
        stage = "Stage 2 — Emerging";
        stageLabel = "Foundation Being Established";
        stageText =
          "You have the beginnings of a content-ready organization, but significant work remains. Focus on closing your lowest-scoring pillar first to build a solid foundation for transformation.";
      } else if (pct <= 79) {
        stage = "Stage 3 — Developing";
        stageLabel = "On the Path to Readiness";
        stageText =
          "You're making progress. Your organization has meaningful content capabilities but clear opportunities to optimize. Targeted improvements to your weakest pillar will unlock significant gains.";
      } else {
        stage = "Stage 4 — Content Ready";
        stageLabel = "Strong Content Foundation";
        stageText =
          "Your organization demonstrates strong content readiness. You're well-positioned to leverage advanced digital and immersive technologies. Focus on sustaining and evolving your capabilities as new platforms emerge.";
      }

      document.getElementById("scoreNumber").textContent = pct + "%";
      document.getElementById("stageBadge").textContent = stage;
      document.getElementById("stageLabel").textContent = stageLabel;
      document.getElementById("stageText").textContent = stageText;
      document.getElementById("pctPeople").textContent = pPct + "%";
      document.getElementById("pctPlatform").textContent = plPct + "%";
      document.getElementById("pctProcess").textContent = prPct + "%";

      // Hidden form fields
      document.getElementById("hiddenScore").value = pct + "%";
      document.getElementById("hiddenStage").value = stage;
      document.getElementById("hiddenPeople").value = pPct + "%";
      document.getElementById("hiddenPlatform").value = plPct + "%";
      document.getElementById("hiddenProcess").value = prPct + "%";

      const scoreEl = document.getElementById("scoreDisplay");
      scoreEl.classList.add("visible");
      setTimeout(() => {
        document.getElementById("barPeople").style.width = pPct + "%";
        document.getElementById("barPlatform").style.width = plPct + "%";
        document.getElementById("barProcess").style.width = prPct + "%";
      }, 100);
      document.getElementById("leadFormWrap").classList.add("visible");
      scoreEl.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    // ─── Content Readiness Lead Form → HubSpot submission ───
    var leadFormLoadTime = Date.now();
    var minSubmitMs = 3 * 1000;
    document
      .getElementById("leadForm")
      .addEventListener("submit", function (e) {
        e.preventDefault();
        var form = document.getElementById("leadForm");
        var btn = form.querySelector(".btn-submit");
        var botCheck = form.querySelector('input[name="website_url"]');
        if (botCheck && botCheck.value) {
          form.innerHTML =
            '<div style="text-align:center;padding:32px 0;"><h3 style="font-size:22px;font-weight:400;margin-bottom:10px;">Action Plan Requested!</h3><p style="font-size:14px;color:#6B6B6B;">Thanks! We\'ll send your personalized Content Readiness™ report shortly.</p></div>';
          return;
        }
        if (Date.now() - leadFormLoadTime < minSubmitMs) {
          form.innerHTML =
            '<div style="text-align:center;padding:32px 0;"><h3 style="font-size:22px;font-weight:400;margin-bottom:10px;">Action Plan Requested!</h3><p style="font-size:14px;color:#6B6B6B;">Thanks! We\'ll send your personalized Content Readiness™ report shortly.</p></div>';
          return;
        }
        var required = form.querySelectorAll("[required]");
        var valid = true;
        required.forEach(function (field) {
          if (!field.value.trim()) {
            field.style.borderColor = "#CB632F";
            valid = false;
          } else {
            field.style.borderColor = "";
          }
        });
        if (!valid) return;
        btn.disabled = true;
        btn.textContent = "Sending…";
        var payload = {
          fields: [
            { name: "firstname", value: form.first_name.value },
            { name: "lastname", value: form.last_name.value },
            { name: "company", value: form.company.value },
            { name: "jobtitle", value: form.role.value },
            { name: "email", value: form.email.value },
            { name: "phone", value: form.phone.value },
            { name: "industry", value: form.industry.value },
            {
              name: "content_readiness_score",
              value: form.querySelector("#hiddenScore").value,
            },
            {
              name: "content_readiness_stage",
              value: form.querySelector("#hiddenStage").value,
            },
            {
              name: "people_score",
              value: form.querySelector("#hiddenPeople").value,
            },
            {
              name: "platform_score",
              value: form.querySelector("#hiddenPlatform").value,
            },
            {
              name: "process_score",
              value: form.querySelector("#hiddenProcess").value,
            },
          ],
          context: {
            pageUri: window.location.href,
            pageName: document.title,
          },
        };
        fetch(
          "https://api.hsforms.com/submissions/v3/integration/submit/44191993/ef7b3576-d3f9-4afe-9d2c-80c10fadfd86",
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          },
        )
          .then(function (r) {
            if (r.ok) {
              form.innerHTML =
                '<div style="text-align:center;padding:32px 0;"><h3 style="font-size:22px;font-weight:400;margin-bottom:10px;">Action Plan Requested!</h3><p style="font-size:14px;color:#6B6B6B;">Thanks! We\'ll send your personalized Content Readiness™ report shortly.</p></div>';
            } else {
              btn.disabled = false;
              btn.textContent = "Send Me My Action Plan →";
              alert(
                "Something went wrong. Please try again or email us at hello@entevate.com.",
              );
            }
          })
          .catch(function () {
            btn.disabled = false;
            btn.textContent = "Send Me My Action Plan →";
            alert(
              "Something went wrong. Please try again or email us at hello@entevate.com.",
            );
          });
      });
  </script>
</BaseLayout>
