---
import Footer from "../../components/Footer.jsx";
import Header from "../../components/Header.jsx";
import "../../global.css";
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Digital Transformation Strategy — ENTEVATE";
const description =
  "Human-centered digital transformation: learning & development, process design, change management, and governance.";
---

<BaseLayout title={title} description={description}>
  <style>
    .section {
      padding: 80px 48px;
    }
    .container {
      max-width: 1160px;
      margin: 0 auto;
    }
    .section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 14px;
      display: inline-block;
      color: var(--orange);
    }
    h2.section-title {
      font-size: clamp(30px, 4vw, 48px);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin-bottom: 16px;
    }
    .section-subtitle {
      font-size: 15px;
      color: var(--gray-mid);
      max-width: 580px;
      line-height: 1.75;
    }

    /* Hero */
    .hero {
      background:
        linear-gradient(
          135deg,
          rgba(50, 22, 5, 0.55) 0%,
          rgba(85, 42, 12, 0.45) 50%,
          rgba(115, 65, 25, 0.38) 100%
        ),
        url("/images/bt2.png") center/cover no-repeat;
      position: relative;
      overflow: hidden;
      padding: 96px 48px 120px;
      min-height: 72vh;
      display: flex;
      align-items: center;
    }
    .hero-inner {
      position: relative;
      z-index: 2;
      max-width: 1160px;
      margin: 0 auto;
      width: 100%;
    }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: rgba(232, 120, 42, 0.14);
      border: 1px solid rgba(232, 120, 42, 0.38);
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 28px;
      color: rgba(255, 255, 255, 0.9);
    }
    .hero-eyebrow-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: linear-gradient(135deg, #ffe5c0, #fff5e0);
      flex-shrink: 0;
    }
    .hero h1 {
      font-size: clamp(46px, 6vw, 84px);
      font-weight: 100;
      line-height: 1.04;
      color: var(--white);
      margin-bottom: 24px;
      letter-spacing: -0.03em;
      text-wrap: balance;
      max-width: 860px;
    }
    .hero h1 .accent {
      background: linear-gradient(90deg, #ffe5c0 0%, #fff5e0 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      font-size: 17px;
      color: rgba(255, 255, 255, 0.68);
      line-height: 1.75;
      max-width: 640px;
      margin-bottom: 42px;
    }
    .hero-actions {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    .btn-orange {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 30px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: linear-gradient(135deg, #e8782a 0%, #f5b731 100%);
      color: var(--white);
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-orange:hover {
      opacity: 0.88;
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(232, 120, 42, 0.45);
    }
    .btn-ghost-dark {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 500;
      background: none;
      border: 1.5px solid rgba(255, 255, 255, 0.35);
      padding: 12px 26px;
      border-radius: var(--radius);
      cursor: pointer;
      color: rgba(255, 255, 255, 0.85);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all var(--tr);
    }
    .btn-ghost-dark:hover {
      border-color: rgba(255, 255, 255, 0.8);
      color: var(--white);
      background: rgba(255, 255, 255, 0.08);
    }

    /* Overview */
    .overview-section {
      background: var(--white);
      padding: 80px 48px;
    }
    .overview-split {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      max-width: 1160px;
      margin: 0 auto;
    }
    .overview-left h2 {
      font-size: clamp(26px, 3.5vw, 40px);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.2;
      margin-bottom: 18px;
    }
    .overview-left p {
      font-size: 15px;
      color: var(--gray-mid);
      line-height: 1.8;
      margin-bottom: 18px;
    }
    .overview-pillars {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 20px;
    }
    .op-chip {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.04em;
      padding: 6px 14px;
      border-radius: 100px;
      background: rgba(232, 120, 42, 0.08);
      border: 1px solid rgba(232, 120, 42, 0.22);
      color: var(--orange);
    }
    .overview-right {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .ov-principle {
      background: var(--light-blue);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px 22px;
      display: flex;
      gap: 16px;
      align-items: flex-start;
    }
    .ov-icon {
      width: 40px;
      height: 40px;
      border-radius: 8px;
      background: rgba(232, 120, 42, 0.1);
      color: var(--orange);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .ov-body h4 {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 5px;
    }
    .ov-body p {
      font-size: 13px;
      color: var(--gray-mid);
      line-height: 1.6;
    }

    /* Components */
    .components-section {
      background: var(--light-blue);
      padding: 80px 48px;
    }
    .components-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      margin-top: 52px;
    }
    .comp-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px 26px;
      position: relative;
      overflow: hidden;
      transition:
        box-shadow var(--tr),
        transform var(--tr);
    }
    .comp-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .cc-1::before {
      background: linear-gradient(90deg, #e8782a, #f5b731);
    }
    .cc-2::before {
      background: linear-gradient(90deg, #ea9709, #f5c842);
    }
    .cc-3::before {
      background: linear-gradient(90deg, #cb632f, #e8782a);
    }
    .cc-4::before {
      background: linear-gradient(90deg, #f5b731, #fdd068);
    }
    .cc-5::before {
      background: linear-gradient(90deg, #e8782a, #cb632f);
    }
    .cc-6::before {
      background: linear-gradient(90deg, #ea9709, #e8782a);
    }
    .comp-card:hover {
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
      transform: translateY(-3px);
    }
    .comp-icon {
      width: 48px;
      height: 48px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 18px;
    }
    .cc-1 .comp-icon {
      background: rgba(232, 120, 42, 0.1);
      color: var(--orange);
    }
    .cc-2 .comp-icon {
      background: rgba(234, 151, 9, 0.1);
      color: var(--orange-light);
    }
    .cc-3 .comp-icon {
      background: rgba(203, 99, 47, 0.1);
      color: var(--orange-dark);
    }
    .cc-4 .comp-icon {
      background: rgba(245, 183, 49, 0.1);
      color: var(--orange-amber);
    }
    .cc-5 .comp-icon {
      background: rgba(232, 120, 42, 0.1);
      color: var(--orange);
    }
    .cc-6 .comp-icon {
      background: rgba(234, 151, 9, 0.1);
      color: var(--orange-light);
    }
    .comp-num {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gray-light);
      margin-bottom: 10px;
    }
    .comp-card h3 {
      font-size: 17px;
      font-weight: 400;
      letter-spacing: -0.01em;
      margin-bottom: 10px;
      line-height: 1.3;
    }
    .comp-card p {
      font-size: 13.5px;
      color: var(--gray-mid);
      line-height: 1.7;
    }
    .comp-card ul {
      margin-top: 14px;
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .comp-card ul li {
      font-size: 12.5px;
      color: var(--gray-mid);
      display: flex;
      align-items: flex-start;
      gap: 7px;
    }
    .comp-card ul li::before {
      content: "·";
      color: var(--orange);
      font-weight: 900;
      font-size: 16px;
      line-height: 1;
      flex-shrink: 0;
    }

    /* Process */
    .process-section {
      background: var(--white);
      padding: 80px 48px;
    }
    .process-track {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-top: 52px;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }
    .process-row {
      display: grid;
      grid-template-columns: 64px 1fr;
      gap: 28px;
      position: relative;
    }
    .process-row:not(:last-child)::before {
      content: "";
      position: absolute;
      left: 31px;
      top: 64px;
      bottom: -8px;
      width: 2px;
      background: linear-gradient(180deg, var(--orange), var(--orange-amber));
      z-index: 0;
    }
    .pr-dot {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: linear-gradient(135deg, #e8782a, #f5b731);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      position: relative;
      z-index: 1;
    }
    .pr-content {
      padding: 10px 0 40px;
    }
    .pr-phase {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 6px;
    }
    .pr-content h3 {
      font-size: 18px;
      font-weight: 400;
      letter-spacing: -0.01em;
      margin-bottom: 8px;
    }
    .pr-content p {
      font-size: 14px;
      color: var(--gray-mid);
      line-height: 1.72;
    }

    /* Why Section */
    .why-section {
      background: var(--light-blue);
      padding: 80px 48px;
    }
    .why-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
      margin-top: 52px;
    }
    .why-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 36px 28px;
      text-align: center;
      transition:
        box-shadow var(--tr),
        transform var(--tr);
    }
    .why-card:hover {
      box-shadow: 0 8px 28px rgba(0, 0, 0, 0.07);
      transform: translateY(-3px);
    }
    .why-icon {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: rgba(232, 120, 42, 0.09);
      color: var(--orange);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
    }
    .why-stat {
      font-size: 17px;
      font-weight: 600;
      color: var(--black);
      margin-bottom: 10px;
      letter-spacing: -0.01em;
    }
    .why-desc {
      font-size: 14px;
      color: var(--gray-mid);
      line-height: 1.65;
    }

    /* CTA Band */
    .cta-band {
      background: linear-gradient(135deg, #3d1e08 0%, #e8782a 100%);
      color: var(--white);
      padding: 80px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-band::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          circle at 25% 40%,
          rgba(255, 255, 255, 0.07) 0%,
          transparent 50%
        ),
        radial-gradient(
          circle at 80% 70%,
          rgba(255, 255, 255, 0.05) 0%,
          transparent 45%
        );
      pointer-events: none;
    }
    .cta-band .container {
      position: relative;
      z-index: 1;
    }
    .cta-band h2 {
      font-size: clamp(28px, 4.5vw, 52px);
      font-weight: 300;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }
    .cta-band p {
      font-size: 16px;
      color: rgba(255, 255, 255, 0.68);
      max-width: 520px;
      margin: 0 auto 38px;
      line-height: 1.72;
    }
    .cta-band-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .btn-white-solid {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 30px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: var(--white);
      color: var(--orange);
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-white-solid:hover {
      background: var(--light-blue);
      transform: translateY(-1px);
    }
    .btn-white-ghost {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 500;
      padding: 12px 30px;
      border-radius: var(--radius);
      border: 1.5px solid rgba(255, 255, 255, 0.45);
      cursor: pointer;
      color: var(--white);
      background: transparent;
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-white-ghost:hover {
      border-color: rgba(255, 255, 255, 0.9);
      background: rgba(255, 255, 255, 0.1);
    }

    /* Footer */
    footer {
      background: var(--black);
      color: var(--white);
      padding: 72px 48px 40px;
    }
    .footer-top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1.4fr;
      gap: 48px;
      margin-bottom: 56px;
    }
    .footer-brand p {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.42);
      line-height: 1.75;
      max-width: 270px;
      margin-bottom: 22px;
    }
    .footer-address {
      font-size: 13px;
      color: rgba(255, 255, 255, 0.35);
      line-height: 1.85;
    }
    .footer-col h5 {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.3);
      margin-bottom: 18px;
    }
    .footer-col ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 11px;
    }
    .footer-col ul a {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.62);
      transition: color var(--tr);
    }
    .footer-col ul a:hover {
      color: var(--white);
    }
    .footer-newsletter h5 {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.3);
      margin-bottom: 12px;
    }
    .footer-newsletter p {
      font-size: 13px;
      color: rgba(255, 255, 255, 0.4);
      margin-bottom: 18px;
      line-height: 1.6;
    }
    .newsletter-form {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .newsletter-form input {
      font-family: var(--font);
      font-size: 13px;
      padding: 11px 14px;
      border-radius: var(--radius);
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.06);
      color: var(--white);
      outline: none;
      transition: border-color var(--tr);
    }
    .newsletter-form input::placeholder {
      color: rgba(255, 255, 255, 0.28);
    }
    .newsletter-form input:focus {
      border-color: var(--orange);
    }
    .newsletter-form button {
      font-family: var(--font);
      font-size: 13px;
      font-weight: 600;
      padding: 11px;
      border-radius: var(--radius);
      border: none;
      background: var(--orange);
      color: var(--white);
      cursor: pointer;
      transition: background var(--tr);
    }
    .newsletter-form button:hover {
      background: var(--orange-dark);
    }
    .footer-bottom {
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      padding-top: 26px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
      color: rgba(255, 255, 255, 0.28);
      flex-wrap: wrap;
      gap: 12px;
    }
    .footer-socials {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .footer-socials a {
      color: rgba(255, 255, 255, 0.38);
      transition: color var(--tr);
      display: flex;
      align-items: center;
    }
    .footer-socials a:hover {
      color: var(--white);
    }
    .fade-up {
      opacity: 0;
      transform: translateY(22px);
      transition:
        opacity 0.55s ease,
        transform 0.55s ease;
    }
    .fade-up.visible {
      opacity: 1;
      transform: none;
    }
  </style>
  <Header client:load />

  <!-- Hero -->
  <section class="hero" id="top">
    <div class="hero-inner">
      <div class="fade-up">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>Digital &amp; Content
          Transformation
        </div>
        <h1>
          Digital Transformation<br /><span class="accent"
            >Built Around Your People.</span
          >
        </h1>
        <p class="hero-sub">
          Technology alone doesn't transform organizations — people do. Our
          Digital Transformation Strategy practice combines learning &amp;
          development, process design, change management, and governance to
          create lasting change that actually sticks.
        </p>
        <div class="hero-actions">
          <a href="/contact?service=transformation" class="btn-orange"
            >Build Your Strategy →</a
          >
          <a href="/transformation" class="btn-ghost-dark"
            >← Back to Transformation</a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="overview-section" id="overview">
    <div class="overview-split fade-up">
      <div class="overview-left">
        <div class="section-label">Our Approach</div>
        <h2>
          Transformation that's human-centered, change-managed, and tied to real
          outcomes.
        </h2>
        <p>
          Most digital transformation efforts fail not because of technology —
          but because of people. Adoption stalls, processes don't change, and
          the tools sit unused. ENTEVATE designs transformation strategies that
          start with your people and build everything else around them.
        </p>
        <p>
          From organizational readiness assessments to learning architecture,
          content standards, and platform governance — we stay with you through
          every phase of the shift, ensuring the transformation is felt across
          every role and every workflow.
        </p>
        <div class="overview-pillars">
          <span class="op-chip">Learning &amp; Development</span>
          <span class="op-chip">Process Design</span>
          <span class="op-chip">Change Management</span>
          <span class="op-chip">Governance</span>
          <span class="op-chip">Tools &amp; Storage</span>
          <span class="op-chip">Instructional Design</span>
        </div>
      </div>
      <div class="overview-right">
        <div class="ov-principle">
          <div class="ov-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              ><path
                d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path><circle
                cx="9"
                cy="7"
                r="4"
                stroke="currentColor"
                stroke-width="1.6"></circle></svg
            >
          </div>
          <div class="ov-body">
            <h4>People-First Philosophy</h4><p>
              Every strategy begins with understanding who your people are, how
              they work, and what they need to succeed in a transformed
              environment.
            </p>
          </div>
        </div>
        <div class="ov-principle">
          <div class="ov-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              ><path
                d="M9 11l3 3L22 4"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path><path
                d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path></svg
            >
          </div>
          <div class="ov-body">
            <h4>Co-Execution, Not Just Consulting</h4><p>
              We don't hand off a slide deck and disappear. We design, align,
              and co-execute with your team — adapting as the transformation
              unfolds.
            </p>
          </div>
        </div>
        <div class="ov-principle">
          <div class="ov-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              ><path
                d="M13 2L3 14h9l-1 8 9-12h-9l1-8z"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linejoin="round"></path></svg
            >
          </div>
          <div class="ov-body">
            <h4>Tied to Business Outcomes</h4><p>
              Every component of the strategy is connected to measurable
              business goals — not just technical milestones or project
              completion criteria.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6 Components -->
  <section class="components-section" id="components">
    <div class="container">
      <div class="fade-up">
        <div class="section-label">Six Core Components</div>
        <h2 class="section-title">A complete transformation framework.</h2>
        <p class="section-subtitle">
          Each engagement is scoped to your specific needs — but true
