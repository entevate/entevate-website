---
import Header from "../components/Header.jsx";
import Footer from "../components/Footer.jsx";
import "../global.css";

const title = "Our Work — ENTEVATE";
const description =
  "Real engagements, tangible outcomes, and thinking from the frontier of experiential branding, digital transformation, and innovation strategy.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header client:load />

    <!-- ═══════════════════════════ PAGE HERO ═══════════════════════════ -->
    <div class="page-hero">
      <div class="hero-svg-bg">
        <svg
          viewBox="0 0 1440 800"
          preserveAspectRatio="xMidYMid slice"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            class="curve-1"
            d="M 180 -80 C 180 -80 60 140 60 300 C 60 460 180 540 180 720 C 180 800 130 860 130 860"
            stroke="white"
            stroke-width="5"
            stroke-linecap="round"
            opacity="0.30"></path>
          <path
            class="curve-2"
            d="M 420 -100 C 420 -100 230 160 230 330 C 230 500 420 600 420 760 C 420 840 360 900 360 900"
            stroke="white"
            stroke-width="5.5"
            stroke-linecap="round"
            opacity="0.40"></path>
          <path
            class="curve-3"
            d="M 790 -120 C 790 -120 490 200 490 400 C 490 600 790 730 790 920"
            stroke="white"
            stroke-width="6"
            stroke-linecap="round"
            opacity="0.50"></path>
          <path
            class="curve-4"
            d="M 1080 -80 C 1080 -80 780 220 780 420 C 780 620 1080 760 1080 940"
            stroke="white"
            stroke-width="5"
            stroke-linecap="round"
            opacity="0.35"></path>
          <path
            class="curve-5"
            d="M 1320 -60 C 1320 -60 1060 240 1060 440 C 1060 640 1320 780 1320 960"
            stroke="white"
            stroke-width="4"
            stroke-linecap="round"
            opacity="0.25"></path>
        </svg>
      </div>
      <div class="page-hero-inner">
        <div class="fade-up">
          <div class="section-label">Our Work</div>
          <h1>Insights, case studies &amp; perspectives.</h1>
          <p>
            Real engagements, tangible outcomes, and thinking from the frontier
            of experiential branding, digital transformation, and innovation
            strategy.
          </p>
          <div class="hero-actions">
            <a href="#case-studies" class="btn-primary">View Case Studies →</a>
            <a href="#insights" class="btn-ghost">Read Insights →</a>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════ FEATURED CASE STUDY ═══════════════════════════ -->
    <div class="featured-section" id="case-studies">
      <div class="container">
        <span class="featured-section-label">Featured Case Study</span>

        <a
          href="/innovation/trinity-aiqui-sandbox"
          class="featured-card fade-up"
        >
          <div class="featured-img">
            <img
              src="/images/trinity.jpg"
              alt="Trinity College AIQUI Sandbox"
            />
          </div>
          <div class="featured-body">
            <div class="featured-tag tag-irm">
              Innovation · Higher Education · AI &amp; Quantum
            </div>
            <h3>Trinity College<br />AIQUI Sandbox</h3>
            <p>
              Trinity College engaged ENTEVATE to design and facilitate an
              applied AI and quantum innovation environment grounded in the
              AIQUI framework. Working across academic, research, and industry
              stakeholders, ENTEVATE mapped the full innovation ecosystem using
              the 7 Core Elements Basecamps™.
            </p>
            <div class="featured-outcomes">
              <div class="featured-outcome">AIQUI Framework Applied</div>
              <div class="featured-outcome">7 Basecamps™ Mapped</div>
              <div class="featured-outcome">Multi-Stakeholder Alignment</div>
              <div class="featured-outcome">Innovation Sandbox Deployed</div>
            </div>
            <span class="btn-case">Read Case Study →</span>
          </div>
        </a>
      </div>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
      <div class="filter-inner">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="experiential"
          >Experiential</button
        >
        <button class="filter-btn" data-filter="transformation"
          >Transformation</button
        >
        <button class="filter-btn" data-filter="innovation">Innovation</button>
        <button class="filter-btn" data-filter="case-study">Case Studies</button
        >
        <button class="filter-btn" data-filter="insight">Insights</button>
      </div>
    </div>

    <!-- ═══════════════════════════ WORK GRID ═══════════════════════════ -->
    <div class="work-section" id="insights">
      <div class="container">
        <span class="work-section-label">Case Studies &amp; Insights</span>

        <div class="work-grid">
          <!-- Card 1: Remote Assistance -->
          <a
            href="/transformation/remote-assistance"
            class="work-card fade-up"
            data-category="transformation case-study"
          >
            <div class="work-thumb"><div class="work-thumb-bg bt2"></div></div>
            <div class="work-body">
              <div class="work-tag tag-dct">
                Digital &amp; Content Transformation
              </div>
              <h3>Transforming Remote Assistance with Spatial Computing</h3>
              <p>
                How spatial computing is reshaping the way teams collaborate and
                deliver remote assistance across industries.
              </p>
              <div class="work-read-more read-dct">Read More →</div>
            </div>
          </a>

          <!-- Card 2: CAD to CGI -->
          <a
            href="/transformation/cad-to-cgi"
            class="work-card fade-up"
            data-category="transformation case-study"
          >
            <div class="work-thumb"><div class="work-thumb-bg bt2"></div></div>
            <div class="work-body">
              <div class="work-tag tag-dct">
                Digital &amp; Content Transformation
              </div>
              <h3>The Power of CAD-to-CGI Conversion for Engineering</h3>
              <p>
                How CAD-to-CGI conversion is unlocking new possibilities for
                engineering visualization and storytelling at scale.
              </p>
              <div class="work-read-more read-dct">Read More →</div>
            </div>
          </a>

          <!-- Card 3: AR/VR Revenue Growth -->
          <a
            href="/insights/beyond-the-hype-ar-vr-revenue"
            class="work-card fade-up"
            data-category="experiential insight"
          >
            <div class="work-thumb"><div class="work-thumb-bg bt1"></div></div>
            <div class="work-body">
              <div class="work-tag tag-ebm">
                Experiential Branding &amp; Marketing
              </div>
              <h3>
                Beyond the Hype: AR/VR/Spatial Computing Fueling Real Revenue
                Growth
              </h3>
              <p>
                The concrete business outcomes immersive technology is
                delivering for forward-thinking brands and enterprises.
              </p>
              <div class="work-read-more read-ebm">Read More →</div>
            </div>
          </a>

          <!-- Card 4: Energy Innovation Lab -->
          <a
            href="/innovation/energy-innovation-lab"
            class="work-card fade-up"
            data-category="innovation case-study"
          >
            <div class="work-thumb"><div class="work-thumb-bg bt3"></div></div>
            <div class="work-body">
              <div class="work-tag tag-irm">
                Innovation | Ventures | Ecosystem
              </div>
              <h3>Energy Innovation Lab: From Concept to Capital Pipeline</h3>
              <p>
                How ENTEVATE designed and launched an internal innovation lab
                for a leading energy organization, connecting ideas to capital
                readiness.
              </p>
              <div class="work-read-more read-irm">Read More →</div>
            </div>
          </a>

          <!-- Card 5: AIQUI Framework -->
          <a
            href="/innovation/aiqui"
            class="work-card fade-up"
            data-category="innovation insight"
          >
            <div class="work-thumb"><div class="work-thumb-bg bt3"></div></div>
            <div class="work-body">
              <div class="work-tag tag-irm">
                Innovation | Ventures | Ecosystem
              </div>
              <h3>
                AIQUI: Applied Innovation for AI &amp; Quantum Technologies
              </h3>
              <p>
                An introduction to ENTEVATE's structured ecosystem model for
                organizations advancing artificial intelligence and quantum
                technologies.
              </p>
              <div class="work-read-more read-irm">Explore Framework →</div>
            </div>
          </a>

          <!-- Card 6: Trade Show Transformation -->
          <a
            href="/experiential/fortune-500-trade-show"
            class="work-card fade-up"
            data-category="experiential case-study"
          >
            <div class="work-thumb"><div class="work-thumb-bg bt1"></div></div>
            <div class="work-body">
              <div class="work-tag tag-ebm">
                Experiential Branding &amp; Marketing
              </div>
              <h3>Fortune 500 Trade Show Transformation with AR Activation</h3>
              <p>
                How an immersive, multi-zone exhibit with real-time engagement
                tracking tripled dwell time at a major industrial trade show.
              </p>
              <div class="work-read-more read-ebm">Read More →</div>
            </div>
          </a>

          <!-- Card 7: Innovation Roadmapping Insight -->
          <a
            href="/insights/innovation-roadmapping"
            class="work-card fade-up"
            data-category="innovation insight"
          >
            <div class="work-thumb"><div class="work-thumb-bg bt3"></div></div>
            <div class="work-body">
              <div class="work-tag tag-irm">
                Innovation | Ventures | Ecosystem
              </div>
              <h3>
                Innovation Roadmapping: Navigating from Ideation to
                Amplification
              </h3>
              <p>
                A guide to leading businesses through today's rapid digital
                evolution — with comprehensive plans to design and execute the
                right innovation strategy for your organization.
              </p>
              <div class="work-read-more read-irm">Read More →</div>
            </div>
          </a>

          <!-- Card 8: Beyond the Buzz — Holistic AR/VR Strategy -->
          <a
            href="/insights/beyond-the-buzz-ar-vr-strategy"
            class="work-card fade-up"
            data-category="experiential insight"
          >
            <div class="work-thumb"><div class="work-thumb-bg bt1"></div></div>
            <div class="work-body">
              <div class="work-tag tag-ebm">
                Experiential Branding &amp; Marketing
              </div>
              <h3>
                Beyond the Buzz: Building a Holistic AR/VR/Spatial Strategy for
                Real Business Impact
              </h3>
              <p>
                True success with immersive technologies lies in weaving AR, VR,
                and spatial computing into the fabric of your business strategy
                — moving past novelty toward sustained, tangible results.
              </p>
              <div class="work-read-more read-ebm">Read More →</div>
            </div>
          </a>

          <!-- Card 9: Trade Show Hacks -->
          <a
            href="/insights/trade-show-hacks"
            class="work-card fade-up"
            data-category="experiential insight"
          >
            <div class="work-thumb"><div class="work-thumb-bg bt1"></div></div>
            <div class="work-body">
              <div class="work-tag tag-ebm">
                Experiential Branding &amp; Marketing
              </div>
              <h3>
                Trade Show Hacks: How to Rise Above the Noise and Engage Users
              </h3>
              <p>
                Actionable tactics from ENTEVATE's trade show floor experience —
                ten strategies to ensure your presence is not only felt but
                leaves a lasting impression on attendees.
              </p>
              <div class="work-read-more read-ebm">Read More →</div>
            </div>
          </a>

          <!-- Card 10: Finding Your Perfect Match -->
          <a
            href="/insights/finding-your-perfect-match"
            class="work-card fade-up"
            data-category="insight"
          >
            <div class="work-thumb">
              <div class="work-thumb-bg bt-blue"></div>
            </div>
            <div class="work-body">
              <div class="work-tag tag-gen">Digital Innovation</div>
              <h3>
                Finding Your Perfect Match: Partnering for Digital Innovation
                Success
              </h3>
              <p>
                Going it alone in digital innovation can be a recipe for
                disaster. Explore how startups and enterprises benefit from the
                right expert partnerships — and the critical questions to ask
                before you commit.
              </p>
              <div class="work-read-more read-gen">Read More →</div>
            </div>
          </a>

          <!-- Card 11: Stepping Into a World of Wow -->
          <a
            href="/insights/stepping-into-a-world-of-wow"
            class="work-card fade-up"
            data-category="experiential insight"
          >
            <div class="work-thumb"><div class="work-thumb-bg bt1"></div></div>
            <div class="work-body">
              <div class="work-tag tag-ebm">
                Experiential Branding &amp; Marketing
              </div>
              <h3>
                Stepping Into a World of "Wow": How Digital Innovation Drives
                Unique Customer Experiences
              </h3>
              <p>
                Customers crave memorable moments and genuine connection.
                Explore how digital innovation transforms ordinary transactions
                into compelling engagements through AR/VR, AI, and personalized
                touchpoints.
              </p>
              <div class="work-read-more read-ebm">Read More →</div>
            </div>
          </a>

          <!-- Card 12: Conquering the Tech Challenge -->
          <a
            href="/insights/conquering-the-tech-challenge"
            class="work-card fade-up"
            data-category="insight"
          >
            <div class="work-thumb">
              <div class="work-thumb-bg bt-blue"></div>
            </div>
            <div class="work-body">
              <div class="work-tag tag-gen">Digital Innovation</div>
              <h3>
                Conquering the Tech Challenge: Your Actionable Checklist for
                Navigating AR, VR, and AI
              </h3>
              <p>
                A clear strategy is everything in a rapidly evolving tech
                landscape. A practical checklist for leveraging artificial
                intelligence, augmented reality, and virtual reality to drive
                real business growth.
              </p>
              <div class="work-read-more read-gen">Read More →</div>
            </div>
          </a>

          <!-- Card 13: Surfing the Tsunami -->
          <a
            href="/insights/surfing-the-tsunami"
            class="work-card fade-up"
            data-category="insight"
          >
            <div class="work-thumb">
              <div class="work-thumb-bg bt-blue"></div>
            </div>
            <div class="work-body">
              <div class="work-tag tag-gen">Digital Innovation</div>
              <h3>
                Surfing the Tsunami: A 2023 Digital Disruption Retrospective
              </h3>
              <p>
                AI went from whispering in our ears to shouting in our faces. A
                retrospective on five major technological shifts that defined
                2023 — from AI's explosion to the rise of the metaverse and
                beyond.
              </p>
              <div class="work-read-more read-gen">Read More →</div>
            </div>
          </a>

          <!-- Card 14: Launch Day Announcement -->
          <a
            href="/insights/launch-day-announcement"
            class="work-card fade-up"
            data-category="insight"
          >
            <div class="work-thumb">
              <div class="work-thumb-bg bt-blue"></div>
            </div>
            <div class="work-body">
              <div class="work-tag tag-gen">Announcement</div>
              <h3>Launch Day: ENTEVATE Is Here</h3>
              <p>
                A collective of passionate change-makers committed to making
                innovation understandable, impactful, and accessible to all —
                introducing ENTEVATE and the mission behind our three core
                services.
              </p>
              <div class="work-read-more read-gen">Read More →</div>
            </div>
          </a>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════ CTA BAND ═══════════════════════════ -->
    <section class="cta-band" id="contact">
      <div class="container">
        <div class="fade-up">
          <h2>Ready to Create Your Own Case Study?</h2>
          <p>
            Let's build something together — and make it worth writing about.
          </p>
          <div class="cta-band-actions">
            <a href="/contact" class="btn-white-solid">Start a Conversation</a>
            <a href="/about" class="btn-white-ghost">About ENTEVATE →</a>
          </div>
        </div>
      </div>
    </section>

    <Footer client:load />

    <script src="../global.js"></script>
    <script>
      document.querySelectorAll(".work-grid .fade-up").forEach((el, i) => {
        el.style.transitionDelay = `${i * 0.08}s`;
      });

      // Filter tabs (basic show/hide)
      const filterBtns = document.querySelectorAll(".filter-btn");
      const workCards = document.querySelectorAll(".work-grid .work-card");
      filterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          filterBtns.forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          const filter = btn.dataset.filter;
          workCards.forEach((card) => {
            if (
              filter === "all" ||
              (card.dataset.category || "").includes(filter)
            ) {
              card.style.display = "flex";
            } else {
              card.style.display = "none";
            }
          });
        });
      });
    </script>

    <style>
      /* ── Page Hero ── */
      .page-hero {
        background: var(--light-blue);
        position: relative;
        overflow: hidden;
        padding: 96px 48px 80px;
        border-bottom: 1px solid var(--border);
      }

      .page-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
          radial-gradient(
            circle at 70% 30%,
            rgba(36, 123, 150, 0.1) 0%,
            transparent 55%
          ),
          radial-gradient(
            circle at 25% 80%,
            rgba(61, 151, 138, 0.07) 0%,
            transparent 50%
          );
      }

      /* Animated SVG curves (match home hero) */
      .hero-svg-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        pointer-events: none;
        overflow: hidden;
      }

      .hero-svg-bg svg {
        width: 100%;
        height: 100%;
        position: absolute;
        inset: 0;
      }

      .curve-1 {
        animation: drift1 8s ease-in-out infinite alternate;
        transform-origin: 50% 50%;
      }
      .curve-2 {
        animation: drift2 10s ease-in-out infinite alternate;
        transform-origin: 50% 50%;
      }
      .curve-3 {
        animation: drift3 12s ease-in-out infinite alternate;
        transform-origin: 50% 50%;
      }
      .curve-4 {
        animation: drift1 9s ease-in-out infinite alternate-reverse;
        transform-origin: 50% 50%;
      }
      .curve-5 {
        animation: drift2 11s ease-in-out infinite alternate-reverse;
        transform-origin: 50% 50%;
      }

      @keyframes drift1 {
        from {
          transform: translateY(-28px) translateX(0px) scaleY(1);
        }
        to {
          transform: translateY(28px) translateX(8px) scaleY(1.04);
        }
      }

      @keyframes drift2 {
        from {
          transform: translateY(20px) translateX(-6px) scaleY(0.97);
        }
        to {
          transform: translateY(-32px) translateX(10px) scaleY(1.04);
        }
      }

      @keyframes drift3 {
        from {
          transform: translateY(-16px) translateX(4px) scaleY(1.02);
        }
        to {
          transform: translateY(36px) translateX(-8px) scaleY(0.96);
        }
      }

      .page-hero-inner {
        max-width: 1160px;
        margin: 0 auto;
        position: relative;
        z-index: 2;
      }

      .page-hero .section-label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 14px;
        color: var(--blue);
      }

      .page-hero h1 {
        font-size: clamp(40px, 6vw, 72px);
        font-weight: 100;
        letter-spacing: -0.03em;
        line-height: 1.06;
        color: var(--black);
        margin-bottom: 18px;
        max-width: 760px;
      }

      .page-hero p {
        font-size: 16px;
        color: var(--gray-mid);
        max-width: 580px;
        line-height: 1.75;
        margin-bottom: 32px;
      }

      .hero-actions {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
      }

      .btn-primary {
        font-family: var(--font);
        font-size: 14px;
        font-weight: 600;
        padding: 11px 24px;
        border-radius: var(--radius);
        border: none;
        cursor: pointer;
        background: var(--blue);
        color: var(--white);
        transition: all var(--tr);
        display: inline-block;
      }

      .btn-primary:hover {
        background: var(--purple);
        transform: translateY(-1px);
      }

      .btn-ghost {
        font-family: var(--font);
        font-size: 14px;
        font-weight: 500;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--blue);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: gap var(--tr);
      }

      .btn-ghost:hover {
        gap: 9px;
      }

      /* ── Filter Tabs ── */
      .filter-bar {
        background: var(--white);
        border-bottom: 1px solid var(--border);
        padding: 0 48px;
        position: sticky;
        top: 70px;
        z-index: 90;
      }

      .filter-inner {
        max-width: 1160px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 4px;
        overflow-x: auto;
        padding: 14px 0;
        scrollbar-width: none;
      }

      .filter-inner::-webkit-scrollbar {
        display: none;
      }

      .filter-btn {
        font-family: var(--font);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 7px 16px;
        border-radius: 100px;
        border: 1.5px solid var(--border);
        background: transparent;
        color: var(--gray-mid);
        cursor: pointer;
        white-space: nowrap;
        transition: all var(--tr);
      }

      .filter-btn:hover {
        border-color: var(--blue);
        color: var(--blue);
      }

      .filter-btn.active {
        background: var(--blue);
        border-color: var(--blue);
        color: var(--white);
      }

      /* ── Work Grid ── */
      .work-section {
        padding: 56px 48px 80px;
        background: var(--white);
      }

      .work-section-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gray-light);
        margin-bottom: 24px;
        display: block;
      }

      .work-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

      .work-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        transition:
          box-shadow var(--tr),
          transform var(--tr);
        display: flex;
        flex-direction: column;
      }

      .work-card:hover {
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
        transform: translateY(-3px);
      }

      .work-thumb {
        height: 185px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
      }

      .work-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.5s ease;
      }

      .work-card:hover .work-thumb img {
        transform: scale(1.04);
      }

      .work-thumb-bg {
        width: 100%;
        height: 100%;
        background-size: cover;
        background-position: center;
        transition: transform 0.5s ease;
      }

      .work-card:hover .work-thumb-bg {
        transform: scale(1.04);
      }

      .bt1 {
        background: url("/images/bt1.png") center/cover no-repeat;
      }

      .bt2 {
        background: url("/images/bt2.png") center/cover no-repeat;
      }

      .bt3 {
        background: url("/images/bt3.png") center/cover no-repeat;
      }

      .bt-trinity {
        background: url("/images/trinity.jpg") center/cover no-repeat;
      }

      .bt-blue {
        background: url("/images/bg-blue.png") center/cover no-repeat;
      }

      .work-body {
        padding: 22px;
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      .work-tag {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 10px;
      }

      .tag-ebm {
        background: linear-gradient(90deg, #2bbfa8, #6dd4a0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .tag-dct {
        background: linear-gradient(90deg, #e8782a, #f5b731);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .tag-irm {
        background: linear-gradient(90deg, #444561, #8e8fc8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .tag-gen {
        background: linear-gradient(90deg, #247b96, #3fafc8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .work-card h3 {
        font-size: 15px;
        font-weight: 400;
        color: var(--black);
        line-height: 1.4;
        margin-bottom: 8px;
      }

      .work-card p {
        font-size: 12.5px;
        color: var(--gray-mid);
        line-height: 1.65;
        margin-bottom: 18px;
        flex: 1;
      }

      .work-read-more {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 6px 14px;
        border-radius: 100px;
        margin-top: auto;
        border: 1.5px solid transparent;
        transition:
          opacity var(--tr),
          gap var(--tr);
        align-self: flex-start;
      }

      .work-read-more:hover {
        opacity: 0.75;
        gap: 8px;
      }

      .read-ebm {
        color: #2bbfa8;
        border-color: #2bbfa8;
      }
      .read-dct {
        color: #e8782a;
        border-color: #e8782a;
      }
      .read-irm {
        color: #5b5c8c;
        border-color: #5b5c8c;
      }
      .read-gen {
        color: #247b96;
        border-color: #247b96;
      }

      /* ── Featured Case Study ── */
      .featured-section {
        background: var(--light-blue);
        padding: 56px 48px 80px;
      }

      .featured-section-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gray-light);
        margin-bottom: 24px;
        display: block;
      }

      .featured-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        transition: box-shadow var(--tr);
      }

      .featured-card:hover {
        box-shadow: 0 12px 48px rgba(0, 0, 0, 0.1);
      }

      .featured-img {
        height: 100%;
        min-height: 320px;
        overflow: hidden;
      }

      .featured-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.5s ease;
      }

      .featured-card:hover .featured-img img {
        transform: scale(1.03);
      }

      .featured-body {
        padding: 48px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .featured-tag {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 16px;
      }

      .featured-body h3 {
        font-size: clamp(22px, 3vw, 32px);
        font-weight: 300;
        letter-spacing: -0.02em;
        color: var(--black);
        margin-bottom: 14px;
        line-height: 1.2;
      }

      .featured-body p {
        font-size: 14px;
        color: var(--gray-mid);
        line-height: 1.75;
        margin-bottom: 28px;
      }

      .featured-outcomes {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 28px;
      }

      .featured-outcome {
        font-size: 11px;
        font-weight: 600;
        padding: 5px 12px;
        border-radius: 100px;
        border: 1px solid var(--border);
        color: var(--gray-mid);
        background: var(--light-blue);
      }

      .btn-case {
        font-family: var(--font);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: gap var(--tr);
        color: var(--purple);
      }

      .btn-case:hover {
        gap: 10px;
      }

      /* ── CTA Band ── */
      .cta-band {
        background: linear-gradient(135deg, var(--blue) 0%, var(--purple) 100%);
        color: var(--white);
        padding: 80px 48px;
        text-align: center;
        position: relative;
        overflow: hidden;
      }

      .cta-band::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(
            circle at 25% 40%,
            rgba(255, 255, 255, 0.07) 0%,
            transparent 50%
          ),
          radial-gradient(
            circle at 80% 70%,
            rgba(255, 255, 255, 0.05) 0%,
            transparent 45%
          );
        pointer-events: none;
      }

      .cta-band .container {
        position: relative;
        z-index: 1;
      }

      .cta-band h2 {
        font-size: clamp(28px, 4.5vw, 52px);
        font-weight: 300;
        letter-spacing: -0.02em;
        margin-bottom: 16px;
      }

      .cta-band p {
        font-size: 16px;
        color: rgba(255, 255, 255, 0.68);
        max-width: 520px;
        margin: 0 auto 38px;
        line-height: 1.72;
      }

      .cta-band-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        flex-wrap: wrap;
      }

      .btn-white-solid {
        font-family: var(--font);
        font-size: 14px;
        font-weight: 600;
        padding: 13px 30px;
        border-radius: var(--radius);
        border: none;
        cursor: pointer;
        background: var(--white);
        color: var(--blue);
        transition: all var(--tr);
        display: inline-block;
      }

      .btn-white-solid:hover {
        background: var(--light-blue);
        transform: translateY(-1px);
      }

      .btn-white-ghost {
        font-family: var(--font);
        font-size: 14px;
        font-weight: 500;
        padding: 12px 30px;
        border-radius: var(--radius);
        border: 1.5px solid rgba(255, 255, 255, 0.45);
        cursor: pointer;
        color: var(--white);
        background: transparent;
        transition: all var(--tr);
        display: inline-block;
      }

      .btn-white-ghost:hover {
        border-color: rgba(255, 255, 255, 0.9);
        background: rgba(255, 255, 255, 0.1);
      }

      /* ── Responsive ── */
      @media (max-width: 960px) {
        .page-hero,
        .featured-section,
        .work-section,
        .cta-band {
          padding: 56px 24px;
        }

        .filter-bar {
          padding: 0 24px;
        }

        .work-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .featured-card {
          grid-template-columns: 1fr;
        }

        .featured-img {
          min-height: 240px;
        }
      }

      @media (max-width: 768px) {
        .work-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 600px) {
        .cta-band-actions {
          flex-direction: column;
        }

        .btn-white-solid,
        .btn-white-ghost {
          width: 100%;
          text-align: center;
        }
      }
    </style>
  </body>
</html>
