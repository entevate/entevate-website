---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.jsx";
import Footer from "../components/Footer.jsx";
import "../global.css";

const title = "Our Work — ENTEVATE";
const description =
  "Real engagements, tangible outcomes, and thinking from the frontier of experiential branding, digital transformation, and innovation strategy.";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Our Work",
  "description": description,
  "url": "https://www.entevate.com/our-work",
  "mainEntity": {
    "@type": "ItemList",
    "name": "ENTEVATE Case Studies & Insights",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "url": "https://www.entevate.com/experiential/fortune-500-trade-show" },
      { "@type": "ListItem", "position": 2, "url": "https://www.entevate.com/innovation/energy-innovation-lab" },
      { "@type": "ListItem", "position": 3, "url": "https://www.entevate.com/innovation/trinity-aiqui-sandbox" }
    ]
  }
});
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header client:load />

  <!-- ═══════════════════════════ PAGE HERO ═══════════════════════════ -->
  <div class="page-hero">
    <div class="hero-svg-bg">
      <svg
        viewBox="0 0 1440 800"
        preserveAspectRatio="xMidYMid slice"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          class="curve-1"
          d="M 180 -80 C 180 -80 60 140 60 300 C 60 460 180 540 180 720 C 180 800 130 860 130 860"
          stroke="white"
          stroke-width="5"
          stroke-linecap="round"
          opacity="0.30"></path>
        <path
          class="curve-2"
          d="M 420 -100 C 420 -100 230 160 230 330 C 230 500 420 600 420 760 C 420 840 360 900 360 900"
          stroke="white"
          stroke-width="5.5"
          stroke-linecap="round"
          opacity="0.40"></path>
        <path
          class="curve-3"
          d="M 790 -120 C 790 -120 490 200 490 400 C 490 600 790 730 790 920"
          stroke="white"
          stroke-width="6"
          stroke-linecap="round"
          opacity="0.50"></path>
        <path
          class="curve-4"
          d="M 1080 -80 C 1080 -80 780 220 780 420 C 780 620 1080 760 1080 940"
          stroke="white"
          stroke-width="5"
          stroke-linecap="round"
          opacity="0.35"></path>
        <path
          class="curve-5"
          d="M 1320 -60 C 1320 -60 1060 240 1060 440 C 1060 640 1320 780 1320 960"
          stroke="white"
          stroke-width="4"
          stroke-linecap="round"
          opacity="0.25"></path>
      </svg>
    </div>
    <div class="page-hero-inner">
      <div class="fade-up">
        <div class="section-label">Our Work</div>
        <h1>Insights, case studies &amp; perspectives.</h1>
        <p>
          Real engagements, tangible outcomes, and thinking from the frontier of
          experiential branding, digital transformation, and innovation
          strategy.
        </p>
        <div class="hero-actions">
          <a href="#case-studies" class="btn-primary">View Case Studies →</a>
          <a href="#insights" class="btn-ghost">Read Insights →</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════ FEATURED CASE STUDY ═══════════════════════════ -->
  <div class="featured-section" id="case-studies">
    <div class="container">
      <span class="featured-section-label">Featured Case Study</span>

      <a href="/innovation/trinity-aiqui-sandbox" class="featured-card fade-up">
        <div class="featured-img">
          <img src="/images/trinity.jpg" alt="Trinity College AIQUI Sandbox" />
        </div>
        <div class="featured-body">
          <div class="featured-tag tag-irm">
            Innovation · Higher Education · AI &amp; Quantum
          </div>
          <h3>Trinity College AIQUI Sandbox:<br />Applied AI &amp; Quantum Innovation</h3>
          <p>
            Trinity College engaged ENTEVATE to design and facilitate an applied
            AI and quantum innovation environment grounded in the AIQUI
            framework. Working across academic, research, and industry
            stakeholders, ENTEVATE mapped the full innovation ecosystem using
            the 7 Core Elements Basecamps™.
          </p>
          <div class="featured-outcomes">
            <div class="featured-outcome">AIQUI Framework Applied</div>
            <div class="featured-outcome">7 Basecamps™ Mapped</div>
            <div class="featured-outcome">Multi-Stakeholder Alignment</div>
            <div class="featured-outcome">Innovation Sandbox Deployed</div>
          </div>
          <span class="btn-case">Read Case Study →</span>
        </div>
      </a>
    </div>
  </div>

  <!-- Filter Bar -->
  <div class="filter-bar">
    <div class="filter-inner">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="experiential">Experiential</button
      >
      <button class="filter-btn" data-filter="transformation"
        >Transformation</button
      >
      <button class="filter-btn" data-filter="innovation">Innovation</button>
      <button class="filter-btn" data-filter="case-study">Case Studies</button>
      <button class="filter-btn" data-filter="insight">Insights</button>
    </div>
  </div>

  <!-- ═══════════════════════════ WORK GRID ═══════════════════════════ -->
  <div class="work-section" id="insights">
    <div class="container">
      <span class="work-section-label">Case Studies &amp; Insights</span>

      <div class="work-grid">
        <!-- Card: Trinity AIQUI Sandbox -->
        <a
          href="/innovation/trinity-aiqui-sandbox"
          class="work-card card-irm fade-up"
          data-category="innovation case-study"
        >
          <div class="work-thumb"><div class="work-thumb-bg bt-trinity"></div></div>
          <div class="work-body">
            <div class="work-tag tag-irm">
              Innovation | Ventures | Ecosystem
            </div>
            <h3>Trinity College AIQUI Sandbox: Applied AI &amp; Quantum Innovation</h3>
            <p>
              How ENTEVATE designed an applied AI and quantum innovation
              environment using the AIQUI framework at Trinity College.
            </p>
            <div class="work-read-more read-irm">Read Case Study →</div>
          </div>
        </a>

        <!-- Card 2: CAD to CGI -->
        <a
          href="/operational-intelligence/cad-to-cgi"
          class="work-card card-dct fade-up"
          data-category="transformation case-study"
        >
          <div class="work-thumb"><div class="work-thumb-bg bt2"></div></div>
          <div class="work-body">
            <div class="work-tag tag-dct">
              Operational Intelligence
            </div>
            <h3>The Power of CAD-to-CGI Conversion for Engineering</h3>
            <p>
              How converting complex CAD data into photorealistic CGI is
              unlocking new possibilities for engineering visualization,
              product marketing, and immersive storytelling.
            </p>
            <div class="work-read-more read-dct">Read More →</div>
          </div>
        </a>

        <!-- Card 3: AR/VR Revenue Growth -->
        <a
          href="/insights/beyond-the-hype-ar-vr-revenue"
          class="work-card card-ebm fade-up"
          data-category="experiential insight"
        >
          <div class="work-thumb"><div class="work-thumb-bg bt1"></div></div>
          <div class="work-body">
            <div class="work-tag tag-ebm">
              Experiential Branding &amp; Marketing
            </div>
            <h3>
              Beyond the Hype: AR/VR/Spatial Computing Fueling Real Revenue
              Growth
            </h3>
            <p>
              The concrete business outcomes that immersive technologies are
              delivering for forward-thinking brands and enterprises today.
            </p>
            <div class="work-read-more read-ebm">Read More →</div>
          </div>
        </a>

        <!-- Card 4: Energy Innovation Lab -->
        <a
          href="/innovation/energy-innovation-lab"
          class="work-card card-irm fade-up"
          data-category="innovation case-study"
        >
          <div class="work-thumb"><div class="work-thumb-bg bt3"></div></div>
          <div class="work-body">
            <div class="work-tag tag-irm">
              Innovation | Ventures | Ecosystem
            </div>
            <h3>Energy Innovation Lab: From Concept to Capital Pipeline</h3>
            <p>
              How ENTEVATE designed and launched an internal innovation lab
              for a leading energy organization, connecting ideas to capital
              readiness.
            </p>
            <div class="work-read-more read-irm">Read More →</div>
          </div>
        </a>

        <!-- Card 5: AIQUI Framework -->
        <a
          href="/innovation/aiqui"
          class="work-card card-irm fade-up"
          data-category="innovation insight"
        >
          <div class="work-thumb"><div class="work-thumb-bg bt3"></div></div>
          <div class="work-body">
            <div class="work-tag tag-irm">
              Innovation | Ventures | Ecosystem
            </div>
            <h3>AIQUI: Applied Innovation for AI &amp; Quantum Technologies</h3>
            <p>
              ENTEVATE's structured ecosystem model for organizations building
              applied capabilities in artificial intelligence and quantum
              technologies.
            </p>
            <div class="work-read-more read-irm">Explore Framework →</div>
          </div>
        </a>

        <!-- Card 6: Trade Show Transformation -->
        <a
          href="/experiential/fortune-500-trade-show"
          class="work-card card-ebm fade-up"
          data-category="experiential case-study"
        >
          <div class="work-thumb"><div class="work-thumb-bg bt1"></div></div>
          <div class="work-body">
            <div class="work-tag tag-ebm">
              Experiential Branding &amp; Marketing
            </div>
            <h3>Fortune 500 Trade Show Transformation with AR Activation</h3>
            <p>
              How an immersive, multi-zone exhibit featuring AR activations and
              real-time engagement tracking tripled visitor dwell time at a
              major industrial trade show.
            </p>
            <div class="work-read-more read-ebm">Read More →</div>
          </div>
        </a>

        <!-- Card 7: Innovation Roadmapping Insight -->
        <a
          href="/insights/innovation-roadmapping"
          class="work-card card-irm fade-up"
          data-category="innovation insight"
        >
          <div class="work-thumb"><div class="work-thumb-bg bt3"></div></div>
          <div class="work-body">
            <div class="work-tag tag-irm">
              Innovation | Ventures | Ecosystem
            </div>
            <h3>
              Innovation Roadmapping: Navigating from Ideation to Amplification
            </h3>
            <p>
              A practical guide to navigating the full innovation lifecycle —
              from early-stage ideation and validation through amplification,
              market scale, and long-term growth.
            </p>
            <div class="work-read-more read-irm">Read More →</div>
          </div>
        </a>

        <!-- Card 8: Beyond the Buzz — Holistic AR/VR Strategy -->
        <a
          href="/insights/beyond-the-buzz-ar-vr-strategy"
          class="work-card card-ebm fade-up"
          data-category="experiential insight"
        >
          <div class="work-thumb"><div class="work-thumb-bg bt1"></div></div>
          <div class="work-body">
            <div class="work-tag tag-ebm">
              Experiential Branding &amp; Marketing
            </div>
            <h3>
              Beyond the Buzz: Building a Holistic AR/VR/Spatial Strategy for
              Real Business Impact
            </h3>
            <p>
              Why a holistic AR/VR/spatial computing strategy delivers lasting
              business impact — moving beyond novelty toward sustained,
              measurable results.
            </p>
            <div class="work-read-more read-ebm">Read More →</div>
          </div>
        </a>

        <!-- Card 9: Trade Show Hacks -->
        <a
          href="/insights/trade-show-hacks"
          class="work-card card-ebm fade-up"
          data-category="experiential insight"
        >
          <div class="work-thumb"><div class="work-thumb-bg bt1"></div></div>
          <div class="work-body">
            <div class="work-tag tag-ebm">
              Experiential Branding &amp; Marketing
            </div>
            <h3>
              Trade Show Hacks: How to Rise Above the Noise and Engage Users
            </h3>
            <p>
              Ten actionable strategies from the trade show floor to help your
              brand rise above the noise, boost engagement, and leave a lasting
              impression on attendees.
            </p>
            <div class="work-read-more read-ebm">Read More →</div>
          </div>
        </a>

        <!-- Card 10: Finding Your Perfect Match -->
        <a
          href="/insights/finding-your-perfect-match"
          class="work-card card-gen fade-up"
          data-category="insight"
        >
          <div class="work-thumb">
            <div class="work-thumb-bg bt-blue"></div>
          </div>
          <div class="work-body">
            <div class="work-tag tag-gen">Digital Innovation</div>
            <h3>
              Finding Your Perfect Match: Partnering for Digital Innovation
              Success
            </h3>
            <p>
              How the right expert partnerships accelerate digital innovation
              — and the critical questions to ask before you commit.
            </p>
            <div class="work-read-more read-gen">Read More →</div>
          </div>
        </a>

        <!-- Card 11: Stepping Into a World of Wow -->
        <a
          href="/insights/stepping-into-a-world-of-wow"
          class="work-card card-ebm fade-up"
          data-category="experiential insight"
        >
          <div class="work-thumb"><div class="work-thumb-bg bt1"></div></div>
          <div class="work-body">
            <div class="work-tag tag-ebm">
              Experiential Branding &amp; Marketing
            </div>
            <h3>
              Stepping Into a World of "Wow": How Digital Innovation Drives
              Unique Customer Experiences
            </h3>
            <p>
              How digital innovation transforms ordinary transactions into
              compelling customer experiences through AR/VR, AI, and
              personalization.
            </p>
            <div class="work-read-more read-ebm">Read More →</div>
          </div>
        </a>

        <!-- Card 12: Conquering the Tech Challenge -->
        <a
          href="/insights/conquering-the-tech-challenge"
          class="work-card card-gen fade-up"
          data-category="insight"
        >
          <div class="work-thumb">
            <div class="work-thumb-bg bt-blue"></div>
          </div>
          <div class="work-body">
            <div class="work-tag tag-gen">Digital Innovation</div>
            <h3>
              Conquering the Tech Challenge: Your Actionable Checklist for
              Navigating AR, VR, and AI
            </h3>
            <p>
              A practical, step-by-step checklist for leveraging artificial
              intelligence, augmented reality, and virtual reality to navigate
              today's evolving tech landscape and drive growth.
            </p>
            <div class="work-read-more read-gen">Read More →</div>
          </div>
        </a>

        <!-- Card 13: Surfing the Tsunami -->
        <a
          href="/insights/surfing-the-tsunami"
          class="work-card card-gen fade-up"
          data-category="insight"
        >
          <div class="work-thumb">
            <div class="work-thumb-bg bt-blue"></div>
          </div>
          <div class="work-body">
            <div class="work-tag tag-gen">Digital Innovation</div>
            <h3>
              Surfing the Tsunami: A 2023 Digital Disruption Retrospective
            </h3>
            <p>
              A retrospective on the five major technological shifts that
              defined 2023 — from AI's explosion to the rise of the metaverse.
            </p>
            <div class="work-read-more read-gen">Read More →</div>
          </div>
        </a>

        <!-- Card 14: Launch Day Announcement -->
        <a
          href="/insights/launch-day-announcement"
          class="work-card card-gen fade-up"
          data-category="insight"
        >
          <div class="work-thumb">
            <div class="work-thumb-bg bt-blue"></div>
          </div>
          <div class="work-body">
            <div class="work-tag tag-gen">Announcement</div>
            <h3>Launch Day: ENTEVATE Is Here</h3>
            <p>
              Introducing ENTEVATE — a human-centered innovation partner on a
              mission to make innovation understandable, impactful, and
              accessible to organizations of every size.
            </p>
            <div class="work-read-more read-gen">Read More →</div>
          </div>
        </a>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════ CTA BAND ═══════════════════════════ -->
  <section class="cta-band" id="contact">
    <div class="container">
      <div class="fade-up">
        <h2>Ready to Create Your Own Case Study?</h2>
        <p>Let's build something together — and make it worth writing about.</p>
        <div class="cta-band-actions">
          <a href="/contact" class="btn-white-solid">Start a Conversation</a>
          <a href="/about" class="btn-white-ghost">About ENTEVATE →</a>
        </div>
      </div>
    </div>
  </section>

  <Footer client:load />

  <script src="../global.js"></script>
  <script>
    window.onload = () => {
      staggerFadeIn(".work-grid .fade-up");
    };

    // Filter tabs (basic show/hide)
    const filterBtns = document.querySelectorAll(".filter-btn");
    const workCards = document.querySelectorAll(".work-grid .work-card");
    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        filterBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        const filter = btn.dataset.filter;
        workCards.forEach((card) => {
          if (
            filter === "all" ||
            (card.dataset.category || "").includes(filter)
          ) {
            card.style.display = "flex";
          } else {
            card.style.display = "none";
          }
        });
      });
    });
  </script>

  <style>
    /* ── Page Hero ── */
    .page-hero {
      background: var(--light-blue);
      position: relative;
      overflow: hidden;
      padding: 96px 48px 80px;
      border-bottom: 1px solid var(--border);
    }

    .page-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(
          circle at 70% 30%,
          rgba(36, 123, 150, 0.1) 0%,
          transparent 55%
        ),
        radial-gradient(
          circle at 25% 80%,
          rgba(61, 151, 138, 0.07) 0%,
          transparent 50%
        );
    }

    /* Animated SVG curves (match home hero) */
    .hero-svg-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
      pointer-events: none;
      overflow: hidden;
    }

    .hero-svg-bg svg {
      width: 100%;
      height: 100%;
      position: absolute;
      inset: 0;
    }

    .curve-1 {
      animation: drift1 8s ease-in-out infinite alternate;
      transform-origin: 50% 50%;
    }
    .curve-2 {
      animation: drift2 10s ease-in-out infinite alternate;
      transform-origin: 50% 50%;
    }
    .curve-3 {
      animation: drift3 12s ease-in-out infinite alternate;
      transform-origin: 50% 50%;
    }
    .curve-4 {
      animation: drift1 9s ease-in-out infinite alternate-reverse;
      transform-origin: 50% 50%;
    }
    .curve-5 {
      animation: drift2 11s ease-in-out infinite alternate-reverse;
      transform-origin: 50% 50%;
    }

    @keyframes drift1 {
      from {
        transform: translateY(-28px) translateX(0px) scaleY(1);
      }
      to {
        transform: translateY(28px) translateX(8px) scaleY(1.04);
      }
    }

    @keyframes drift2 {
      from {
        transform: translateY(20px) translateX(-6px) scaleY(0.97);
      }
      to {
        transform: translateY(-32px) translateX(10px) scaleY(1.04);
      }
    }

    @keyframes drift3 {
      from {
        transform: translateY(-16px) translateX(4px) scaleY(1.02);
      }
      to {
        transform: translateY(36px) translateX(-8px) scaleY(0.96);
      }
    }

    .page-hero-inner {
      max-width: 1160px;
      margin: 0 auto;
      position: relative;
      z-index: 2;
    }

    .page-hero .section-label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 14px;
      color: var(--blue);
    }

    .page-hero h1 {
      font-size: clamp(30px, 6vw, 62px);
      font-weight: 100;
      letter-spacing: -0.03em;
      line-height: 1.06;
      color: var(--black);
      margin-bottom: 18px;
      max-width: 760px;
    }

    .page-hero p {
      font-size: 16px;
      color: var(--gray-mid);
      max-width: 580px;
      line-height: 1.75;
      margin-bottom: 32px;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .btn-primary {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 11px 24px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: var(--blue);
      color: var(--white);
      transition: all var(--tr);
      display: inline-block;
    }

    .btn-primary:hover {
      background: var(--purple);
      transform: translateY(-1px);
    }

    .btn-ghost {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 500;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--blue);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: gap var(--tr);
    }

    .btn-ghost:hover {
      gap: 9px;
    }

    /* ── Filter Tabs ── */
    .filter-bar {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 0 48px;
      position: sticky;
      top: 70px;
      z-index: 90;
    }

    .filter-inner {
      max-width: 1160px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 4px;
      overflow-x: auto;
      padding: 14px 0;
      scrollbar-width: none;
    }

    .filter-inner::-webkit-scrollbar {
      display: none;
    }

    .filter-btn {
      font-family: var(--font);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.04em;
      padding: 7px 16px;
      border-radius: 100px;
      border: 1.5px solid var(--border);
      background: transparent;
      color: var(--gray-mid);
      cursor: pointer;
      white-space: nowrap;
      transition: all var(--tr);
    }

    .filter-btn:hover {
      border-color: var(--blue);
      color: var(--blue);
    }

    .filter-btn.active {
      background: var(--blue);
      border-color: var(--blue);
      color: var(--white);
    }

    /* ── Work Grid ── */
    .work-section {
      padding: 56px 48px 80px;
      background: var(--white);
    }

    .work-section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gray-light);
      margin-bottom: 24px;
      display: block;
    }

    .work-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .work-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      transition:
        box-shadow var(--tr),
        transform var(--tr);
      display: flex;
      flex-direction: column;
    }

    .work-card:hover {
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
      transform: translateY(-3px);
    }

    .work-thumb {
      height: 185px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    .work-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.5s ease;
    }

    .work-card:hover .work-thumb img {
      transform: scale(1.04);
    }

    .work-thumb-bg {
      width: 100%;
      height: 100%;
      background-size: cover;
      background-position: center;
      transition: transform 0.5s ease;
    }

    .work-card:hover .work-thumb-bg {
      transform: scale(1.04);
    }

