---
import Header from '../../components/Header.jsx';
import Footer from '../../components/Footer.jsx';
import '../../global.css';

const title = 'Innovation | Ventures | Ecosystem — ENTEVATE';
const description = 'ENTEVATE co-creates actionable innovation roadmaps that move ecosystems, ventures, and teams from ideation through amplification — with clarity at every stage.';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <Header client:load />
  
  <!-- ═══════════════════════════ HERO ═══════════════════════════ -->
  <section class="hero" id="top">
    <div class="hero-inner">
      <div class="fade-up">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>
          Innovation | Ventures | Ecosystem
        </div>
        <h1>From Bold Idea to <span class="accent">Lasting Outcome.</span></h1>
        <p class="hero-sub">ENTEVATE co-creates actionable innovation roadmaps that move ecosystems, ventures, and teams from ideation through amplification — with clarity at every stage.</p>
        <div class="hero-actions">
          <a href="/contact?service=innovation" class="btn-blue">Start Your Roadmap →</a>
          <a href="#journey" class="btn-ghost-dark">View the 8-Stage Journey ↓</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ 8-STAGE JOURNEY ═══════════════════════════ -->
  <section class="journey-section" id="journey">
    <div class="container">
      <div class="journey-header fade-up">
        <div class="section-label">Innovation Roadmapping™</div>
        <h2 class="section-title">Navigating from Ideation Through Amplification</h2>
        <p class="section-subtitle">Eight proven stages that carry your idea from spark to sustained, scalable impact — with structure and accountability at every waypoint.</p>
      </div>
    </div>

    <div class="journey-outer">
      <div class="journey-wrap" id="journeyScroll">
        <div class="journey-track">

          <!-- Stage 1 -->
          <div class="journey-step fade-up">
            <div class="journey-num c-blue">
              <span class="step-n">1</span>
              <span class="step-s">Stage</span>
            </div>
            <div class="journey-content">
              <div class="journey-step-name">Ideation</div>
              <div class="journey-step-desc">Surface and screen ideas through brainstorming, crowdsourcing, and exploration.</div>
            </div>
          </div>

          <!-- Stage 2 -->
          <div class="journey-step fade-up">
            <div class="journey-num c-green">
              <span class="step-n">2</span>
              <span class="step-s">Stage</span>
            </div>
            <div class="journey-content">
              <div class="journey-step-name">Validation</div>
              <div class="journey-step-desc">Confirm feasibility, market fit, and demand through research and customer discovery.</div>
            </div>
          </div>

          <!-- Stage 3 -->
          <div class="journey-step fade-up">
            <div class="journey-num c-purple">
              <span class="step-n">3</span>
              <span class="step-s">Stage</span>
            </div>
            <div class="journey-content">
              <div class="journey-step-name">Curation</div>
              <div class="journey-step-desc">Refine the idea and shape a clear, stakeholder-aligned business case.</div>
            </div>
          </div>

          <!-- Stage 4 -->
          <div class="journey-step fade-up">
            <div class="journey-num c-orange-l">
              <span class="step-n">4</span>
              <span class="step-s">Stage</span>
            </div>
            <div class="journey-content">
              <div class="journey-step-name">Innovation</div>
              <div class="journey-step-desc">Build and test an MVP in a real-world setting, iterating on data and learnings.</div>
            </div>
          </div>

          <!-- Stage 5 -->
          <div class="journey-step fade-up">
            <div class="journey-num c-blue">
              <span class="step-n">5</span>
              <span class="step-s">Stage</span>
            </div>
            <div class="journey-content">
              <div class="journey-step-name">Operation</div>
              <div class="journey-step-desc">Define team structure, roles, and processes for reliable ongoing operations.</div>
            </div>
          </div>

          <!-- Stage 6 -->
          <div class="journey-step fade-up">
            <div class="journey-num c-green">
              <span class="step-n">6</span>
              <span class="step-s">Stage</span>
            </div>
            <div class="journey-content">
              <div class="journey-step-name">Amplification</div>
              <div class="journey-step-desc">Drive adoption through targeted communication and feedback loops that expand reach.</div>
            </div>
          </div>

          <!-- Stage 7 -->
          <div class="journey-step fade-up">
            <div class="journey-num c-purple">
              <span class="step-n">7</span>
              <span class="step-s">Stage</span>
            </div>
            <div class="journey-content">
              <div class="journey-step-name">Acceleration</div>
              <div class="journey-step-desc">Scale to full potential through performance optimization and strategic partnerships.</div>
            </div>
          </div>

          <!-- Stage 8 -->
          <div class="journey-step fade-up">
            <div class="journey-num c-orange-l">
              <span class="step-n">8</span>
              <span class="step-s">Stage</span>
            </div>
            <div class="journey-content">
              <div class="journey-step-name">Harvest</div>
              <div class="journey-step-desc">Sustain and compound value from a scaled innovation performing at its peak.</div>
            </div>
          </div>

        </div><!-- .journey-track -->
      </div><!-- .journey-wrap -->
      <div class="journey-hint">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Scroll to explore all 8 stages
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ CORE OFFERINGS ═══════════════════════════ -->
  <section class="offerings-section" id="offerings">
    <div class="container">
      <div class="fade-up">
        <div class="section-label">What We Deliver</div>
        <h2 class="section-title">Four structured engagement tracks.</h2>
        <p class="section-subtitle">Choose one or combine them — each track is designed to work independently or as part of a fully integrated innovation engagement.</p>
      </div>

      <div class="offerings-grid">

        <!-- Card 1: Ecosystem Model -->
        <div class="offering-card oc-green fade-up">
          <div class="offering-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M12 2l8.66 5v10L12 22l-8.66-5V7L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
              <path d="M12 2v10M3.34 7l8.66 5M20.66 7l-8.66 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" opacity="0.5"/>
            </svg>
          </div>
          <h3>Ecosystem Model: 7 Core Elements™</h3>
          <em>Map your full innovation ecosystem.</em>
          <p>We assess your ecosystem across seven interconnected basecamps: Policy/Advocacy, Research &amp; Innovation Development, Real Estate/Infrastructure/Placemaking, Economic Development, Workforce Development, Venture Development, and Social/Community/Accessibility. Every layer is evaluated, gap-analyzed, and roadmapped.</p>
          <a href="/innovation/ecosystem-model" class="offering-cta">Explore the Model →</a>
        </div>

        <!-- Card 2: Innovation Sandbox -->
        <div class="offering-card oc-orange-light fade-up">
          <div class="offering-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M9 3h6M10 3v6L6 18h12L14 9V3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M6.5 15h11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              <circle cx="15" cy="12" r="1" fill="currentColor"/>
              <circle cx="10" cy="16" r="1" fill="currentColor"/>
            </svg>
          </div>
          <h3>Innovation Sandbox™</h3>
          <em>Start small. Learn fast. Scale with confidence.</em>
          <p>A contained, low-risk environment to prototype and test your most promising ideas before full deployment. We design the sandbox, run facilitated sessions, and deliver a validated signal for what to build next.</p>
          <a href="/innovation/innovation-sandbox" class="offering-cta">Run a Sandbox →</a>
        </div>

        <!-- Card 3: Innovation Roadmapping + Venture Development -->
        <div class="offering-card oc-blue fade-up">
          <div class="offering-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M3 5v14l5-3 8 3 5-3V2l-5 3-8-3-5 3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
              <path d="M8 2v14M16 5v14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" opacity="0.55"/>
            </svg>
          </div>
          <h3>Innovation Roadmapping™ + Venture Development</h3>
          <em>Strategy meets execution.</em>
          <p>We build structured, milestone-driven innovation roadmaps aligned to your organization's goals — then stay with you through venture development to bring those milestones to life.</p>
          <a href="/innovation/roadmapping" class="offering-cta">Build Your Roadmap →</a>
        </div>

        <!-- Card 4: Sideline Capital Activation -->
        <div class="offering-card oc-orange-dark fade-up">
          <div class="offering-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M12 2v20M17 5H9.5a3.5 3.5 0 100 7h5a3.5 3.5 0 110 7H6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Sideline Capital Activation</h3>
          <em>Angel Academy™ | Innovation Funding Lab®</em>
          <p>Connecting innovators with capital through curated angel investor networks, funding readiness programming, and the Innovation Funding Lab® — a hands-on track for ventures preparing to raise.</p>
          <a href="/innovation/sideline-capital" class="offering-cta">Activate Capital →</a>
        </div>

      </div><!-- .offerings-grid -->
    </div>
  </section>

  <!-- ═══════════════════════════ AIQUI SPOTLIGHT ═══════════════════════════ -->
  <section class="aiqui-section" id="aiqui">
    <div class="aiqui-inner">

      <!-- Left: Text block -->
      <div class="aiqui-left fade-up">
        <span class="aiqui-eyebrow">Featured Framework</span>
        <h2>AIQUI: An Ecosystem Model for Applied AI + Quantum Innovation</h2>
        <p>AIQUI is ENTEVATE's applied framework for organizations building at the frontier of AI and quantum technologies. Using the 7 Core Elements Basecamps™ model, AIQUI maps the full innovation landscape — from policy and research to workforce, venture development, and community access.</p>
        <a href="/innovation/aiqui" class="btn-green">Explore AIQUI →</a>
      </div>

      <!-- Right: Hexagon cluster SVG -->
      <div class="aiqui-hex-wrap fade-up">
        <svg viewBox="50 80 415 360" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="AIQUI 7 Core Elements hexagon cluster">
          <defs>
            <!-- Center: Venture Development — teal green -->
            <linearGradient id="g-center" x1="198" y1="195" x2="302" y2="315" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#3D978A"/>
              <stop offset="100%" stop-color="#72D4C5"/>
            </linearGradient>
            <!-- E: Economic Development — slate gray -->
            <linearGradient id="g-e" x1="312" y1="195" x2="416" y2="315" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#7A7A7A"/>
              <stop offset="100%" stop-color="#C0C0C0"/>
            </linearGradient>
            <!-- NE: Policy / Advocacy — indigo purple -->
            <linearGradient id="g-ne" x1="255" y1="96" x2="359" y2="216" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#444561"/>
              <stop offset="100%" stop-color="#8E8FC8"/>
            </linearGradient>
            <!-- NW: Research / Innovation Development — cyan blue -->
            <linearGradient id="g-nw" x1="141" y1="96" x2="245" y2="216" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#247B96"/>
              <stop offset="100%" stop-color="#4DC8E0"/>
            </linearGradient>
            <!-- W: Social / Community / Accessibility — amber -->
            <linearGradient id="g-w" x1="84" y1="195" x2="188" y2="315" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#EA9709"/>
              <stop offset="100%" stop-color="#F5C842"/>
            </linearGradient>
            <!-- SW: Real Estate / Infrastructure / Placemaking — burnt orange -->
            <linearGradient id="g-sw" x1="141" y1="294" x2="245" y2="414" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#CB632F"/>
              <stop offset="100%" stop-color="#F09550"/>
            </linearGradient>
            <!-- SE: Workforce Development — crimson red -->
            <linearGradient id="g-se" x1="255" y1="294" x2="359" y2="414" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#C0392B"/>
              <stop offset="100%" stop-color="#E87060"/>
            </linearGradient>
          </defs>

          <!-- ── Center: Venture Development ── -->
          <polygon
            points="250,195 301.96,225 301.96,285 250,315 198.04,285 198.04,225"
            fill="rgba(61,151,138,0.07)" stroke="url(#g-center)" stroke-width="2"/>
          <text text-anchor="middle" font-family="Archivo,system-ui,sans-serif" fill="#72D4C5">
            <tspan x="250" y="249" font-size="9">Venture</tspan>
            <tspan x="250" y="262" font-size="9">Development</tspan>
          </text>

          <!-- ── E: Economic Development ── -->
          <polygon
            points="364,195 415.96,225 415.96,285 364,315 312.04,285 312.04,225"
            fill="rgba(120,120,120,0.06)" stroke="url(#g-e)" stroke-width="2"/>
          <text text-anchor="middle" font-family="Archivo,system-ui,sans-serif" fill="#C0C0C0">
            <tspan x="364" y="249" font-size="9">Economic</tspan>
            <tspan x="364" y="261" font-size="9">Development</tspan>
          </text>

          <!-- ── NE: Policy / Advocacy ── -->
          <polygon
            points="307,96 358.96,126 358.96,186 307,216 255.04,186 255.04,126"
            fill="rgba(68,69,97,0.08)" stroke="url(#g-ne)" stroke-width="2"/>
          <text text-anchor="middle" font-family="Archivo,system-ui,sans-serif" fill="#AAABCC">
            <tspan x="307" y="150" font-size="9">Policy /</tspan>
            <tspan x="307" y="163" font-size="9">Advocacy</tspan>
          </text>

          <!-- ── NW: Research / Innovation Development ── -->
          <polygon
            points="193,96 244.96,126 244.96,186 193,216 141.04,186 141.04,126"
            fill="rgba(36,123,150,0.08)" stroke="url(#g-nw)" stroke-width="2"/>
          <text text-anchor="middle" font-family="Archivo,system-ui,sans-serif" fill="#6FDCEF">
            <tspan x="193" y="150" font-size="9">Research /</tspan>
            <tspan x="193" y="163" font-size="9">Innovation Dev.</tspan>
          </text>

          <!-- ── W: Social / Community / Accessibility ── -->
          <polygon
            points="136,195 187.96,225 187.96,285 136,315 84.04,285 84.04,225"
            fill="rgba(234,151,9,0.08)" stroke="url(#g-w)" stroke-width="2"/>
          <text text-anchor="middle" font-family="Archivo,system-ui,sans-serif" fill="#F5C842">
            <tspan x="136" y="249" font-size="9">Social /</tspan>
            <tspan x="136" y="262" font-size="9">Community</tspan>
          </text>

          <!-- ── SW: Real Estate / Infrastructure / Placemaking ── -->
          <polygon
            points="193,294 244.96,324 244.96,384 193,414 141.04,384 141.04,324"
            fill="rgba(203,99,47,0.08)" stroke="url(#g-sw)" stroke-width="2"/>
          <text text-anchor="middle" font-family="Archivo,system-ui,sans-serif" fill="#F09550">
            <tspan x="193" y="348" font-size="9">Real Estate /</tspan>
            <tspan x="193" y="361" font-size="9">Infrastructure</tspan>
          </text>

          <!-- ── SE: Workforce Development ── -->
          <polygon
            points="307,294 358.96,324 358.96,384 307,414 255.04,384 255.04,324"
            fill="rgba(192,57,43,0.08)" stroke="url(#g-se)" stroke-width="2"/>
          <text text-anchor="middle" font-family="Archivo,system-ui,sans-serif" fill="#E87060">
            <tspan x="307" y="348" font-size="9">Workforce</tspan>
            <tspan x="307" y="361" font-size="9">Development</tspan>
          </text>

        </svg>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════ WHY ENTEVATE ═══════════════════════════ -->
  <section class="why-section" id="why">
    <div class="container">
      <div class="why-header fade-up">
        <div class="section-label">Why ENTEVATE</div>
        <h2 class="section-title">Built for the Builders.</h2>
      </div>

      <div class="proof-grid">

        <!-- Proof 1: Compass / 8-Stage -->
        <div class="proof-point fade-up">
          <div class="proof-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/>
              <path d="M16.24 7.76l-2.12 6.36-6.36 2.12 2.12-6.36z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="proof-stat">8-Stage Journey</div>
          <div class="proof-desc">A clear, validated methodology from first idea to full-scale harvest.</div>
        </div>

        <!-- Proof 2: Layers / 7 Basecamps -->
        <div class="proof-point fade-up">
          <div class="proof-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none">
              <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
              <path d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
              <path d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="proof-stat">7 Ecosystem Basecamps™</div>
          <div class="proof-desc">Holistic coverage across every dimension of your innovation environment.</div>
        </div>

        <!-- Proof 3: Lightning / Capital Pipeline -->
        <div class="proof-point fade-up">
          <div class="proof-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none">
              <path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="proof-stat">Venture-to-Capital Pipeline</div>
          <div class="proof-desc">From Sandbox to Funding Lab — we keep momentum moving.</div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ CASE STUDIES ═══════════════════════════ -->
  <section class="cases-section" id="case-studies">
    <div class="container">
      <div class="fade-up">
        <div class="section-label">In the Field</div>
        <h2 class="section-title">Innovation at work.</h2>
        <p class="section-subtitle">Two engagements where ENTEVATE frameworks moved from blueprint to real-world impact.</p>
      </div>

      <div class="cases-grid">

        <!-- Case Study 1: Trinity College AIQUI Sandbox -->
        <div class="case-card cc-blue fade-up">
          <div class="case-img"><img src="/images/trinity.jpg" alt="Trinity College AIQUI Sandbox" /></div>
          <div class="case-tag">Higher Education · AI &amp; Quantum Innovation</div>
          <h3>Trinity College<br>AIQUI Sandbox</h3>
          <p>Trinity College engaged ENTEVATE to design and facilitate an applied AI and quantum innovation environment grounded in the AIQUI framework. Working across academic, research, and industry stakeholders, ENTEVATE mapped the full innovation ecosystem using the 7 Core Elements Basecamps™ — identifying gaps, aligning cross-departmental priorities, and standing up a structured sandbox to accelerate applied discovery.</p>
          <div class="case-outcomes">
            <div class="case-outcome">AIQUI Framework Applied</div>
            <div class="case-outcome">7 Ecosystem Basecamps™ Mapped</div>
            <div class="case-outcome">Multi-Stakeholder Alignment</div>
            <div class="case-outcome">Innovation Sandbox Deployed</div>
          </div>
          <a href="/innovation/trinity-aiqui-sandbox" class="case-cta">Learn More →</a>
        </div>

        <!-- Case Study 2: Energy Innovation Lab -->
        <div class="case-card cc-purple fade-up">
          <div class="case-img"><img src="/images/bt2.png" alt="Energy Innovation Lab" /></div>
          <div class="case-tag">Energy Sector · Innovation Lab</div>
          <h3>Energy<br>Innovation Lab</h3>
          <p>A leading energy organization partnered with ENTEVATE to build an internal innovation lab capable of moving ideas from signal to scalable venture. ENTEVATE led the design of the lab's operating model, facilitated structured ideation and validation cycles through the Innovation Roadmapping™ framework, and connected the venture pipeline to capital readiness programming through the Innovation Funding Lab®.</p>
          <div class="case-outcomes">
            <div class="case-outcome">Innovation Lab Designed</div>
            <div class="case-outcome">8-Stage Roadmap Built</div>
            <div class="case-outcome">Capital Pipeline Activated</div>
            <div class="case-outcome">Cross-Functional Engagement</div>
          </div>
          <a href="/innovation/energy-innovation-lab" class="case-cta">Learn More →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ CTA BAND ═══════════════════════════ -->
  <section class="cta-band" id="contact">
    <div class="container">
      <div class="fade-up">
        <h2>Ready to Build Something Bold?</h2>
        <p>Let's map your innovation journey together. ENTEVATE partners with ecosystems, enterprises, and emerging ventures.</p>
        <div class="cta-band-actions">
          <a href="/contact?service=innovation" class="btn-white-solid">Schedule a Discovery Call</a>
          <a href="/contact?service=innovation" class="btn-white-ghost">Download the Framework Overview</a>
        </div>
      </div>
    </div>
  </section>
  
  <Footer client:load />
  
  <script>
    // Intersection Observer for fade-up animations
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
    }, { threshold: 0.10 });
    document.querySelectorAll('.fade-up').forEach(el => io.observe(el));
    
    // Staggered animation delays for journey steps
    document.querySelectorAll('.journey-step.fade-up').forEach((el, i) => {
      el.style.transitionDelay = `${i * 0.06}s`;
    });
    
    // Staggered animation delays for offering cards
    document.querySelectorAll('.offerings-grid .fade-up').forEach((el, i) => {
      el.style.transitionDelay = `${i * 0.08}s`;
    });
    
    // Staggered animation delays for proof points
    document.querySelectorAll('.proof-grid .fade-up').forEach((el, i) => {
      el.style.transitionDelay = `${i * 0.1}s`;
    });
    
    // Staggered animation delays for case cards
    document.querySelectorAll('.cases-grid .fade-up').forEach((el, i) => {
      el.style.transitionDelay = `${i * 0.1}s`;
    });
  </script>

  <style>
    /* ── Hero (Innovation) ── */
    .hero {
      background:
        linear-gradient(135deg, rgba(15,14,32,0.58) 0%, rgba(32,32,58,0.50) 50%, rgba(50,50,82,0.42) 100%),
        url('/images/bt3.png') center/cover no-repeat;
      position: relative;
      overflow: hidden;
      padding: 96px 48px 120px;
      min-height: 82vh;
      display: flex;
      align-items: center;
    }

    .hero-inner {
      position: relative;
      z-index: 2;
      max-width: 1160px;
      margin: 0 auto;
      width: 100%;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: rgba(142,144,192,0.14);
      border: 1px solid rgba(142,144,192,0.38);
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 28px;
      color: rgba(255,255,255,0.90);
    }

    .hero-eyebrow-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: linear-gradient(135deg, #9899CC, #C8C9E8);
      flex-shrink: 0;
    }

    .hero h1 {
      font-size: clamp(50px, 7vw, 92px);
      font-weight: 100;
      line-height: 1.04;
      color: var(--white);
      margin-bottom: 24px;
      letter-spacing: -0.03em;
      text-wrap: balance;
      max-width: 880px;
    }

    .hero h1 .accent {
      background: linear-gradient(90deg, #CDD2FF 0%, #EDEEFF 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-sub {
      font-size: 17px;
      color: rgba(255,255,255,0.68);
      line-height: 1.75;
      max-width: 680px;
      margin-bottom: 42px;
    }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .btn-blue {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 30px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: linear-gradient(135deg, #444561 0%, #6B6C9A 100%);
      color: var(--white);
      transition: all var(--tr);
      display: inline-block;
    }

    .btn-blue:hover {
      background: linear-gradient(135deg, #35344F 0%, #5B5C8C 100%);
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(68,69,97,0.50);
    }

    .btn-ghost-dark {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 500;
      background: none;
      border: 1.5px solid rgba(255,255,255,0.35);
      padding: 12px 26px;
      border-radius: var(--radius);
      cursor: pointer;
      color: rgba(255,255,255,0.85);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all var(--tr);
    }

    .btn-ghost-dark:hover {
      border-color: rgba(255,255,255,0.80);
      color: var(--white);
      background: rgba(255,255,255,0.08);
    }

    /* ── 8-Stage Journey ── */
    .journey-section {
      background: var(--white);
      border-top: 1px solid var(--border);
      padding: 80px 48px;
    }
    .journey-header { text-align: center; margin-bottom: 8px; }
    .journey-header .section-label { display: block; text-align: center; color: var(--blue); -webkit-text-fill-color: var(--blue); background: none; }
    .journey-header .section-title { margin: 0 auto 10px; }
    .journey-header .section-subtitle { margin: 0 auto; text-align: center; }
    .journey-outer { position: relative; margin-top: 48px; }
    .journey-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      padding: 32px 0 24px;
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }
    .journey-wrap::-webkit-scrollbar { height: 4px; }
    .journey-wrap::-webkit-scrollbar-track { background: transparent; }
    .journey-wrap::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
    .journey-track {
      display: flex;
      min-width: max-content;
      position: relative;
      padding: 0 32px;
      gap: 0;
    }
    .journey-track::before {
      content: '';
      position: absolute;
      top: 44px;
      left: 112px;
      right: 112px;
      height: 2px;
      background: linear-gradient(90deg,
        var(--blue) 0%, var(--blue) 12.5%,
        var(--green) 12.5%, var(--green) 25%,
        var(--purple) 25%, var(--purple) 37.5%,
        var(--orange-light) 37.5%, var(--orange-light) 50%,
        var(--blue) 50%, var(--blue) 62.5%,
        var(--green) 62.5%, var(--green) 75%,
        var(--purple) 75%, var(--purple) 87.5%,
        var(--orange-light) 87.5%, var(--orange-light) 100%
      );
      opacity: 0.35;
      z-index: 0;
    }
    .journey-step {
      flex: 0 0 200px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 12px;
      position: relative;
      z-index: 1;
    }
    .journey-num {
      width: 88px;
      height: 88px;
      border-radius: 50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: var(--white);
      margin-bottom: 20px;
      flex-shrink: 0;
      position: relative;
      z-index: 2;
      box-shadow: 0 4px 18px rgba(0,0,0,0.13);
      transition: transform var(--tr), box-shadow var(--tr);
    }
    .journey-step:hover .journey-num {
      transform: translateY(-5px);
      box-shadow: 0 12px 28px rgba(0,0,0,0.18);
    }
    .journey-num .step-n { font-size: 24px; font-weight: 700; line-height: 1; }
    .journey-num .step-s { font-size: 8px; font-weight: 600; letter-spacing: 0.10em; text-transform: uppercase; opacity: 0.75; margin-top: 3px; }
    .journey-content { display: flex; flex-direction: column; }
    .journey-step-name { font-size: 14px; font-weight: 600; color: var(--black); margin-bottom: 8px; }
    .journey-step-desc { font-size: 12px; color: var(--gray-mid); line-height: 1.58; }
    .c-blue { background: var(--blue); }
    .c-green { background: var(--green); }
    .c-purple { background: var(--purple); }
    .c-orange-l { background: var(--orange-light); }
    .journey-hint {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--gray-light);
      margin-top: 12px;
    }

    /* ── Core Offerings ── */
    .offerings-section {
      background: var(--light-blue);
      padding: 80px 48px;
    }
    .offerings-section .section-label { color: var(--blue); -webkit-text-fill-color: var(--blue); background: none; }
    .offerings-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
      margin-top: 52px;
    }
    .offering-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 32px 28px;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      transition: box-shadow var(--tr), transform var(--tr);
    }
    .offering-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .oc-green::before { background: var(--green); }
    .oc-orange-light::before { background: var(--orange-light); }
    .oc-blue::before { background: var(--blue); }
    .oc-purple::before { background: var(--purple); }
    .oc-orange-dark::before { background: var(--orange-dark); }
    .offering-card:hover {
      box-shadow: 0 10px 40px rgba(0,0,0,0.08);
      transform: translateY(-3px);
    }
    .offering-icon {
      width: 48px;
      height: 48px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
    }
    .oc-green .offering-icon { background: rgba(61,151,138,0.10); color: var(--green); }
    .oc-orange-light .offering-icon { background: rgba(234,151,9,0.10); color: var(--orange-light); }
    .oc-blue .offering-icon { background: rgba(36,123,150,0.10); color: var(--blue); }
    .oc-purple .offering-icon { background: rgba(68,69,97,0.10); color: var(--purple); }
    .oc-orange-dark .offering-icon { background: rgba(203,99,47,0.10); color: var(--orange-dark); }
    .offering-card h3 {
      font-size: 17px;
      font-weight: 300;
      color: var(--black);
      margin-bottom: 6px;
      letter-spacing: -0.01em;
      line-height: 1.3;
    }
    .offering-card em {
      display: block;
      font-style: italic;
      font-size: 13px;
      color: var(--gray-light);
      margin-bottom: 14px;
    }
    .offering-card p {
      font-size: 13.5px;
      color: var(--gray-mid);
      line-height: 1.7;
      flex: 1;
      margin-bottom: 22px;
    }
    .offering-cta {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: auto;
      transition: gap var(--tr);
    }
    .oc-green .offering-cta { color: var(--green); }
    .oc-orange-light .offering-cta { color: var(--orange-light); }
    .oc-blue .offering-cta { color: var(--blue); }
    .oc-purple .offering-cta { color: var(--purple); }
    .oc-orange-dark .offering-cta { color: var(--orange-dark); }
    .offering-cta:hover { gap: 10px; }

    /* ── AIQUI ── */
    .aiqui-section {
      background:
        linear-gradient(135deg, rgba(15,14,32,0.58) 0%, rgba(32,32,58,0.50) 50%, rgba(50,50,82,0.42) 100%),
        url('/images/bt3.png') center/cover no-repeat;
      color: var(--white);
      padding: 80px 48px;
    }
    .aiqui-inner {
      max-width: 1160px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .aiqui-eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--green);
      margin-bottom: 14px;
      display: block;
    }
    .aiqui-left h2 {
      font-size: clamp(26px, 3.5vw, 40px);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.15;
      margin-bottom: 18px;
    }
    .aiqui-left p {
      font-size: 15px;
      color: rgba(255,255,255,0.60);
      line-height: 1.80;
      margin-bottom: 32px;
      max-width: 460px;
    }
    .btn-green {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 30px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: var(--green);
      color: var(--white);
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-green:hover { background: var(--blue); transform: translateY(-1px); }
    .aiqui-hex-wrap { display: flex; align-items: center; justify-content: center; }
    .aiqui-hex-wrap svg { width: 100%; max-width: 460px; height: auto; }

    /* ── Why ENTEVATE ── */
    .why-section {
      background: var(--light-blue);
      padding: 80px 48px;
    }
    .why-header { text-align: center; margin-bottom: 56px; }
    .why-header .section-label { display: block; text-align: center; color: var(--blue); -webkit-text-fill-color: var(--blue); background: none; }
    .why-header h2 { font-size: clamp(28px, 4vw, 46px); font-weight: 300; letter-spacing: -0.02em; }
    .proof-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
      max-width: 1160px;
      margin: 0 auto;
    }
    .proof-point {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 40px 28px 36px;
      background: var(--white);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      transition: box-shadow var(--tr), transform var(--tr);
    }
    .proof-point:hover {
      box-shadow: 0 8px 28px rgba(0,0,0,0.07);
      transform: translateY(-3px);
    }
    .proof-icon {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: rgba(36,123,150,0.09);
      color: var(--blue);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
    }
    .proof-stat { font-size: 20px; font-weight: 700; color: var(--black); margin-bottom: 10px; letter-spacing: -0.01em; }
    .proof-desc { font-size: 14px; color: var(--gray-mid); line-height: 1.65; }

    /* ── Case Studies ── */
    .cases-section { background: var(--white); padding: 80px 48px; }
    .cases-section .section-label { color: var(--blue); -webkit-text-fill-color: var(--blue); background: none; }
    .cases-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 28px;
      margin-top: 52px;
    }
    .case-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 36px 32px;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      transition: box-shadow var(--tr), transform var(--tr);
    }
    .case-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .case-card.cc-blue::before { background: linear-gradient(90deg, var(--blue), var(--green)); }
    .case-card.cc-purple::before { background: linear-gradient(90deg, var(--purple), #8E8FC8); }
    .case-card:hover {
      box-shadow: 0 16px 56px rgba(0,0,0,0.35);
      transform: translateY(-3px);
    }
    .case-img {
      margin: -36px -32px 28px -32px;
      height: 210px;
      overflow: hidden;
      border-radius: var(--radius) var(--radius) 0 0;
    }
    .case-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.5s ease;
    }
    .case-card:hover .case-img img { transform: scale(1.04); }
    .case-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gray-light);
      margin-bottom: 18px;
    }
    .case-tag::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--border);
      flex-shrink: 0;
    }
    .cc-blue .case-tag::before { background: var(--blue); }
    .cc-purple .case-tag::before { background: var(--purple); }
    .case-card h3 {
      font-size: 22px;
      font-weight: 300;
      letter-spacing: -0.02em;
      color: var(--black);
      margin-bottom: 14px;
      line-height: 1.25;
    }
    .case-card p { font-size: 14px; color: var(--gray-mid); line-height: 1.75; margin-bottom: 26px; flex: 1; }
    .case-outcomes {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 28px;
    }
    .case-outcome {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.04em;
      padding: 5px 12px;
      border-radius: 100px;
      border: 1px solid var(--border);
      color: var(--gray-mid);
      background: var(--light-blue);
    }
    .case-cta {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: auto;
      transition: gap var(--tr);
    }
    .cc-blue .case-cta { color: var(--blue); }
    .cc-purple .case-cta { color: var(--purple); }
    .case-cta:hover { gap: 10px; }

    /* ── CTA Band ── */
    .cta-band {
      background: linear-gradient(135deg, var(--blue) 0%, var(--purple) 100%);
      color: var(--white);
      padding: 80px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-band::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 25% 40%, rgba(255,255,255,0.07) 0%, transparent 50%),
        radial-gradient(circle at 80% 70%, rgba(255,255,255,0.05) 0%, transparent 45%);
      pointer-events: none;
    }
    .cta-band .container { position: relative; z-index: 1; }
    .cta-band h2 {
      font-size: clamp(28px, 4.5vw, 52px);
      font-weight: 300;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }
    .cta-band p {
      font-size: 16px;
      color: rgba(255,255,255,0.68);
      max-width: 520px;
      margin: 0 auto 38px;
      line-height: 1.72;
    }
    .cta-band-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .btn-white-solid {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 30px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: var(--white);
      color: var(--blue);
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-white-solid:hover { background: var(--light-blue); transform: translateY(-1px); }
    .btn-white-ghost {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 500;
      padding: 12px 30px;
      border-radius: var(--radius);
      border: 1.5px solid rgba(255,255,255,0.45);
      cursor: pointer;
      color: var(--white);
      background: transparent;
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-white-ghost:hover { border-color: rgba(255,255,255,0.90); background: rgba(255,255,255,0.10); }

    /* ── Responsive ── */
    @media (max-width: 960px) {
      .hero { padding: 72px 24px 88px; min-height: auto; }
      .journey-section,
      .offerings-section,
      .aiqui-section,
      .why-section,
      .cta-band,
      .cases-section { padding: 64px 24px; }
      .aiqui-inner { grid-template-columns: 1fr; gap: 48px; }
      .cases-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .hero { padding: 60px 20px 72px; }
      .journey-wrap { overflow-x: visible; padding: 16px 0 8px; }
      .journey-track { flex-direction: column; min-width: auto; padding: 0; }
      .journey-track::before {
        top: 44px;
        bottom: 44px;
        left: 43px;
        right: auto;
        width: 2px;
        height: auto;
        background: linear-gradient(180deg,
          var(--blue) 0%, var(--green) 33%,
          var(--purple) 66%, var(--orange-light) 100%
        );
      }
      .journey-step {
        flex: none;
        flex-direction: row;
        text-align: left;
        align-items: flex-start;
        gap: 20px;
        padding: 0 0 36px;
        width: 100%;
      }
      .journey-num { flex-shrink: 0; width: 64px; height: 64px; margin-bottom: 0; }
      .journey-num .step-n { font-size: 19px; }
      .journey-content { padding-top: 8px; }
      .offerings-grid { grid-template-columns: 1fr; }
      .proof-grid { grid-template-columns: 1fr; gap: 16px; }
      .journey-hint { display: none; }
    }
    @media (max-width: 600px) {
      .cta-band-actions { flex-direction: column; }
      .btn-white-solid,
      .btn-white-ghost { width: 100%; text-align: center; }
    }
  </style>
</body>
</html>