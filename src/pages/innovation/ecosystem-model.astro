---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.jsx";
import Footer from "../../components/Footer.jsx";
import "../../global.css";

const title = "Ecosystem Model: 7 Core Elements™ — ENTEVATE";
const description =
  "ENTEVATE's 7 Core Elements™ framework gives any innovation ecosystem a complete, structured map — covering every stakeholder, sector, and stage from assessment through activation.";

const jsonLd = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Ecosystem Model: 7 Core Elements™",
    "provider": { "@type": "Organization", "name": "ENTEVATE" },
    "description": description,
    "url": "https://www.entevate.com/innovation/ecosystem-model",
    "serviceType": "Innovation Ecosystem Consulting",
    "audience": {
      "@type": "Audience",
      "audienceType": "Innovation districts, cities, universities, economic development organizations, enterprise innovation teams"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.entevate.com" },
      { "@type": "ListItem", "position": 2, "name": "Innovation", "item": "https://www.entevate.com/innovation" },
      { "@type": "ListItem", "position": 3, "name": "Ecosystem Model", "item": "https://www.entevate.com/innovation/ecosystem-model" }
    ]
  }
]);
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Header client:load />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div class="fade-up">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>
          Ecosystem Model: 7 Core Elements™
        </div>
        <h1>
          Map Every Dimension of Your <span class="accent"
            >Innovation Ecosystem.</span
          >
        </h1>
        <p class="hero-sub">
          ENTEVATE's 7 Core Elements™ framework gives any innovation ecosystem a
          complete, structured map — covering every stakeholder, sector, and
          stage from assessment through activation.
        </p>
        <div class="hero-actions">
          <a href="/contact?service=ecosystem-model" class="btn-primary"
            >Start Your Assessment →</a
          >
          <a href="#elements" class="btn-ghost-dark">Explore the 7 Elements ↓</a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="overview-section" id="overview">
    <div class="overview-inner">
      <div class="overview-left fade-up">
        <div class="section-label">The Framework</div>
        <h2>
          A complete map of every dimension that drives innovation success.
        </h2>
        <p>
          Most innovation initiatives fail not because the ideas are bad — but
          because critical dimensions of the ecosystem go unmapped and
          underinvested. The Ecosystem Model: 7 Core Elements™ was developed by
          ENTEVATE to ensure nothing falls through the cracks.
        </p>
        <p>
          Rather than treating innovation as a single-track challenge, the 7
          Core Elements™ maps the full environment: policy, research,
          infrastructure, economic growth, workforce, venture formation, and
          community access. Each element is assessed, gap-analyzed, and
          integrated into a shared, milestone-driven roadmap.
        </p>
      </div>

      <div class="overview-right fade-up">
        <div class="overview-stat">
          <div class="overview-stat-icon osi-green">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
              ><path
                d="M12 2l8.66 5v10L12 22l-8.66-5V7L12 2z"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linejoin="round"></path><path
                d="M12 2v10M3.34 7l8.66 5M20.66 7l-8.66 5"
                stroke="currentColor"
                stroke-width="1.3"
                stroke-linecap="round"
                opacity="0.5"></path></svg
            >
          </div>
          <div class="overview-stat-body">
            <div class="overview-stat-num">7</div>
            <div class="overview-stat-label">
              Core Elements Basecamps™ mapped across every engagement
            </div>
          </div>
        </div>
        <div class="overview-stat">
          <div class="overview-stat-icon osi-purple">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
              ><circle
                cx="12"
                cy="12"
                r="10"
                stroke="currentColor"
                stroke-width="1.6"></circle><path
                d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"></path></svg
            >
          </div>
          <div class="overview-stat-body">
            <div class="overview-stat-num">360°</div>
            <div class="overview-stat-label">
              Ecosystem view spanning every stakeholder, sector, and stage
            </div>
          </div>
        </div>
        <div class="overview-stat">
          <div class="overview-stat-icon osi-blue">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
              ><path
                d="M9 11l3 3L22 4"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path><path
                d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path></svg
            >
          </div>
          <div class="overview-stat-body">
            <div class="overview-stat-num">1</div>
            <div class="overview-stat-label">
              Integrated roadmap connecting all elements to shared strategic
              goals
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7 Core Elements -->
  <section class="elements-section" id="elements">
    <div class="elements-inner">
      <div class="elements-header fade-up">
        <div class="section-label">The 7 Core Elements Basecamps™</div>
        <h2 class="section-title">Every dimension. One framework.</h2>
        <p class="section-subtitle">
          The 7 Core Elements™ maps the full innovation ecosystem across seven
          interconnected basecamps — no dimension is treated in isolation, and
          no stakeholder is left unaccounted for.
        </p>
      </div>

      <div class="elements-grid">
        <!-- Hex cluster visual -->
        <div class="elements-hex fade-up">
          <svg
            viewBox="50 80 415 360"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            role="img"
            aria-label="7 Core Elements hexagon cluster"
          >
            <defs>
              <linearGradient
                id="g-center"
                x1="198"
                y1="195"
                x2="302"
                y2="315"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#3D978A"></stop><stop
                  offset="100%"
                  stop-color="#72D4C5"></stop>
              </linearGradient>
              <linearGradient
                id="g-e"
                x1="312"
                y1="195"
                x2="416"
                y2="315"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#7A7A7A"></stop><stop
                  offset="100%"
                  stop-color="#C0C0C0"></stop>
              </linearGradient>
              <linearGradient
                id="g-ne"
                x1="255"
                y1="96"
                x2="359"
                y2="216"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#444561"></stop><stop
                  offset="100%"
                  stop-color="#8E8FC8"></stop>
              </linearGradient>
              <linearGradient
                id="g-nw"
                x1="141"
                y1="96"
                x2="245"
                y2="216"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#247B96"></stop><stop
                  offset="100%"
                  stop-color="#4DC8E0"></stop>
              </linearGradient>
              <linearGradient
                id="g-w"
                x1="84"
                y1="195"
                x2="188"
                y2="315"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#EA9709"></stop><stop
                  offset="100%"
                  stop-color="#F5C842"></stop>
              </linearGradient>
              <linearGradient
                id="g-sw"
                x1="141"
                y1="294"
                x2="245"
                y2="414"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#CB632F"></stop><stop
                  offset="100%"
                  stop-color="#F09550"></stop>
              </linearGradient>
              <linearGradient
                id="g-se"
                x1="255"
                y1="294"
                x2="359"
                y2="414"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#C0392B"></stop><stop
                  offset="100%"
                  stop-color="#E87060"></stop>
              </linearGradient>
            </defs>
            <polygon
              points="250,195 301.96,225 301.96,285 250,315 198.04,285 198.04,225"
              fill="rgba(61,151,138,0.07)"
              stroke="url(#g-center)"
              stroke-width="2"></polygon>
            <text
              text-anchor="middle"
              font-family="Archivo,system-ui,sans-serif"
              fill="#72D4C5"
            >
              <tspan x="250" y="249" font-size="9">Venture</tspan>
              <tspan x="250" y="262" font-size="9">Development</tspan>
            </text>
            <polygon
              points="364,195 415.96,225 415.96,285 364,315 312.04,285 312.04,225"
              fill="rgba(120,120,120,0.06)"
              stroke="url(#g-e)"
              stroke-width="2"></polygon>
            <text
              text-anchor="middle"
              font-family="Archivo,system-ui,sans-serif"
              fill="#C0C0C0"
            >
              <tspan x="364" y="249" font-size="9">Economic</tspan>
              <tspan x="364" y="261" font-size="9">Development</tspan>
            </text>
            <polygon
              points="307,96 358.96,126 358.96,186 307,216 255.04,186 255.04,126"
              fill="rgba(68,69,97,0.08)"
              stroke="url(#g-ne)"
              stroke-width="2"></polygon>
            <text
              text-anchor="middle"
              font-family="Archivo,system-ui,sans-serif"
              fill="#AAABCC"
            >
              <tspan x="307" y="150" font-size="9">Policy /</tspan>
              <tspan x="307" y="163" font-size="9">Advocacy</tspan>
            </text>
            <polygon
              points="193,96 244.96,126 244.96,186 193,216 141.04,186 141.04,126"
              fill="rgba(36,123,150,0.08)"
              stroke="url(#g-nw)"
              stroke-width="2"></polygon>
            <text
              text-anchor="middle"
              font-family="Archivo,system-ui,sans-serif"
              fill="#7CCCE0"
            >
              <tspan x="193" y="144" font-size="8.5">Research &amp;</tspan>
              <tspan x="193" y="157" font-size="8.5">Innovation</tspan>
              <tspan x="193" y="170" font-size="8.5">Development</tspan>
            </text>
            <polygon
              points="136,195 187.96,225 187.96,285 136,315 84.04,285 84.04,225"
              fill="rgba(234,151,9,0.07)"
              stroke="url(#g-w)"
              stroke-width="2"></polygon>
            <text
              text-anchor="middle"
              font-family="Archivo,system-ui,sans-serif"
              fill="#F5C842"
            >
              <tspan x="136" y="245" font-size="8.5">Social /</tspan>
              <tspan x="136" y="258" font-size="8.5">Community /</tspan>
              <tspan x="136" y="271" font-size="8.5">Accessibility</tspan>
            </text>
            <polygon
              points="193,294 244.96,324 244.96,384 193,414 141.04,384 141.04,324"
              fill="rgba(203,99,47,0.07)"
              stroke="url(#g-sw)"
              stroke-width="2"></polygon>
            <text
              text-anchor="middle"
              font-family="Archivo,system-ui,sans-serif"
              fill="#F09550"
            >
              <tspan x="193" y="342" font-size="8.5">Real Estate /</tspan>
              <tspan x="193" y="355" font-size="8.5">Infrastructure /</tspan>
              <tspan x="193" y="368" font-size="8.5">Placemaking</tspan>
            </text>
            <polygon
              points="307,294 358.96,324 358.96,384 307,414 255.04,384 255.04,324"
              fill="rgba(192,57,43,0.07)"
              stroke="url(#g-se)"
              stroke-width="2"></polygon>
            <text
              text-anchor="middle"
              font-family="Archivo,system-ui,sans-serif"
              fill="#E87060"
            >
              <tspan x="307" y="349" font-size="9">Workforce</tspan>
              <tspan x="307" y="362" font-size="9">Development</tspan>
            </text>
          </svg>
        </div>

        <!-- Elements list -->
        <div class="elements-list fade-up">
          <div class="element-item">
            <div class="element-dot" style="background:#72D4C5;"></div>
            <div>
              <div class="element-name">Venture Development</div>
              <div class="element-desc">
                The beating heart of any innovation ecosystem — supporting the
                formation, growth, and scaling of ventures born from research,
                collaboration, and institutional investment. This is where ideas
                become organizations.
              </div>
            </div>
          </div>

          <div class="element-item">
            <div class="element-dot" style="background:#8E8FC8;"></div>
            <div>
              <div class="element-name">Policy / Advocacy</div>
              <div class="element-desc">
                Shaping the regulatory frameworks, government partnerships, and
                institutional policies that enable innovation to take root,
                scale, and benefit the broader community it serves.
              </div>
            </div>
          </div>

          <div class="element-item">
            <div class="element-dot" style="background:#4DC8E0;"></div>
            <div>
              <div class="element-name">
                Research &amp; Innovation Development
              </div>
              <div class="element-desc">
                Building the research infrastructure, academic partnerships, and
                applied R&D pipelines that generate breakthroughs and move them
                toward real-world commercialization and impact.
              </div>
            </div>
          </div>

          <div class="element-item">
            <div class="element-dot" style="background:#F09550;"></div>
            <div>
              <div class="element-name">
                Real Estate / Infrastructure / Placemaking
              </div>
              <div class="element-desc">
                Creating the physical and digital environments — labs, campuses,
                innovation districts — where frontier technology work can happen
                at the scale and quality the work demands.
              </div>
            </div>
          </div>

          <div class="element-item">
            <div class="element-dot" style="background:#C0C0C0;"></div>
            <div>
              <div class="element-name">Economic Development</div>
              <div class="element-desc">
                Connecting innovation activity to regional economic growth
                through job creation, industry attraction, startup formation,
                and structured commercialization pathways that benefit the
                broader economy.
              </div>
            </div>
          </div>

          <div class="element-item">
            <div class="element-dot" style="background:#E87060;"></div>
            <div>
              <div class="element-name">Workforce Development</div>
              <div class="element-desc">
                Building the talent pipeline through education, training,
                reskilling, and credentialing programs that prepare communities
                for a technology-enabled economy — and ensure no one is left
                behind.
              </div>
            </div>
          </div>

          <div class="element-item">
            <div class="element-dot" style="background:#F5C842;"></div>
            <div>
              <div class="element-name">Social / Community / Accessibility</div>
              <div class="element-desc">
                Ensuring innovation benefits are broadly shared through
                intentional community engagement, equity frameworks, and
                accessible pathways into the innovation economy for all
                residents and stakeholders.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="process-section" id="process">
    <div class="process-inner">
      <div class="fade-up" style="text-align:center;">
        <div class="section-label" style="display:block;text-align:center;">
          How It Works
        </div>
        <h2 class="section-title" style="text-align:center;margin:0 auto 14px;">
          From assessment to activation.
        </h2>
        <p class="section-subtitle" style="margin:0 auto;text-align:center;">
          A structured four-phase engagement that translates the 7 Core
          Elements™ framework into a living, working roadmap for your ecosystem.
        </p>
      </div>

      <div class="process-steps">
        <div class="process-step fade-up">
          <div class="process-num pn-green">1</div>
          <div class="process-step-name">Ecosystem Assessment</div>
          <div class="process-step-desc">
            Map your current state across all 7 Core Elements™, benchmarking
            strengths, gaps, and opportunities at every layer.
          </div>
        </div>

        <div class="process-step fade-up">
          <div class="process-num pn-blue">2</div>
          <div class="process-step-name">Gap Analysis</div>
          <div class="process-step-desc">
            Surface critical whitespace and priority areas with the highest
            potential for near- and long-term impact across the ecosystem.
          </div>
        </div>

        <div class="process-step fade-up">
          <div class="process-num pn-purple">3</div>
          <div class="process-step-name">Innovation Roadmap</div>
          <div class="process-step-desc">
            Co-create a milestone-driven roadmap — sequenced, resourced, and
            aligned to your goals and ecosystem context.
          </div>
        </div>

        <div class="process-step fade-up">
          <div class="process-num pn-teal">4</div>
          <div class="process-step-name">Activation &amp; Embedding</div>
          <div class="process-step-desc">
            ENTEVATE stays embedded as a strategic partner through execution,
            iteration, and continuous ecosystem development.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="for-section" id="for">
    <div class="for-header fade-up">
      <div class="section-label">Who It's For</div>
      <h2 class="section-title">Built for builders across every sector.</h2>
      <p class="section-subtitle">
        The Ecosystem Model: 7 Core Elements™ is deployed wherever complex,
        multi-stakeholder innovation meets real-world ecosystem challenges.
      </p>
    </div>

    <div class="for-grid">
      <div class="for-card fade-up">
        <div class="for-card-icon fci-blue">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
            ><path
              d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linejoin="round"></path><path
              d="M9 22V12h6v10"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linejoin="round"></path></svg
          >
        </div>
        <h3>Universities &amp; Research Institutions</h3>
        <p>
          Map and build your innovation ecosystem from foundational research
          through commercialization, venture formation, and community impact.
        </p>
      </div>

      <div class="for-card fade-up">
        <div class="for-card-icon fci-orange">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
            ><path
              d="M22 12h-4l-3 9L9 3l-3 9H2"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          >
        </div>
        <h3>Economic Development Organizations</h3>
        <p>
          Activate innovation as a regional growth driver with a measurable,
          stakeholder-aligned framework tied to real economic outcomes.
        </p>
      </div>

      <div class="for-card fade-up">
        <div class="for-card-icon fci-purple">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
            ><circle
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="1.6"></circle><path
              d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"></path></svg
          >
        </div>
        <h3>Innovation Districts &amp; Cities Planning</h3>
        <p>
          Design place-based innovation ecosystems that attract talent, capital,
          and anchor institutions — with a framework built for urban complexity.
        </p>
      </div>

      <div class="for-card fade-up">
        <div class="for-card-icon fci-green">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
            ><rect
              x="2"
              y="7"
              width="20"
              height="14"
              rx="2"
              stroke="currentColor"
              stroke-width="1.6"></rect><path
              d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linejoin="round"></path><line
              x1="12"
              y1="12"
              x2="12"
              y2="16"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"></line><line
              x1="10"
              y1="14"
              x2="14"
              y2="14"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"></line></svg
          >
        </div>
        <h3>Enterprise &amp; Corporate Organizations</h3>
        <p>
          Build internal innovation capability aligned to your strategic
          priorities, with structured pathways from idea through venture
          formation and scale.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="cta-band" id="contact">
    <div class="container">
      <div class="fade-up">
        <h2>Ready to Map Your Innovation Ecosystem?</h2>
        <p>
          Let's assess every dimension, surface the gaps, and build a roadmap
          your whole ecosystem can execute. ENTEVATE stays with you from
          assessment through activation.
        </p>
        <div class="cta-band-actions">
          <a href="/contact?service=ecosystem-model" class="btn-white-solid"
            >Schedule a Discovery Call</a
          >
          <a href="/innovation" class="btn-white-ghost"
            >Back to Innovation Overview</a
          >
        </div>
      </div>
    </div>
  </section>

  <Footer client:load buttonStyle={{ background: "var(--purple-dark)" }} />

  <script src="../../global.js"></script>
  <script>
    window.onload = () => {
      staggerFadeIn(".process-step.fade-up");
      staggerFadeIn(".for-card.fade-up");
    };
  </script>

  <style>
    /* Page accent override */
    .section-label {
      color: var(--green) !important;
    }

    /* Hero */
    .hero {
      background:
        linear-gradient(
          135deg,
          rgba(15, 14, 32, 0.58) 0%,
          rgba(32, 32, 58, 0.5) 50%,
          rgba(50, 50, 82, 0.42) 100%
        ),
        url("/images/bt3.png") center/cover no-repeat;
      position: relative;
      overflow: hidden;
      padding: 96px 48px 120px;
      min-height: 82vh;
      display: flex;
      align-items: center;
    }
    .hero-inner {
      position: relative;
      z-index: 2;
      max-width: 1160px;
      margin: 0 auto;
      width: 100%;
    }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: rgba(61, 151, 138, 0.14);
      border: 1px solid rgba(61, 151, 138, 0.38);
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 28px;
      color: rgba(255, 255, 255, 0.9);
    }
    .hero-eyebrow-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: linear-gradient(135deg, #3d978a, #72d4c5);
      flex-shrink: 0;
    }
    .hero h1 {
      font-size: clamp(38px, 6.5vw, 78px);
      font-weight: 100;
      line-height: 1.04;
      color: var(--white);
      margin-bottom: 24px;
      letter-spacing: -0.03em;
      text-wrap: balance;
