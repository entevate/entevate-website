---
import Header from '../../components/Header.jsx';
import Footer from '../../components/Footer.jsx';
import '../../global.css';

const title = 'Energy Innovation Lab — Case Study — ENTEVATE';
const description = 'A case study documenting how ENTEVATE partnered with an energy sector client to build an innovation lab — from roadmap design through live experimentation and venture development.';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <Header client:load />

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-breadcrumb">
        <a href="/">ENTEVATE</a>
        <span class="breadcrumb-sep">/</span>
        <a href="/our-work">Our Work</a>
        <span class="breadcrumb-sep">/</span>
        <span>Energy Innovation Lab</span>
      </div>
      <div class="hero-eyebrow">
        <span class="hero-eyebrow-dot"></span>
        Case Study &mdash; Innovation &amp; Ventures
      </div>
      <h1>Energy <span class="accent">Innovation Lab</span></h1>
      <div class="hero-meta">
        <span class="hero-meta-item">Case Study</span>
        <span class="hero-meta-divider"></span>
        <span class="hero-meta-item">Innovation &amp; Ventures</span>
      </div>
    </div>
  </section>

  <!-- Placeholder Content -->
  <div class="placeholder-wrap">
    <div class="coming-soon-icon">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/></svg>
    </div>
    <h2>Case Study In Progress</h2>
    <p>We're developing the full story behind this engagement. Check back soon to learn how ENTEVATE partnered with an energy sector client to build an innovation lab — from roadmap design through live experimentation and venture development.</p>
    <div class="placeholder-actions">
      <a href="/innovation" class="btn-primary">Explore Innovation Services</a>
      <a href="/our-work" class="btn-ghost">Back to Our Work</a>
    </div>
  </div>

  <Footer client:load />

  <style>
    /* Page accent override - Innovation purple */
    .section-label {
      color: var(--purple) !important;
    }

    /* Hero */
    .hero {
      background:
        linear-gradient(135deg, rgba(15, 15, 30, 0.86) 0%, rgba(40, 40, 70, 0.72) 50%, rgba(106, 107, 158, 0.4) 100%),
        url('/images/bt3.png') center/cover no-repeat;
      position: relative;
      overflow: hidden;
      padding: 96px 48px 112px;
      min-height: 60vh;
      display: flex;
      align-items: center;
    }

    .hero-inner {
      position: relative;
      z-index: 2;
      max-width: 1160px;
      margin: 0 auto;
      width: 100%;
    }

    .hero-breadcrumb {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.65);
      margin-bottom: 24px;
      font-weight: 500;
    }

    .hero-breadcrumb a {
      color: rgba(255, 255, 255, 0.65);
      transition: color var(--tr);
    }

    .hero-breadcrumb a:hover {
      color: rgba(255, 255, 255, 0.9);
    }

    .breadcrumb-sep {
      margin: 0 8px;
      color: rgba(255, 255, 255, 0.35);
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: rgba(106, 107, 158, 0.2);
      border: 1px solid rgba(142, 144, 192, 0.45);
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 24px;
      color: rgba(255, 255, 255, 0.92);
    }

    .hero-eyebrow-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: linear-gradient(135deg, #6a6b9e, #8e90c0);
      flex-shrink: 0;
    }

    .hero h1 {
      font-size: clamp(36px, 5vw, 68px);
      font-weight: 100;
      line-height: 1.08;
      color: var(--white);
      margin-bottom: 22px;
      letter-spacing: -0.03em;
      max-width: 820px;
      text-wrap: balance;
    }

    .hero h1 .accent {
      background: linear-gradient(90deg, #8e90c0 0%, #b0b2d8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-meta {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .hero-meta-item {
      font-size: 13px;
      color: rgba(255, 255, 255, 0.55);
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .hero-meta-divider {
      width: 1px;
      height: 14px;
      background: rgba(255, 255, 255, 0.2);
    }

    /* Placeholder Content */
    .placeholder-wrap {
      max-width: 760px;
      margin: 80px auto;
      padding: 0 48px;
      text-align: center;
    }

    .coming-soon-icon {
      width: 72px;
      height: 72px;
      border-radius: 16px;
      background: linear-gradient(135deg, #6a6b9e, #8e90c0);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 28px;
    }

    .coming-soon-icon svg {
      width: 36px;
      height: 36px;
      color: var(--white);
    }

    .placeholder-wrap h2 {
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 16px;
    }

    .placeholder-wrap p {
      font-size: 17px;
      color: var(--gray-mid);
      line-height: 1.75;
      max-width: 520px;
      margin: 0 auto 36px;
    }

    .placeholder-actions {
      display: flex;
      gap: 14px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .placeholder-actions .btn-primary {
      background: #6a6b9e;
      color: var(--white);
      padding: 12px 26px;
      border-radius: var(--radius);
      font-weight: 700;
      font-size: 15px;
      transition: opacity var(--tr);
      border: none;
      cursor: pointer;
    }

    .placeholder-actions .btn-primary:hover {
      opacity: 0.88;
    }

    .placeholder-actions .btn-ghost {
      border: 1.5px solid var(--border);
      color: var(--black);
      padding: 11px 24px;
      border-radius: var(--radius);
      font-weight: 600;
      font-size: 15px;
      transition: border-color var(--tr), color var(--tr);
      background: transparent;
      cursor: pointer;
    }

    .placeholder-actions .btn-ghost:hover {
      border-color: #6a6b9e;
      color: #6a6b9e;
    }

    /* Responsive */
    @media (max-width: 960px) {
      .hero {
        padding: 72px 24px 88px;
        min-height: auto;
      }

      .placeholder-wrap {
        margin: 56px auto;
        padding: 0 24px;
      }
    }

    @media (max-width: 600px) {
      .hero {
        padding: 56px 20px 72px;
      }

      .placeholder-wrap {
        padding: 0 20px;
      }
    }
  </style>
</body>
</html>