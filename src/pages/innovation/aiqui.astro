  <script>
    window.onload = () => {
      staggerFadeIn(".process-step.fade-up");
      staggerFadeIn(".for-card.fade-up");
    };

    // Stagger basecamp items
    document.querySelectorAll(".basecamp-item").forEach((el, i) => {
      el.style.opacity = "0";
      el.style.transform = "translateY(16px)";
      el.style.transition = `opacity 0.45s ease ${i * 0.06}s, transform 0.45s ease ${i * 0.06}s`;
      const obs = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            el.style.opacity = "1";
            el.style.transform = "none";
            obs.unobserve(el);
          }
        },
        { threshold: 0.15 },
      );
      obs.observe(el);
    });
  </script>
