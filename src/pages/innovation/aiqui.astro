---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.jsx";
import Footer from "../../components/Footer.jsx";
import "../../global.css";

const title = "AIQUI Framework — ENTEVATE";
const description =
  "AIQUI is ENTEVATE’s applied framework for AI and quantum innovation, mapping the full ecosystem across seven core basecamps.";

const jsonLd = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "AIQUI Framework — AI & Quantum Innovation",
    "provider": { "@type": "Organization", "name": "ENTEVATE" },
    "description": description,
    "url": "https://www.entevate.com/innovation/aiqui",
    "serviceType": "AI & Quantum Innovation Consulting"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.entevate.com" },
      { "@type": "ListItem", "position": 2, "name": "Innovation", "item": "https://www.entevate.com/innovation" },
      { "@type": "ListItem", "position": 3, "name": "AIQUI", "item": "https://www.entevate.com/innovation/aiqui" }
    ]
  }
]);
---

<BaseLayout title={title} description={description} ogImage="/images/og/irm-og.png" jsonLd={jsonLd}>
  <style>
    /* ── Shared ── */
    .section {
      padding: 80px 48px;
    }
    .container {
      max-width: 1160px;
      margin: 0 auto;
    }
    .section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 14px;
      display: inline-block;
      color: var(--blue);
    }
    h2.section-title {
      font-size: clamp(30px, 4vw, 48px);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.1;
      margin-bottom: 16px;
    }
    .section-subtitle {
      font-size: 15px;
      color: var(--gray-mid);
      max-width: 580px;
      line-height: 1.75;
    }

    /* ── Hero ── */
    .hero {
      background:
        linear-gradient(
          135deg,
          rgba(15, 14, 32, 0.58) 0%,
          rgba(32, 32, 58, 0.5) 50%,
          rgba(50, 50, 82, 0.42) 100%
        ),
        url("/images/bt3.png") center/cover no-repeat;
      position: relative;
      overflow: hidden;
      padding: 96px 48px 120px;
      min-height: 82vh;
      display: flex;
      align-items: center;
    }
    .hero-inner {
      position: relative;
      z-index: 2;
      max-width: 1160px;
      margin: 0 auto;
      width: 100%;
    }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: rgba(142, 144, 192, 0.14);
      border: 1px solid rgba(142, 144, 192, 0.38);
      padding: 6px 16px;
      border-radius: 100px;
      margin-bottom: 28px;
      color: rgba(255, 255, 255, 0.9);
    }
    .hero-eyebrow-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: linear-gradient(135deg, #9899cc, #c8c9e8);
      flex-shrink: 0;
    }
    .hero h1 {
      font-size: clamp(38px, 6.5vw, 78px);
      font-weight: 100;
      line-height: 1.04;
      color: var(--white);
      margin-bottom: 24px;
      letter-spacing: -0.03em;
      text-wrap: balance;
      max-width: 900px;
    }
    .hero h1 .accent {
      background: linear-gradient(90deg, #cdd2ff 0%, #edeeff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      font-size: 17px;
      color: rgba(255, 255, 255, 0.68);
      line-height: 1.75;
      max-width: 660px;
      margin-bottom: 42px;
    }
    .hero-actions {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    .btn-primary {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 30px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: linear-gradient(135deg, #444561 0%, #6b6c9a 100%);
      color: var(--white);
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-primary:hover {
      background: linear-gradient(135deg, #35344f 0%, #5b5c8c 100%);
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(68, 69, 97, 0.5);
    }
    .btn-ghost-dark {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 500;
      background: none;
      border: 1.5px solid rgba(255, 255, 255, 0.35);
      padding: 12px 26px;
      border-radius: var(--radius);
      cursor: pointer;
      color: rgba(255, 255, 255, 0.85);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all var(--tr);
    }
    .btn-ghost-dark:hover {
      border-color: rgba(255, 255, 255, 0.8);
      color: var(--white);
      background: rgba(255, 255, 255, 0.08);
    }

    /* ── Section 2: Overview ── */
    .overview-section {
      background: var(--white);
      padding: 88px 48px;
      border-top: 1px solid var(--border);
    }
    .overview-inner {
      max-width: 1160px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
    }
    .overview-left h2 {
      font-size: clamp(28px, 3.8vw, 46px);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.15;
      margin-bottom: 22px;
    }
    .overview-left p {
      font-size: 15px;
      color: var(--gray-mid);
      line-height: 1.8;
      margin-bottom: 18px;
    }
    .overview-left p:last-of-type {
      margin-bottom: 0;
    }
    .overview-right {
      display: flex;
      flex-direction: column;
      gap: 20px;
      padding-top: 8px;
    }
    .overview-stat {
      display: flex;
      align-items: flex-start;
      gap: 20px;
      padding: 24px 24px;
      background: var(--light-blue);
      border-radius: var(--radius);
      border: 1px solid var(--border);
    }
    .overview-stat-icon {
      width: 44px;
      height: 44px;
      border-radius: 10px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .osi-purple {
      background: rgba(68, 69, 97, 0.1);
      color: var(--purple);
    }
    .osi-green {
      background: rgba(61, 151, 138, 0.1);
      color: var(--green);
    }
    .osi-blue {
      background: rgba(36, 123, 150, 0.1);
      color: var(--blue);
    }
    .overview-stat-body {
    }
    .overview-stat-num {
      font-size: 28px;
      font-weight: 500;
      letter-spacing: -0.02em;
      color: var(--black);
      line-height: 1;
      margin-bottom: 4px;
    }
    .overview-stat-label {
      font-size: 13px;
      color: var(--gray-mid);
      line-height: 1.5;
    }

    /* ── Section 3: 7 Core Elements ── */
    .basecamps-section {
      background: var(--light-blue);
      padding: 88px 48px;
    }
    .basecamps-inner {
      max-width: 1160px;
      margin: 0 auto;
    }
    .basecamps-header {
      margin-bottom: 60px;
    }
    .basecamps-grid {
      display: grid;
      grid-template-columns: 420px 1fr;
      gap: 72px;
      align-items: start;
    }
    .basecamps-hex {
      position: sticky;
      top: 100px;
    }
    .basecamps-hex svg {
      width: 100%;
      height: auto;
    }
    .basecamps-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .basecamp-item {
      display: flex;
      gap: 20px;
      align-items: flex-start;
      padding: 24px 0;
      border-bottom: 1px solid var(--border);
    }
    .basecamp-item:first-child {
      border-top: 1px solid var(--border);
    }
    .basecamp-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 5px;
    }
    .basecamp-body {
    }
    .basecamp-name {
      font-size: 15px;
      font-weight: 600;
      color: var(--black);
      margin-bottom: 5px;
      letter-spacing: -0.01em;
    }
    .basecamp-desc {
      font-size: 13.5px;
      color: var(--gray-mid);
      line-height: 1.7;
    }

    /* ── Section 4: AIQUI in Practice ── */
    .process-section {
      background: var(--white);
      padding: 88px 48px;
      border-top: 1px solid var(--border);
    }
    .process-inner {
      max-width: 1160px;
      margin: 0 auto;
    }
    .process-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      margin-top: 56px;
      position: relative;
    }
    .process-steps::before {
      content: "";
      position: absolute;
      top: 27px;
      left: calc(12.5% + 14px);
      right: calc(12.5% + 14px);
      height: 2px;
      background: linear-gradient(
        90deg,
        var(--blue) 0%,
        var(--green) 33%,
        var(--purple) 66%,
        var(--orange-light) 100%
      );
      opacity: 0.3;
      z-index: 0;
    }
    .process-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 20px;
      position: relative;
      z-index: 1;
    }
    .process-num {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 20px;
      flex-shrink: 0;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.13);
      transition:
        transform var(--tr),
        box-shadow var(--tr);
    }
    .process-step:hover .process-num {
      transform: translateY(-4px);
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.18);
    }
    .pn-blue {
      background: var(--blue);
    }
    .pn-green {
      background: var(--green);
    }
    .pn-purple {
      background: var(--purple);
    }
    .pn-orange {
      background: var(--orange-light);
    }
    .process-step-name {
      font-size: 15px;
      font-weight: 600;
      color: var(--black);
      margin-bottom: 10px;
    }
    .process-step-desc {
      font-size: 13px;
      color: var(--gray-mid);
      line-height: 1.65;
    }

    /* ── Section 5: Who It's For ── */
    .for-section {
      background: var(--black);
      color: var(--white);
      padding: 88px 48px;
    }
    .for-header {
      max-width: 1160px;
      margin: 0 auto 52px;
    }
    .for-header .section-label {
      color: var(--green);
    }
    .for-header .section-title {
      color: var(--white);
    }
    .for-header .section-subtitle {
      color: rgba(255, 255, 255, 0.55);
    }
    .for-grid {
      max-width: 1160px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    .for-card {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.09);
      border-radius: var(--radius);
      padding: 32px 26px;
      transition:
        background var(--tr),
        border-color var(--tr),
        transform var(--tr);
    }
    .for-card:hover {
      background: rgba(255, 255, 255, 0.09);
      border-color: rgba(255, 255, 255, 0.18);
      transform: translateY(-3px);
    }
    .for-card-icon {
      width: 46px;
      height: 46px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
    }
    .fci-blue {
      background: rgba(36, 123, 150, 0.2);
      color: #4dc8e0;
    }
    .fci-green {
      background: rgba(61, 151, 138, 0.2);
      color: #72d4c5;
    }
    .fci-purple {
      background: rgba(142, 144, 200, 0.2);
      color: #b4baff;
    }
    .fci-orange {
      background: rgba(234, 151, 9, 0.2);
      color: #f5c842;
    }
    .for-card h3 {
      font-size: 16px;
      font-weight: 500;
      color: var(--white);
      margin-bottom: 10px;
      line-height: 1.3;
    }
    .for-card p {
      font-size: 13px;
      color: rgba(255, 255, 255, 0.5);
      line-height: 1.7;
    }

    /* ── Section 6: Case Study Feature ── */
    .feature-section {
      background: var(--light-blue);
      padding: 88px 48px;
    }
    .feature-card {
      max-width: 1160px;
      margin: 52px auto 0;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      display: grid;
      grid-template-columns: 420px 1fr;
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.07);
      transition:
        box-shadow var(--tr),
        transform var(--tr);
    }
    .feature-card:hover {
      box-shadow: 0 16px 56px rgba(0, 0, 0, 0.11);
      transform: translateY(-2px);
    }
    .feature-img {
      overflow: hidden;
    }
    .feature-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.5s ease;
    }
    .feature-card:hover .feature-img img {
      transform: scale(1.04);
    }
    .feature-body {
      padding: 48px 52px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .feature-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gray-light);
      margin-bottom: 18px;
    }
    .feature-tag::before {
      content: "";
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--blue);
      flex-shrink: 0;
    }
    .feature-body h3 {
      font-size: clamp(22px, 2.8vw, 34px);
      font-weight: 300;
      letter-spacing: -0.02em;
      color: var(--black);
      margin-bottom: 16px;
      line-height: 1.2;
    }
    .feature-body p {
      font-size: 14px;
      color: var(--gray-mid);
      line-height: 1.8;
      margin-bottom: 28px;
    }
    .feature-outcomes {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 32px;
    }
    .feature-outcome {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.04em;
      padding: 5px 12px;
      border-radius: 100px;
      border: 1px solid var(--border);
      color: var(--gray-mid);
      background: var(--light-blue);
    }
    .feature-cta {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--blue);
      transition: gap var(--tr);
    }
    .feature-cta:hover {
      gap: 10px;
    }

    /* ── CTA Band ── */
    .cta-band {
      background: linear-gradient(135deg, var(--blue) 0%, var(--purple) 100%);
      color: var(--white);
      padding: 80px 48px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-band::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          circle at 25% 40%,
          rgba(255, 255, 255, 0.07) 0%,
          transparent 50%
        ),
        radial-gradient(
          circle at 80% 70%,
          rgba(255, 255, 255, 0.05) 0%,
          transparent 45%
        );
      pointer-events: none;
    }
    .cta-band .container {
      position: relative;
      z-index: 1;
    }
    .cta-band h2 {
      font-size: clamp(28px, 4.5vw, 52px);
      font-weight: 300;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }
    .cta-band p {
      font-size: 16px;
      color: rgba(255, 255, 255, 0.68);
      max-width: 520px;
      margin: 0 auto 38px;
      line-height: 1.72;
    }
    .cta-band-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .btn-white-solid {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 30px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      background: var(--white);
      color: var(--blue);
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-white-solid:hover {
      background: var(--light-blue);
      transform: translateY(-1px);
    }
    .btn-white-ghost {
      font-family: var(--font);
      font-size: 14px;
      font-weight: 500;
      padding: 12px 30px;
      border-radius: var(--radius);
      border: 1.5px solid rgba(255, 255, 255, 0.45);
      cursor: pointer;
      color: var(--white);
      background: transparent;
      transition: all var(--tr);
      display: inline-block;
    }
    .btn-white-ghost:hover {
      border-color: rgba(255, 255, 255, 0.9);
      background: rgba(255, 255, 255, 0.1);
    }

    /* ── Responsive ── */
    @media (max-width: 960px) {
      nav {
        padding: 0 24px;
      }
      .nav-center,
      .nav-right .btn-outline {
        display: none;
      }
      .hamburger {
        display: block;
      }
      .hero {
        padding: 72px 24px 88px;
        min-height: auto;
      }
      .overview-inner {
        grid-template-columns: 1fr;
        gap: 48px;
      }
      .basecamps-grid {
        grid-template-columns: 1fr;
      }
      .basecamps-hex {
        position: static;
      }
      .process-steps {
        grid-template-columns: repeat(2, 1fr);
        gap: 40px;
      }
      .process-steps::before {
        display: none;
      }
      .for-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .feature-card {
        grid-template-columns: 1fr;
      }
      .feature-img {
        height: 260px;
      }
      .footer-top {
        grid-template-columns: 1fr 1fr;
        gap: 32px;
      }
      .overview-section,
      .basecamps-section,
      .process-section,
      .for-section,
      .feature-section,
      .cta-band {
        padding: 64px 24px;
      }
    }
    @media (max-width: 768px) {
      .hero {
        padding: 60px 20px 72px;
      }
      .process-steps {
        grid-template-columns: 1fr;
      }
      .for-grid {
        grid-template-columns: 1fr;
      }
      .hero-actions {
        flex-direction: column;
        align-items: flex-start;
      }
    }
    @media (max-width: 600px) {
      .cta-band-actions {
        flex-direction: column;
      }
      .btn-white-solid,
      .btn-white-ghost {
        width: 100%;
        text-align: center;
      }
      .footer-top {
        grid-template-columns: 1fr;
      }
      footer {
        padding: 56px 20px 32px;
      }
      .footer-bottom {
        flex-direction: column;
        text-align: center;
      }
    }

    /* ─── MOBILE DRAWER ─── */
    .mob-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.48);
      z-index: 200;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.28s ease;
    }
    .mob-overlay.open {
      opacity: 1;
      pointer-events: all;
    }
    .mob-drawer {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(300px, 90vw);
      background: var(--white);
      z-index: 201;
      transform: translateX(100%);
      transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      box-shadow: -6px 0 32px rgba(0, 0, 0, 0.16);
    }
    .mob-drawer.open {
      transform: translateX(0);
    }
    .mob-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .mob-close {
      background: none;
      border: none;
      cursor: pointer;
      padding: 5px;
      color: var(--black);
      line-height: 1;
      border-radius: var(--radius);
      transition: background var(--tr);
    }
    .mob-close:hover {
      background: var(--light-blue);
    }
    .mob-nav {
      flex: 1;
      display: block;
      height: auto;
      padding: 0;
      position: static;
      border-bottom: none;
      background: transparent;
      z-index: auto;
    }
    .mob-icon {
      width: 15px;
      height: 15px;
      flex-shrink: 0;
      opacity: 0.5;
      transition: opacity var(--tr);
    }
    .mob-sub-icon {
      width: 13px;
      height: 13px;
      flex-shrink: 0;
      opacity: 0.45;
      transition: opacity var(--tr);
    }
    .mob-item-inner {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .mob-services-btn {
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 16px;
      font-size: 13px;
      line-height: 1.2;
      font-weight: 500;
      font-family: var(--font);
      color: var(--black);
      background: none;
      border: none;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      text-align: left;
      transition: color var(--tr);
    }
    .mob-services-btn:hover {
