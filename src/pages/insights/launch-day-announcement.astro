---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.jsx";
import Footer from "../../components/Footer.jsx";
import "../../global.css";

const title = "Launch Day: ENTEVATE Is Here — ENTEVATE";
const description =
  "Launch announcement for ENTEVATE, outlining our mission, services, and how to connect.";
---

<BaseLayout title={title} description={description}>
    <style>
      /* Page accent (launch blue theme) — base vars from global.css */
      :root {
        --accent: #247b96;
        --accent-light: #5ba8c4;
      }

      /* ── Hero ── */
      .hero {
        background:
          linear-gradient(
            135deg,
            rgba(10, 30, 50, 0.82) 0%,
            rgba(20, 70, 100, 0.65) 50%,
            rgba(36, 123, 150, 0.35) 100%
          ),
          url("/images/bg-blue.png") center/cover no-repeat;
        position: relative;
        overflow: hidden;
        padding: 96px 48px 112px;
        min-height: 60vh;
        display: flex;
        align-items: center;
      }
      .hero-inner {
        position: relative;
        z-index: 2;
        max-width: 1160px;
        margin: 0 auto;
        width: 100%;
      }
      .breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.55);
        margin-bottom: 22px;
      }
      .breadcrumb a {
        color: rgba(255, 255, 255, 0.55);
        transition: color var(--tr);
      }
      .breadcrumb a:hover {
        color: rgba(255, 255, 255, 0.9);
      }
      .breadcrumb-sep {
        opacity: 0.4;
      }
      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: rgba(36, 123, 150, 0.18);
        border: 1px solid rgba(36, 123, 150, 0.4);
        padding: 6px 16px;
        border-radius: 100px;
        margin-bottom: 24px;
        color: rgba(255, 255, 255, 0.92);
      }
      .hero-eyebrow-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: linear-gradient(135deg, #247b96, #5ba8c4);
        flex-shrink: 0;
      }
      .hero h1 {
        font-size: clamp(36px, 5vw, 68px);
        font-weight: 100;
        line-height: 1.08;
        color: var(--white);
        margin-bottom: 22px;
        letter-spacing: -0.03em;
        max-width: 820px;
        text-wrap: balance;
      }
      .hero h1 .accent {
        background: linear-gradient(90deg, #5ba8c4 0%, #90cce4 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .hero-meta {
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
      }
      .hero-meta-item {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.55);
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .hero-meta-item svg {
        opacity: 0.6;
      }
      .hero-meta-divider {
        width: 1px;
        height: 14px;
        background: rgba(255, 255, 255, 0.2);
      }

      /* ── Article Layout ── */
      .article-wrap {
        max-width: 1160px;
        margin: 0 auto;
        padding: 80px 48px;
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 72px;
        align-items: start;
      }
      .article-body {
        min-width: 0;
      }
      .article-body h2 {
        font-size: clamp(22px, 2.8vw, 30px);
        font-weight: 300;
        letter-spacing: -0.02em;
        line-height: 1.2;
        color: var(--black);
        margin-bottom: 14px;
        margin-top: 52px;
      }
      .article-body h2:first-child {
        margin-top: 0;
      }
      .article-body p {
        font-size: 16px;
        color: #3d3d3d;
        line-height: 1.82;
        margin-bottom: 20px;
      }
      .article-body p:last-child {
        margin-bottom: 0;
      }
      .article-body ul {
        padding-left: 22px;
        margin-bottom: 20px;
      }
      .article-body li {
        font-size: 16px;
        color: #3d3d3d;
        line-height: 1.75;
        margin-bottom: 8px;
      }
      .pull-quote {
        border-left: 3px solid var(--accent);
        background: linear-gradient(
          135deg,
          rgba(36, 123, 150, 0.06),
          rgba(91, 168, 196, 0.04)
        );
        border-radius: 0 var(--radius) var(--radius) 0;
        padding: 24px 28px;
        margin: 36px 0;
      }
      .pull-quote p {
        font-size: 18px;
        font-weight: 300;
        font-style: italic;
        color: var(--black);
        line-height: 1.65;
        margin: 0;
        letter-spacing: -0.01em;
      }

      /* ── Service Cards ── */
      .service-cards {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin: 28px 0 36px;
      }
      .service-card {
        background: var(--light-blue);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
        position: relative;
        overflow: hidden;
      }
      .service-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--accent), var(--accent-light));
      }
      .service-card h4 {
        font-size: 14px;
        font-weight: 600;
        color: var(--black);
        margin-bottom: 8px;
      }
      .service-card p {
        font-size: 13.5px;
        color: var(--gray-mid);
        line-height: 1.65;
        margin: 0;
      }

      /* ── Sidebar ── */
      .article-sidebar {
        position: sticky;
        top: 90px;
        display: flex;
        flex-direction: column;
        gap: 24px;
      }
      .sidebar-card {
        background: var(--light-blue);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
      }
      .sidebar-card h4 {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--gray-light);
        margin-bottom: 16px;
      }
      .sidebar-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        font-weight: 600;
        padding: 6px 12px;
        border-radius: 100px;
        background: linear-gradient(
          90deg,
          rgba(36, 123, 150, 0.12),
          rgba(91, 168, 196, 0.12)
        );
        color: var(--accent);
        border: 1px solid rgba(36, 123, 150, 0.25);
        margin-bottom: 12px;
      }
      .sidebar-meta {
        font-size: 13px;
        color: var(--gray-mid);
        line-height: 1.7;
      }
      .sidebar-meta strong {
        color: var(--black);
        font-weight: 500;
      }
      .sidebar-divider {
        height: 1px;
        background: var(--border);
        margin: 14px 0;
      }
      .toc {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .toc a {
        font-size: 13px;
        color: var(--gray-mid);
        padding: 6px 10px;
        border-radius: var(--radius);
        display: block;
        transition: all var(--tr);
        border-left: 2px solid transparent;
      }
      .toc a:hover {
        color: var(--accent);
        background: rgba(36, 123, 150, 0.06);
        border-left-color: var(--accent);
      }
      .sidebar-cta {
        background: linear-gradient(
          135deg,
          rgba(10, 30, 50, 0.92) 0%,
          rgba(36, 123, 150, 0.88) 100%
        );
        border-radius: var(--radius);
        padding: 24px;
        color: var(--white);
      }
      .sidebar-cta h4 {
        font-size: 15px;
        font-weight: 400;
        line-height: 1.4;
        margin-bottom: 10px;
        color: var(--white);
        letter-spacing: 0;
        text-transform: none;
      }
      .sidebar-cta p {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.68);
        line-height: 1.6;
        margin-bottom: 18px;
      }
      .btn-blue {
        font-family: var(--font);
        font-size: 13px;
        font-weight: 600;
        padding: 11px 20px;
        border-radius: var(--radius);
        border: none;
        cursor: pointer;
        background: var(--white);
        color: var(--accent);
        transition: all var(--tr);
        display: inline-block;
        width: 100%;
        text-align: center;
      }
      .btn-blue:hover {
        background: var(--light-blue);
        transform: translateY(-1px);
      }

      /* ── Key Takeaways ── */
      .takeaways-section {
        background: var(--light-blue);
        padding: 80px 48px;
        border-top: 1px solid var(--border);
      }
      .takeaways-inner {
        max-width: 1160px;
        margin: 0 auto;
      }
      .section-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 14px;
        display: inline-block;
        color: var(--accent);
      }
      .section-title {
        font-size: clamp(26px, 3.5vw, 40px);
        font-weight: 300;
        letter-spacing: -0.02em;
        line-height: 1.1;
        margin-bottom: 48px;
      }
      .takeaways-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
      }
      .tk-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 28px 22px;
        position: relative;
        overflow: hidden;
        transition:
          box-shadow var(--tr),
          transform var(--tr);
      }
      .tk-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        border-radius: var(--radius) var(--radius) 0 0;
      }
      .tk-1::before {
        background: linear-gradient(90deg, #247b96, #5ba8c4);
      }
      .tk-2::before {
        background: linear-gradient(90deg, #3a90aa, #6abfda);
      }
      .tk-3::before {
        background: linear-gradient(90deg, #1d6a82, #4ea8c0);
      }
      .tk-card:hover {
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.07);
        transform: translateY(-3px);
      }
      .tk-icon {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        background: linear-gradient(
          135deg,
          rgba(36, 123, 150, 0.12),
          rgba(91, 168, 196, 0.08)
        );
        color: var(--accent);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
      }
      .tk-card h3 {
        font-size: 15px;
        font-weight: 500;
        color: var(--black);
        margin-bottom: 8px;
        line-height: 1.3;
      }
      .tk-card p {
        font-size: 13px;
        color: var(--gray-mid);
        line-height: 1.65;
      }

      /* ── CTA Band ── */
      .cta-band {
        background:
          linear-gradient(
            135deg,
            rgba(10, 30, 50, 0.92) 0%,
            rgba(20, 70, 100, 0.86) 50%,
            rgba(36, 123, 150, 0.8) 100%
          ),
          url("/images/bg-blue.png") center/cover no-repeat;
        color: var(--white);
        padding: 80px 48px;
        text-align: center;
      }
      .cta-band h2 {
        font-size: clamp(28px, 4vw, 48px);
        font-weight: 300;
        letter-spacing: -0.02em;
        margin-bottom: 14px;
      }
      .cta-band p {
        font-size: 16px;
        color: rgba(255, 255, 255, 0.65);
        max-width: 500px;
        margin: 0 auto 36px;
        line-height: 1.72;
      }
      .cta-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        flex-wrap: wrap;
      }
      .btn-blue-solid {
        font-family: var(--font);
        font-size: 14px;
        font-weight: 600;
        padding: 13px 30px;
        border-radius: var(--radius);
        border: none;
        cursor: pointer;
        background: linear-gradient(135deg, #247b96, #5ba8c4);
        color: var(--white);
        transition: all var(--tr);
        display: inline-block;
      }
      .btn-blue-solid:hover {
        opacity: 0.88;
        transform: translateY(-2px);
        box-shadow: 0 6px 24px rgba(36, 123, 150, 0.45);
      }
      .btn-ghost-dark {
        font-family: var(--font);
        font-size: 14px;
        font-weight: 500;
        background: none;
        border: 1.5px solid rgba(255, 255, 255, 0.35);
        padding: 12px 26px;
        border-radius: var(--radius);
        cursor: pointer;
        color: rgba(255, 255, 255, 0.85);
        display: inline-block;
        transition: all var(--tr);
      }
      .btn-ghost-dark:hover {
        border-color: rgba(255, 255, 255, 0.8);
        color: var(--white);
        background: rgba(255, 255, 255, 0.08);
      }

      /* ── Animations ── */
      .fade-up {
        opacity: 0;
        transform: translateY(22px);
        transition:
          opacity 0.55s ease,
          transform 0.55s ease;
      }
      .fade-up.visible {
        opacity: 1;
        transform: none;
      }

      /* ── Responsive ── */
      @media (max-width: 1024px) {
        .article-wrap {
          grid-template-columns: 1fr;
          gap: 48px;
        }
        .article-sidebar {
          position: static;
        }
        .takeaways-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 960px) {
        .hero {
          padding: 72px 24px 88px;
          min-height: auto;
        }
        .article-wrap {
          padding: 56px 24px;
        }
        .takeaways-section {
          padding: 64px 24px;
        }
        .cta-band {
          padding: 64px 24px;
        }
      }
      @media (max-width: 600px) {
        .hero {
          padding: 56px 20px 72px;
        }
        .article-wrap {
          padding: 44px 20px;
        }
        .takeaways-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  <Header client:load />

    <!-- ═══ HERO ═══ -->
    <section class="hero">
      <div class="hero-inner">
        <div class="breadcrumb">
          <a href="/our-work">Our Work</a>
          <span class="breadcrumb-sep">/</span>
          <span>Announcement</span>
        </div>
        <div class="hero-eyebrow fade-up">
          <span class="hero-eyebrow-dot"></span>
          Announcement
        </div>
        <h1 class="fade-up">
          ENTEVATE Is Here: Where <span class="accent"
            >Innovation Meets Impact</span>
        </h1>
        <div class="hero-meta fade-up">
          <span class="hero-meta-item">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              ><rect x="3" y="4" width="18" height="18" rx="2"></rect><line
                x1="16"
                y1="2"
                x2="16"
                y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line
                x1="3"
                y1="10"
                x2="21"
                y2="10"></line></svg
            >
            April 30, 2025
          </span>
          <span class="hero-meta-divider"></span>
          <span class="hero-meta-item">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              ><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"
              ></path></svg
            >
            2 min read
          </span>
          <span class="hero-meta-divider"></span>
          <span class="hero-meta-item">Announcement</span>
          <span class="hero-meta-divider"></span>
          <span class="hero-meta-item">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"></path><circle
                cx="12"
                cy="7"
                r="4"></circle></svg
            >
            ENTEVATE Team
          </span>
        </div>
      </div>
    </section>

    <!-- ═══ ARTICLE ═══ -->
    <div class="article-wrap">
      <!-- Article Body -->
      <article class="article-body">
        <p id="overview">
          Today, ENTEVATE officially opens its doors — and with it, a new
          chapter begins for businesses and communities navigating the
          relentless pace of digital disruption. We are a collective of
          passionate change-makers with one shared mission: to infuse innovation
          into organizations, making it understandable, impactful, and
          accessible to all.
        </p>

        <p>
          The word <strong>ENTEVATE</strong> says it all. It's a promise — of transformation,
          of growth, of meeting disruption not with hesitation, but with strategy.
          We believe innovation shouldn't be reserved for Silicon Valley giants. It
          should be something every business can harness, right now, wherever they
          are.
        </p>

        <div class="pull-quote fade-up">
          <p>
            "Innovation meets impact — that's not a tagline. It's a commitment
            we make to every client, every engagement, every day."
          </p>
        </div>

        <h2 id="what-we-do">What We Do</h2>

        <p>
          ENTEVATE operates through three tightly integrated service areas, each
          designed to create measurable momentum for our clients. Whether you're
          building a brand experience, charting a digital roadmap, or exploring
          entirely new business models, we have the expertise and the drive to
          get you there.
        </p>

        <div class="service-cards">
          <div class="service-card fade-up">
            <h4>Experiential Branding &amp; Marketing</h4>
            <p>
              We create brand experiences that don't just look good — they feel
              unforgettable. Through advanced technology and innovative design,
              we help brands connect with audiences in tangible, measurable
              ways. From immersive trade show activations to AR-powered
              storytelling, we turn your brand into an experience people talk
              about long after the moment passes.
            </p>
          </div>
          <div class="service-card fade-up">
            <h4>Innovation Roadmapping</h4>
            <p>
              Great ideas need great strategy. Our Innovation Roadmapping
              service develops comprehensive blueprints that take you from
              concept through execution — with clarity at every stage. Drawing
              on decades of expertise across industries, we transform ambition
              into measurable business outcomes, ensuring every step forward is
              grounded in data and aligned to your goals.
            </p>
          </div>
          <div class="service-card fade-up">
            <h4>Digital &amp; Content Transformation</h4>
            <p>
              We call it <strong>Content Readiness™</strong> — a proprietary approach
              to integrating emerging technologies like AI, IoT, AR, and VR into the
              way your organization operates and communicates. The result: enhanced
              efficiency, elevated customer experiences, and a content ecosystem built
              to scale with your ambitions.
            </p>
          </div>
        </div>

        <h2 id="why-now">Why Now?</h2>

        <p>
          Because the pace of change isn't slowing down. Digital disruption
          isn't a future threat — it's the present reality. Businesses that wait
          for clarity before acting will find themselves perpetually behind.
          Those that move with purpose, guided by the right partners, will
          define what their industries look like tomorrow.
        </p>

        <p>
          ENTEVATE was built for this moment. Not as another agency, not as a
          vendor, but as a true strategic partner — one deeply invested in your
          outcomes, your culture, and your long-term success.
        </p>

        <h2 id="where-to-find-us">Come Find Us</h2>

        <p>
          We're headquartered in the heart of the DFW innovation corridor, ready
          to work with organizations across the country and around the globe.
          Whether you're ready to start a conversation or just exploring what's
          possible, we'd love to connect.
        </p>

        <ul>
          <li>
            <strong>Location:</strong> 5 Cowboys Way, Suite 300, Frisco, Texas 75034
          </li>
          <li><strong>Phone:</strong> (972) 200-3445</li>
        </ul>

        <p>The future is being built right now — let's build it together.</p>
      </article>

      <!-- Sidebar -->
      <aside class="article-sidebar">
        <div class="sidebar-card">
          <h4>About This Post</h4>
          <div class="sidebar-tag">
            <svg
              width="11"
              height="11"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg
            >
            Announcement
          </div>
          <div class="sidebar-meta">
            <strong>Author</strong><br />ENTEVATE Team
            <div class="sidebar-divider"></div>
            <strong>Published</strong><br />April 30, 2025
            <div class="sidebar-divider"></div>
            <strong>Reading time</strong><br />~2 minutes
            <div class="sidebar-divider"></div>
            <strong>Type</strong><br />Announcement
          </div>
        </div>

        <div class="sidebar-card">
          <h4>In This Post</h4>
          <ul class="toc">
            <li><a href="#overview">Our Promise</a></li>
            <li><a href="#what-we-do">What We Do</a></li>
            <li><a href="#why-now">Why Now?</a></li>
            <li><a href="#where-to-find-us">Come Find Us</a></li>
            <li><a href="#takeaways">Key Takeaways</a></li>
          </ul>
        </div>

        <div class="sidebar-cta">
          <h4>Ready to start something?</h4>
          <p>
            Let's talk about where you want to go and how we can help get you
            there.
          </p>
          <a href="/contact" class="btn-blue">Get In Touch →</a>
        </div>

        <div class="sidebar-card">
          <h4>Explore Our Services</h4>
          <p
            style="font-size:13px;color:var(--gray-mid);line-height:1.6;margin-bottom:14px;"
          >
            Three integrated disciplines — Experiential Branding, Innovation
            Roadmapping, and Digital Transformation — working in concert to
            drive your growth.
          </p>
          <a
            href="/our-work"
            style="font-size:13px;font-weight:600;color:var(--accent);display:inline-flex;align-items:center;gap:4px;transition:gap var(--tr);"
            onmouseover="this.style.gap='8px'"
            onmouseout="this.style.gap='4px'">View Our Work →</a
          >
        </div>
      </aside>
    </div>

    <!-- ═══ KEY TAKEAWAYS ═══ -->
    <section class="takeaways-section" id="takeaways">
      <div class="takeaways-inner">
        <div class="fade-up">
          <div class="section-label">Key Takeaways</div>
          <h2 class="section-title">
            Three principles at the heart of everything we do.
          </h2>
        </div>
        <div class="takeaways-grid">
          <div class="tk-card tk-1 fade-up">
