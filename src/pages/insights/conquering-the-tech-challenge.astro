    padding: 6px 16px;
    border-radius: 100px;
    margin-bottom: 24px;
    color: rgba(255, 255, 255, 0.92);
  }
  .hero-eyebrow-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(135deg, #247b96, #5ba8c4);
    flex-shrink: 0;
  }
  .hero h1 {
    font-size: clamp(36px, 5vw, 68px);
    font-weight: 100;
    line-height: 1.08;
    color: var(--white);
    margin-bottom: 22px;
