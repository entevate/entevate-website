    overflow: hidden;
    padding: 96px 48px 112px;
    min-height: 64vh;
    display: flex;
    align-items: center;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1160px;
    margin: 0 auto;
    width: 100%;
  }
