{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/gtm",
      "destination": "https://entevate-growth-engine.vercel.app/gtm"
    },
    {
      "source": "/gtm/:path*",
      "destination": "https://entevate-growth-engine.vercel.app/gtm/:path*"
    },
    {
      "source": "/api/gtm/:path*",
      "destination": "https://entevate-growth-engine.vercel.app/api/gtm/:path*"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://entevate-growth-engine.vercel.app/_next/:path*"
    },
    {
      "source": "/ENTEVATE-Logo_White.svg",
      "destination": "https://entevate-growth-engine.vercel.app/ENTEVATE-Logo_White.svg"
    }
  ],
  "redirects": [
    {
      "source": "/growth-engine",
      "destination": "/gtm",
      "permanent": false
    },
    {
      "source": "/growth-engine/:path*",
      "destination": "/gtm/:path*",
      "permanent": false
    }
  ]
}
